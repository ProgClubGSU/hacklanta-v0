# Primary database (applications, events, etc.)
DATABASE_URL=postgresql+asyncpg://dev:dev@localhost:5432/hackathon

# Supabase database (team matching)
SUPABASE_DATABASE_URL=postgresql+asyncpg://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
SUPABASE_API_URL=https://[project-ref].supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...

REDIS_URL=redis://localhost:6379/0

CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# Resend (transactional email — replaces AWS SES)
RESEND_API_KEY=re_...

# AWS (S3 only for resume uploads — SES no longer used)
AWS_REGION=us-east-1
AWS_SES_FROM_EMAIL=noreply@hacklanta.com
S3_BUCKET_NAME=hacklanta-uploads

CORS_ORIGINS=["http://localhost:4321"]

DEBUG=true

SENTRY_DSN=

AXIOM_TOKEN=
AXIOM_DATASET=hacklanta-api
