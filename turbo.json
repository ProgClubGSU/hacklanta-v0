{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "env": [
        "PUBLIC_API_URL",
        "PUBLIC_CLERK_PUBLISHABLE_KEY",
        "PUBLIC_SENTRY_DSN",
        "CLERK_SECRET_KEY"
      ],
      "outputs": ["dist/**", ".astro/**"]
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"]
    }
  }
}
