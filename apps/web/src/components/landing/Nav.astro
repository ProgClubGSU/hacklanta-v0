---
// Nav — minimal, no auth buttons, no section links
---

<nav id="site-nav" class="fixed inset-x-0 top-0 z-50 transition-all duration-500">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-5 py-4 md:px-8">

    <!-- Wordmark -->
    <a
      href="/"
      class="hacklanta-logo font-display italic text-sm tracking-wide"
      style="color: rgba(255,255,255,0.65);"
    >
      Hacklanta
    </a>

    <!-- Minimal right links -->
    <div class="flex items-center gap-5 md:gap-7">
      <a
        href="https://discord.com/invite/BgKg9gskM2"
        target="_blank"
        rel="noopener noreferrer"
        class="nav-link flex items-center gap-2"
      >
        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515a.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0a12.64 12.64 0 0 0-.617-1.25a.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057a19.9 19.9 0 0 0 5.993 3.03a.078.078 0 0 0 .084-.028a14.09 14.09 0 0 0 1.226-1.994a.076.076 0 0 0-.041-.106a13.107 13.107 0 0 1-1.872-.892a.077.077 0 0 1-.008-.128a10.2 10.2 0 0 0 .372-.292a.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127a12.299 12.299 0 0 1-1.873.892a.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028a19.839 19.839 0 0 0 6.002-3.03a.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419c0-1.333.956-2.419 2.157-2.419c1.21 0 2.176 1.096 2.157 2.42c0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419c0-1.333.955-2.419 2.157-2.419c1.21 0 2.176 1.096 2.157 2.42c0 1.333-.946 2.418-2.157 2.418z"/>
        </svg>
        Discord
      </a>
      <a
        href="https://www.instagram.com/progsuhq/"
        target="_blank"
        rel="noopener noreferrer"
        class="nav-link hidden sm:flex items-center gap-2"
      >
        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path d="M12 2.163c3.204 0 3.584.012 4.85.07c3.252.148 4.771 1.691 4.919 4.919c.058 1.265.069 1.645.069 4.849c0 3.205-.012 3.584-.069 4.849c-.149 3.225-1.664 4.771-4.919 4.919c-1.266.058-1.644.07-4.85.07c-3.204 0-3.584-.012-4.849-.07c-3.26-.149-4.771-1.699-4.919-4.92c-.058-1.265-.07-1.644-.07-4.849c0-3.204.013-3.583.07-4.849c.149-3.227 1.664-4.771 4.919-4.919c1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072C2.695.272.273 2.69.073 7.052C.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948c.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072c4.354-.2 6.782-2.618 6.979-6.98c.059-1.28.073-1.689.073-4.948c0-3.259-.014-3.667-.072-4.947c-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324a6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8a4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881a1.44 1.44 0 0 0 0-2.881z"/>
        </svg>
        Instagram
      </a>
    </div>

  </div>
</nav>

<style>
  .nav-link {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.5);
    transition: color 0.2s, text-shadow 0.2s, letter-spacing 0.25s;
    position: relative;
  }
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -3px;
    left: 0;
    right: 0;
    height: 1px;
    background: rgba(196, 30, 58, 0.7);
    transform: scaleX(0);
    transform-origin: center;
    transition: transform 0.25s cubic-bezier(0.23, 1, 0.32, 1);
  }
  .nav-link:hover {
    color: rgba(255, 255, 255, 0.95);
    text-shadow: 0 0 14px rgba(255,255,255,0.25);
    letter-spacing: 0.32em;
  }
  .nav-link:hover::after {
    transform: scaleX(1);
  }

  .user-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: rgba(255, 255, 255, 0.6);
    transition: all 0.2s;
  }
  .user-icon:hover {
    border-color: rgba(196, 30, 58, 0.5);
    color: rgba(255, 255, 255, 0.85);
    box-shadow: 0 0 15px rgba(196, 30, 58, 0.2);
  }

  /* Hacklanta logo — outlined stroke on hover (matches TextLogo effect) */
  .hacklanta-logo {
    -webkit-text-stroke: 1px transparent;
    transition: color 0.35s ease, -webkit-text-stroke-color 0.35s ease, filter 0.35s ease;
  }
  .hacklanta-logo:hover {
    color: transparent !important;
    -webkit-text-stroke-color: rgba(255, 255, 255, 0.85);
    filter: drop-shadow(0 0 10px rgba(196,30,58,0.6)) drop-shadow(0 0 28px rgba(196,30,58,0.25));
  }

  /* Scrolled state — added by JS */
  #site-nav.scrolled {
    background: rgba(26, 10, 14, 0.9);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(196, 30, 58, 0.12);
  }
</style>

<script>
  const nav = document.getElementById('site-nav')!;
  const onScroll = () => {
    nav.classList.toggle('scrolled', window.scrollY > 60);
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
</script>
