---
// Nav — fixed top bar with logo + links
import { SignedIn, SignedOut } from '@clerk/astro/components';
---

<nav
  id="site-nav"
  class="fixed inset-x-0 top-0 z-50 transition-all duration-300"
>
  <div class="mx-auto flex max-w-6xl items-center justify-between px-5 py-4 md:px-8">
    <!-- Home icon -->
    <a href="/" class="relative z-10 shrink-0 text-white/60 transition-colors duration-200 hover:text-white" aria-label="Home">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
        <polyline points="9 22 9 12 15 12 15 22"></polyline>
      </svg>
    </a>

    <!-- Links -->
    <div class="flex items-center gap-6 md:gap-8">
      <a href="#schedule" class="nav-link">Schedule</a>
      <a href="#sponsors" class="nav-link">Sponsors</a>
      <a href="#faq" class="nav-link">FAQ</a>
      <SignedOut>
        <a
          href="/sign-in"
          class="relative inline-flex items-center gap-2 border border-white/40 bg-white/10 px-5 py-1.5 font-body text-[11px] font-semibold tracking-[0.15em] text-white uppercase transition-all duration-300 hover:border-white/70 hover:bg-white/20 hover:shadow-[0_0_20px_rgba(255,255,255,0.15)]"
        >
          Log In
        </a>
      </SignedOut>
      <SignedIn>
        <a
          href="/dashboard/team"
          class="relative inline-flex items-center gap-2 border border-[#FBAE17]/40 bg-[#FBAE17]/10 px-5 py-1.5 font-body text-[11px] font-semibold tracking-[0.15em] text-[#FBAE17] uppercase transition-all duration-300 hover:border-[#FBAE17]/70 hover:bg-[#FBAE17]/20 hover:shadow-[0_0_20px_rgba(251,174,23,0.15)]"
        >
          Team Matcher
        </a>
      </SignedIn>
      <a
        href="/apply"
        class="relative inline-flex items-center gap-2 border border-red/40 bg-red/10 px-5 py-1.5 font-body text-[11px] font-semibold tracking-[0.15em] text-red-bright uppercase transition-all duration-300 hover:border-red/70 hover:bg-red/20 hover:shadow-[0_0_20px_rgba(196,30,58,0.15)]"
      >
        Apply
      </a>
      <SignedIn>
        <a
          href="/status"
          class="user-icon ml-2"
          aria-label="Application status"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
            <circle cx="12" cy="7" r="4"></circle>
          </svg>
        </a>
      </SignedIn>
    </div>
  </div>
</nav>

<style>
  .nav-link {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.6);
    transition: color 0.2s;
  }
  .nav-link:hover {
    color: rgba(255, 255, 255, 0.85);
  }

  .user-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: rgba(255, 255, 255, 0.6);
    transition: all 0.2s;
  }
  .user-icon:hover {
    border-color: rgba(196, 30, 58, 0.5);
    color: rgba(255, 255, 255, 0.85);
    box-shadow: 0 0 15px rgba(196, 30, 58, 0.2);
  }

  /* Scrolled state — added by JS */
  #site-nav.scrolled {
    background: rgba(26, 10, 14, 0.9);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(196, 30, 58, 0.12);
  }
</style>

<script>
  const nav = document.getElementById('site-nav')!;
  const onScroll = () => {
    nav.classList.toggle('scrolled', window.scrollY > 60);
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
</script>
