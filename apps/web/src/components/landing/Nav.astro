---
// Nav — minimal, no auth buttons, no section links
---

<nav id="site-nav" class="fixed inset-x-0 top-0 z-50 transition-all duration-500">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-5 py-4 md:px-8">

    <!-- Wordmark -->
    <a
      href="/"
      class="hacklanta-logo font-display italic text-sm tracking-wide"
      style="color: rgba(255,255,255,0.65);"
    >
      Hacklanta
    </a>

    <!-- Minimal right links -->
    <div class="flex items-center gap-5 md:gap-7">
      <a
        href="https://discord.com/invite/BgKg9gskM2"
        target="_blank"
        rel="noopener noreferrer"
        class="nav-link"
      >Discord</a>
      <a
        href="https://www.instagram.com/progsuhq/"
        target="_blank"
        rel="noopener noreferrer"
        class="nav-link hidden sm:block"
      >Instagram</a>
    </div>

  </div>
</nav>

<style>
  .nav-link {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.5);
    transition: color 0.2s, text-shadow 0.2s, letter-spacing 0.25s;
    position: relative;
  }
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -3px;
    left: 0;
    right: 0;
    height: 1px;
    background: rgba(196, 30, 58, 0.7);
    transform: scaleX(0);
    transform-origin: center;
    transition: transform 0.25s cubic-bezier(0.23, 1, 0.32, 1);
  }
  .nav-link:hover {
    color: rgba(255, 255, 255, 0.95);
    text-shadow: 0 0 14px rgba(255,255,255,0.25);
    letter-spacing: 0.32em;
  }
  .nav-link:hover::after {
    transform: scaleX(1);
  }

  .user-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: rgba(255, 255, 255, 0.6);
    transition: all 0.2s;
  }
  .user-icon:hover {
    border-color: rgba(196, 30, 58, 0.5);
    color: rgba(255, 255, 255, 0.85);
    box-shadow: 0 0 15px rgba(196, 30, 58, 0.2);
  }

  /* Hacklanta logo — outlined stroke on hover (matches TextLogo effect) */
  .hacklanta-logo {
    -webkit-text-stroke: 1px transparent;
    transition: color 0.35s ease, -webkit-text-stroke-color 0.35s ease, filter 0.35s ease;
  }
  .hacklanta-logo:hover {
    color: transparent !important;
    -webkit-text-stroke-color: rgba(255, 255, 255, 0.85);
    filter: drop-shadow(0 0 10px rgba(196,30,58,0.6)) drop-shadow(0 0 28px rgba(196,30,58,0.25));
  }

  /* Scrolled state — added by JS */
  #site-nav.scrolled {
    background: rgba(26, 10, 14, 0.9);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(196, 30, 58, 0.12);
  }
</style>

<script>
  const nav = document.getElementById('site-nav')!;
  const onScroll = () => {
    nav.classList.toggle('scrolled', window.scrollY > 60);
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
</script>
