---
// [02] Schedule / Timeline section

const schedule = [
  { time: '9:00 AM', title: 'Doors Open + Check-in', type: 'general', desc: 'Grab your badge, find your table, settle in.' },
  { time: '9:30 AM', title: 'Opening Ceremony', type: 'ceremony', desc: 'Welcome, rules, and the official start.' },
  { time: '10:00 AM', title: 'Hacking Begins', type: 'general', desc: 'The clock starts. Go all in.' },
  { time: '11:00 AM', title: 'Workshop: Intro to APIs', type: 'workshop', desc: 'Build your first REST API from scratch.' },
  { time: '12:30 PM', title: 'Lunch', type: 'meal', desc: 'Food provided — recharge and network.' },
  { time: '1:30 PM', title: 'Workshop: AI/ML Crash Course', type: 'workshop', desc: 'Get hands-on with machine learning.' },
  { time: '3:00 PM', title: 'Mini-game: Speed Debug', type: 'minigame', desc: 'Fix bugs against the clock. Prizes for the fastest.' },
  { time: '5:00 PM', title: 'Dinner', type: 'meal', desc: 'Refuel for the home stretch.' },
  { time: '6:00 PM', title: 'Mini-game: UI Roulette', type: 'minigame', desc: 'Random UI challenge. Spin the wheel of CSS.' },
  { time: '8:00 PM', title: 'Submissions Due', type: 'general', desc: 'Final commits. Push it or lose it.' },
  { time: '8:30 PM', title: 'Demo & Judging', type: 'ceremony', desc: 'Show what you built. Impress the judges.' },
  { time: '9:30 PM', title: 'Awards Ceremony', type: 'ceremony', desc: 'Winners announced. Prizes dealt.' },
];

const typeConfig: Record<string, { color: string; border: string; label: string }> = {
  workshop: { color: 'text-neon-green', border: 'border-neon-green/40', label: 'WORKSHOP' },
  minigame: { color: 'text-hot-pink', border: 'border-hot-pink/40', label: 'MINI-GAME' },
  ceremony: { color: 'text-gold', border: 'border-gold/40', label: 'CEREMONY' },
  meal: { color: 'text-cyan', border: 'border-cyan/40', label: 'MEAL' },
  general: { color: 'text-text-secondary', border: 'border-base-border', label: 'GENERAL' },
};
---

<section id="schedule" class="relative bg-base-black px-4 py-24 md:py-32">
  <div class="mx-auto max-w-4xl">
    <!-- Section header -->
    <div class="schedule-header mb-12">
      <div class="flex items-center gap-3 font-mono text-xs tracking-widest text-text-muted">
        <span class="text-neon-green">[02]</span>
        <span class="h-px flex-1 bg-base-border"></span>
        <span>// schedule</span>
      </div>
      <h2 class="mt-4 font-display text-4xl font-black text-text-primary md:text-5xl">
        The <span class="text-hot-pink">lineup</span>
      </h2>
      <p class="mt-3 font-mono text-sm text-text-muted">
        12 hours. One shot. Here's the deal.
      </p>
    </div>

    <!-- Timeline -->
    <div class="relative">
      <!-- Vertical line -->
      <div class="absolute left-[72px] top-0 hidden h-full w-px bg-gradient-to-b from-neon-green/30 via-base-border to-base-border md:block"></div>

      <div class="space-y-3">
        {schedule.map((event) => {
          const cfg = typeConfig[event.type] || typeConfig.general;
          return (
            <div class={`schedule-item group flex gap-4 md:gap-6`}>
              {/* Time */}
              <div class="hidden w-[72px] shrink-0 pt-4 text-right md:block">
                <span class="font-mono text-xs text-text-muted">{event.time}</span>
              </div>

              {/* Dot */}
              <div class="relative hidden shrink-0 md:block">
                <div class={`mt-4 h-3 w-3 rounded-full border-2 ${cfg.border} bg-base-black transition-colors group-hover:bg-base-card`}></div>
              </div>

              {/* Card */}
              <div class={`flex-1 border ${cfg.border} bg-base-card p-4 transition-all group-hover:shadow-[0_0_15px_rgba(0,0,0,0.3)]`}>
                <div class="flex flex-wrap items-center gap-2">
                  <span class={`font-mono text-[10px] tracking-widest ${cfg.color}`}>{cfg.label}</span>
                  <span class="font-mono text-[10px] text-text-muted md:hidden">{event.time}</span>
                </div>
                <h3 class="mt-1 font-display text-sm font-bold text-text-primary">{event.title}</h3>
                <p class="mt-1 font-mono text-xs text-text-muted">{event.desc}</p>
              </div>
            </div>
          );
        })}
      </div>
    </div>

    <!-- Type legend -->
    <div class="mt-8 flex flex-wrap justify-center gap-4">
      {Object.entries(typeConfig).map(([, cfg]) => (
        <span class={`font-mono text-[10px] tracking-wider ${cfg.color}`}>
          <span class="mr-1 inline-block h-2 w-2 rounded-full" style={`background: currentColor;`}></span>
          {cfg.label}
        </span>
      ))}
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  gsap.from('.schedule-header', {
    scrollTrigger: { trigger: '.schedule-header', start: 'top 80%' },
    opacity: 0,
    y: 30,
    duration: 0.8,
  });

  gsap.from('.schedule-item', {
    scrollTrigger: { trigger: '.schedule-item', start: 'top 85%' },
    opacity: 0,
    x: -30,
    stagger: 0.08,
    duration: 0.6,
    ease: 'power2.out',
  });
</script>
