---
// [03] Schedule — detailed run-of-show timeline

const suitSvg = {
  spade:   '<svg viewBox="0 0 100 100" fill="currentColor" aria-hidden="true" style="width:1em;height:1em;display:inline-block;vertical-align:-0.125em;"><path d="M50 5C50 5 20 40 20 58c0 12 8 20 18 20 6 0 10-3 12-7v14H40v6h20v-6H50V71c2 4 6 7 12 7 10 0 18-8 18-20C80 40 50 5 50 5z"/></svg>',
  heart:   '<svg viewBox="0 0 100 100" fill="currentColor" aria-hidden="true" style="width:1em;height:1em;display:inline-block;vertical-align:-0.125em;"><path d="M50 90C50 90 5 55 5 35 5 18 20 5 35 10c7 3 12 8 15 15 3-7 8-12 15-15 15-5 30 8 30 25C95 55 50 90 50 90z"/></svg>',
  diamond: '<svg viewBox="0 0 100 100" fill="currentColor" aria-hidden="true" style="width:1em;height:1em;display:inline-block;vertical-align:-0.125em;"><path d="M50 5L5 50 50 95 95 50z"/></svg>',
  club:    '<svg viewBox="0 0 100 100" fill="currentColor" aria-hidden="true" style="width:1em;height:1em;display:inline-block;vertical-align:-0.125em;"><circle cx="35" cy="45" r="20"/><circle cx="65" cy="45" r="20"/><circle cx="50" cy="28" r="20"/><rect x="40" y="58" width="20" height="28"/><rect x="30" y="82" width="40" height="8"/></svg>',
};

type ScheduleEvent = {
  time: string;
  label: string;
  note?: string;
  tag?: string; // e.g. 'sponsor' | 'food' | 'judging' | 'workshop' | 'ceremony'
};

const phases: Array<{
  name: string;
  subtitle: string;
  timeRange: string;
  suit: string;
  color: string;
  rgb: string;
  events: ScheduleEvent[];
}> = [
  {
    name: 'THE OPENING',
    subtitle: 'ANTE UP',
    timeRange: '9:45 AM – 2:00 PM',
    suit: suitSvg.spade,
    color: '#C41E3A',
    rgb: '196,30,58',
    events: [
      { time: '9:45 AM',  label: 'Sponsor Tables Open',           tag: 'sponsor',  note: 'Swag & networking opportunities for hackers' },
      { time: '9:00 AM',  label: 'Breakfast Closes',              tag: 'food' },
      { time: '10:00 AM', label: 'Snack Bar Opens',               tag: 'food' },
      { time: '10:30 AM', label: 'Workshop #1 Begins',            tag: 'workshop' },
      { time: '11:15 AM', label: 'Workshop #1 Closes',            tag: 'workshop' },
      { time: '11:30 AM', label: 'Blackjack / Poker Tables Open', note: 'Poker chips granted after workshop — no real gambling' },
      { time: '12:00 PM', label: 'Submission Info Announcement',  note: 'Discord announcement: where to submit, rules, demos, etc.' },
      { time: '12:15 PM', label: 'Project Submission Form Opens', note: 'Form for electing to submit — fill out before 4:00 PM' },
      { time: '12:15 PM', label: 'Judge Mentor Hours Open',       note: '"Mentorship" style event — attendees can interact with judges' },
      { time: '12:15 PM', label: 'Mentor Session — Amazon',       tag: 'sponsor',  note: 'Classroom South 103' },
      { time: '12:30 PM', label: 'Merchandise Store Opens',       note: 'Attendees begin receiving poker chips' },
      { time: '1:00 PM',  label: 'Mentor Session — Amazon Ends',  tag: 'sponsor' },
      { time: '1:00 PM',  label: 'MonkeyType Competition Starts' },
      { time: '1:10 PM',  label: 'Mentor Session — Microsoft',    tag: 'sponsor',  note: 'Classroom South 105' },
      { time: '1:20 PM',  label: 'Lunch Pickup / Delivery',       tag: 'food' },
      { time: '1:55 PM',  label: 'Mentor Session — Microsoft Ends', tag: 'sponsor' },
      { time: '2:00 PM',  label: 'Lunch Opens',                   tag: 'food',     note: 'Lunch Line will open in Classroom South 150' },
    ],
  },
  {
    name: 'THE GRIND',
    subtitle: 'PLAYING THE HAND',
    timeRange: '2:45 PM – 6:45 PM',
    suit: suitSvg.heart,
    color: '#E63946',
    rgb: '230,57,70',
    events: [
      { time: '2:45 PM', label: 'Lunch Closes',                 tag: 'food' },
      { time: '3:15 PM', label: 'Judge Mentor Hours Close' },
      { time: '3:45 PM', label: 'Workshop #2 Begins — Cox',     tag: 'workshop' },
      { time: '4:30 PM', label: 'Workshop #2 Ends',             tag: 'workshop' },
      { time: '5:00 PM', label: 'Dinner Pickup / Delivery',     tag: 'food',    note: 'Please account for traffic' },
      { time: '5:30 PM', label: 'Dinner Line Opens',            tag: 'food',    note: 'Dinner Line opens in Classroom South 150' },
      { time: '6:00 PM', label: 'Dinner Line Closes',           tag: 'food' },
      { time: '6:15 PM', label: 'Hacking Ending Alert — 45 min', note: 'Discord announcement + vocal alert: hacking ends in 45 min' },
      { time: '6:40 PM', label: 'Hacking Ending Alert — 5 min',  note: 'Discord announcement + vocal alert: hacking ends in 5 min' },
      { time: '6:45 PM', label: 'Hacking Officially Ends',      note: 'All submissions should now be made' },
    ],
  },
  {
    name: 'THE FINAL HAND',
    subtitle: 'ALL IN',
    timeRange: '7:10 PM – 9:00 PM',
    suit: suitSvg.diamond,
    color: '#C9A84C',
    rgb: '201,168,76',
    events: [
      { time: '7:10 PM', label: 'Judging Begins'},
      { time: '8:00 PM', label: 'Judging Concludes' },
      { time: '8:30 PM', label: 'Closing Ceremony' },
    ],
  },
];


---

<section id="schedule" class="relative overflow-hidden bg-black px-4 py-16 md:py-24">
  <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-red/30 to-transparent"></div>

  <!-- Ambient glows -->
  <div
    class="pointer-events-none absolute left-[-8%] top-[18%] h-[680px] w-[680px] rounded-full"
    style="background: radial-gradient(circle, rgba(196,30,58,0.06) 0%, rgba(196,30,58,0.02) 42%, transparent 68%);"
  ></div>
  <div
    class="pointer-events-none absolute right-[-5%] bottom-[-10%] h-[500px] w-[500px] rounded-full opacity-[0.06] blur-[80px]"
    style="background: radial-gradient(circle, rgba(201,168,76,0.45) 0%, transparent 70%);"
  ></div>

  <!-- Ghosted suit marks -->
  <div class="pointer-events-none absolute inset-0 select-none overflow-hidden" aria-hidden="true">
    <span class="lineup-suit absolute left-[2%] top-[10%] text-white/[0.018] md:w-[16rem] w-[12rem]"><svg viewBox="0 0 100 100" fill="currentColor" aria-hidden="true"><path d="M50 5C50 5 20 40 20 58c0 12 8 20 18 20 6 0 10-3 12-7v14H40v6h20v-6H50V71c2 4 6 7 12 7 10 0 18-8 18-20C80 40 50 5 50 5z"/></svg></span>
    <span class="lineup-suit absolute right-[4%] top-[26%] text-red/[0.03] md:w-[15rem] w-[11rem]"><svg viewBox="0 0 100 100" fill="currentColor" aria-hidden="true"><path d="M50 90C50 90 5 55 5 35 5 18 20 5 35 10c7 3 12 8 15 15 3-7 8-12 15-15 15-5 30 8 30 25C95 55 50 90 50 90z"/></svg></span>
    <span class="lineup-suit absolute left-[12%] bottom-[6%] text-gold/[0.04] md:w-[14rem] w-[10rem]"><svg viewBox="0 0 100 100" fill="currentColor" aria-hidden="true"><path d="M50 5L5 50 50 95 95 50z"/></svg></span>
  </div>

  <div class="relative z-10 mx-auto max-w-6xl">
    <!-- Header -->
    <div class="lineup-header mb-14 md:mb-20">
      <div class="flex items-center gap-3 font-mono text-[11px] tracking-[0.3em] text-gray-400">
        <span class="text-red/80">[02]</span>
        <span class="h-px flex-1 bg-gradient-to-r from-border/80 to-transparent"></span>
        <span>LINEUP</span>
      </div>
      <div class="mt-6 grid gap-6 lg:grid-cols-[1.15fr_1fr] lg:items-end">
        <h2 class="font-display text-5xl tracking-wide text-white-pure md:text-7xl">
          THE LINEUP
        </h2>
      </div>
    </div>

    <!-- Phase selector buttons -->
    <div class="lineup-board mx-auto max-w-6xl">
      <div class="mb-5 flex flex-wrap gap-2">
        {phases.map((phase, pi) => (
          <button
            type="button"
            class="phase-tab flex items-center gap-2 border px-4 py-2.5 font-mono text-[11px] tracking-[0.2em] uppercase transition-all duration-300"
            data-phase={pi}
            style={`
              --tab-rgb: ${phase.rgb};
              --tab-color: ${phase.color};
              border-color: rgba(${phase.rgb}, ${pi === 0 ? '0.5' : '0.15'});
              background: ${pi === 0 ? `rgba(${phase.rgb}, 0.08)` : 'transparent'};
              color: ${pi === 0 ? phase.color : 'rgba(255,255,255,0.4)'};
            `}
          >
            <span class="text-xs leading-none" set:html={phase.suit} />
            <span class="hidden sm:inline">{phase.name}</span>
            <span class="sm:hidden">PHASE {pi + 1}</span>
          </button>
        ))}
      </div>

      <!-- Phase cards -->
      {phases.map((phase, pi) => (
        <article
          class="phase-card group relative overflow-hidden border border-border/60 bg-black-card/70 p-5 md:p-7"
          data-phase-card={pi}
          style={`--phase-rgb: ${phase.rgb}; ${pi !== 0 ? 'display:none;' : ''}`}
        >
          <div
            class="pointer-events-none absolute inset-x-0 top-0 h-px opacity-70"
            style={`background: linear-gradient(90deg, transparent, rgba(${phase.rgb},0.46), transparent);`}
          ></div>
          <div
            class="pointer-events-none absolute -right-10 -top-10 h-44 w-44 rounded-full opacity-0 blur-[1px] transition-opacity duration-500 group-hover:opacity-100"
            style={`background: radial-gradient(circle, rgba(${phase.rgb}, 0.2) 0%, rgba(${phase.rgb},0.05) 40%, transparent 68%);`}
          ></div>

          <header class="flex flex-wrap items-start justify-between gap-4">
            <div>
              <p
                class="font-mono text-[10px] tracking-[0.38em] uppercase"
                style={`color: rgba(${phase.rgb}, 0.65);`}
              >
                {phase.subtitle}
              </p>
              <h3 class="mt-1 font-display text-2xl tracking-wide text-white md:text-[2rem]">
                {phase.name}
              </h3>
              <p class="mt-1 font-mono text-[10px] tracking-[0.22em] text-gray-500">
                {phase.timeRange}
              </p>
            </div>

            <div class="text-right">
              <p class="font-display text-4xl leading-none" style={`color: ${phase.color};`}>
                <Fragment set:html={phase.suit} />
              </p>
              <p class="mt-1 font-mono text-[9px] tracking-[0.22em] text-gray-500">
                PHASE {pi + 1}
              </p>
            </div>
          </header>

          <!-- Timeline list -->
          <div class="mt-5 border-t border-border/40 pt-5 space-y-0">
            {phase.events.map((evt, ei) => {
              return (
                <div
                  class="schedule-row group/row relative flex items-start gap-3 border-b border-border/20 py-3 last:border-b-0"
                  data-index={ei}
                >
                  <!-- left accent line -->
                  <div
                    class="pointer-events-none absolute left-0 inset-y-0 w-[2px] opacity-0 group-hover/row:opacity-100 transition-opacity duration-200 rounded-full"
                    style={`background: rgba(${phase.rgb}, 0.5);`}
                  ></div>

                  <!-- time chip -->
                  <span
                    class="flex-shrink-0 w-[72px] font-mono text-[10px] tracking-[0.12em] pt-0.5"
                    style={`color: rgba(${phase.rgb}, 0.72);`}
                  >
                    {evt.time}
                  </span>

                  <!-- suit dot -->
                  <span
                    class="flex-shrink-0 text-[11px] leading-none mt-0.5"
                    style={`color: rgba(${phase.rgb}, 0.55);`}
                  >
                    <Fragment set:html={phase.suit} />
                  </span>

                  <!-- content -->
                  <div class="flex-1 min-w-0">
                    <div class="flex flex-wrap items-center gap-2">
                      <span class="font-display text-sm tracking-wide text-white/90 md:text-base">
                        {evt.label}
                      </span>

                    </div>
                    {evt.note && (
                      <p class="mt-0.5 font-mono text-[10px] leading-relaxed text-white/30">
                        {evt.note}
                      </p>
                    )}
                  </div>

                  <!-- trailing dash -->
                  <span
                    class="hidden md:block flex-shrink-0 self-center h-px w-8"
                    style={`background: linear-gradient(90deg, rgba(${phase.rgb},0.25), transparent);`}
                  ></span>
                </div>
              );
            })}
          </div>
        </article>
      ))}
    </div>

    <!-- Date badge -->
    <p class="mt-8 text-center font-mono text-[11px] tracking-[0.2em] text-white/35 uppercase">
      Saturday, March 28 @ Georgia State University
    </p>

  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  gsap.from('.lineup-header', {
    scrollTrigger: { trigger: '.lineup-header', start: 'top 82%' },
    opacity: 0,
    y: 28,
    duration: 0.9,
    ease: 'power3.out',
  });

  gsap.from('.phase-card[data-phase-card="0"]', {
    scrollTrigger: { trigger: '.lineup-board', start: 'top 80%' },
    opacity: 0,
    y: 28,
    duration: 0.75,
    ease: 'power3.out',
  });

  // Phase tab switching
  const tabs = document.querySelectorAll<HTMLButtonElement>('.phase-tab');
  const cards = document.querySelectorAll<HTMLElement>('.phase-card');

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const idx = tab.dataset.phase!;

      // Update tabs
      tabs.forEach((t) => {
        const rgb = t.style.getPropertyValue('--tab-rgb');
        const isActive = t.dataset.phase === idx;
        t.style.borderColor = `rgba(${rgb}, ${isActive ? '0.5' : '0.15'})`;
        t.style.background = isActive ? `rgba(${rgb}, 0.08)` : 'transparent';
        t.style.color = isActive ? t.style.getPropertyValue('--tab-color') : 'rgba(255,255,255,0.4)';
      });

      // Show/hide cards with animation
      cards.forEach((card) => {
        if (card.dataset.phaseCard === idx) {
          card.style.display = '';
          gsap.fromTo(card, { opacity: 0, y: 16 }, { opacity: 1, y: 0, duration: 0.4, ease: 'power2.out' });

          // Stagger rows
          const rows = card.querySelectorAll('.schedule-row');
          gsap.fromTo(rows,
            { opacity: 0, x: -8 },
            { opacity: 1, x: 0, duration: 0.35, stagger: 0.03, ease: 'power2.out' }
          );
        } else {
          card.style.display = 'none';
        }
      });
    });
  });

  // Subtle parallax on ghosted suits
  const suits = Array.from(document.querySelectorAll('.lineup-suit'));
  const lineupSection = document.getElementById('schedule');
  const suitAnims = suits.map((el) => ({
    x: gsap.quickTo(el, 'x', { duration: 0.8, ease: 'power2.out' }),
    y: gsap.quickTo(el, 'y', { duration: 0.8, ease: 'power2.out' }),
  }));

  lineupSection?.addEventListener('mousemove', (e) => {
    const rect = lineupSection.getBoundingClientRect();
    const nx = (e.clientX - rect.left) / rect.width - 0.5;
    const ny = (e.clientY - rect.top) / rect.height - 0.5;
    suitAnims.forEach((anim, i) => {
      const speed = 16 + i * 8;
      anim.x(nx * speed);
      anim.y(ny * speed * 0.5);
    });
  });

  lineupSection?.addEventListener('mouseleave', () => {
    suitAnims.forEach((anim) => {
      anim.x(0);
      anim.y(0);
    });
  });
</script>
