        rgba(154, 142, 120, 0.06) 3px,
        rgba(154, 142, 120, 0.06) 4px
      ),
      repeating-linear-gradient(
        -45deg,
        transparent,
        transparent 3px,
        rgba(154, 142, 120, 0.06) 3px,
        rgba(154, 142, 120, 0.06) 4px
      );
