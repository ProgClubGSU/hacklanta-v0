  type SymbolFn = () => string;
  const symbolDefs: SymbolFn[] = [
    ICONS.cherry,
    ICONS.diamond,
    ICONS.seven,
    ICONS.bar,
    ICONS.bell,
    ICONS.horseshoe,
    ICONS.melon,
    ICONS.orange,
    ICONS.plum,
    ICONS.lemon,
  ];
  const WIN_REELS: SymbolFn[] = [ICONS.sixGreen, ICONS.seven, ICONS.sixGold, ICONS.nineCyan];
  const reelEls = [reels.days, reels.hours, reels.mins, reels.secs] as HTMLElement[];
  const keys = ['days', 'hours', 'mins', 'secs'] as const;
  const marqueeText = document.querySelector<HTMLElement>('.marquee-text')!;
  const cabinet = document.querySelector<HTMLElement>('.slot-cabinet')!;

  function randSym(): SymbolFn {
    return symbolDefs[Math.floor(Math.random() * symbolDefs.length)];
  }
  // Safari won't correctly parse SVG gradients/defs when inserted via innerHTML
  // on a non-SVG element (<span>). The SVG gets parsed in the HTML namespace instead
  // of the SVG namespace, so <linearGradient>, <radialGradient>, etc. are ignored.
  // Fix: parse through a temporary <div> so the browser creates proper SVG DOM nodes,
  // then move the node into the target element.
  const _svgParser = document.createElement('div');
  function setSymbol(el: HTMLElement, sym: SymbolFn) {
    _svgParser.innerHTML = sym();
    el.textContent = '';
    const svgNode = _svgParser.firstElementChild;
    if (svgNode) el.appendChild(svgNode);
  }

  // Hide labels during spin phase
  Object.values(reelLabels).forEach((l) => ((l as HTMLElement).style.opacity = '0'));

  // Start all reels spinning with symbols
  reelEls.forEach((el) => {
    setSymbol(el, randSym());
  });

  // Compute reel window height in px — Safari chokes on percentage-based y transforms
  // when the animated element contains SVGs with filters/gradients inside overflow:hidden.
  // Using pixel values avoids the Safari rendering bug entirely.
  const reelWindowH = (reelEls[0].closest('.slot-reel-window') as HTMLElement).offsetHeight;
  const yOff = Math.ceil(reelWindowH * 1.1);   // 110% equivalent
  const yUp = -yOff;
  const yDown = yOff;

  // GSAP-based smooth vertical scroll spinning
  const stopFns: (() => void)[] = [];

  function startSpinning() {
    reelEls.forEach((el, i) => {
      const targetSpeed = 0.04 + i * 0.004;
      let speed = 0.12;
      let running = true;

      function cycle() {
        if (!running) return;
        speed = Math.max(targetSpeed, speed * 0.6);
        gsap.to(el, {
          y: yUp,
          duration: speed,
          ease: 'none',
          onComplete: () => {
            if (!running) return;
            setSymbol(el, randSym());
            gsap.set(el, { y: yDown });
            gsap.to(el, { y: 0, duration: speed, ease: 'none', onComplete: cycle });
          },
        });
      }

      stopFns[i] = () => {
        running = false;
        gsap.killTweensOf(el);
      };
      cycle();
    });
  }

  // Stop reel with smooth deceleration + bounce landing
  async function stopReel(index: number, target: SymbolFn): Promise<void> {
    stopFns[index]();
    const el = reelEls[index];

    // Deceleration: progressively slower cycles
    const durs = [0.07, 0.12, 0.18];
    for (const dur of durs) {
      await new Promise<void>((res) => {
        gsap.to(el, {
          y: yUp,
          duration: dur,
          ease: 'none',
          onComplete: () => {
            setSymbol(el, randSym());
            gsap.set(el, { y: yDown });
            gsap.to(el, { y: 0, duration: dur, ease: 'none', onComplete: res });
          },
        });
      });
    }

    // Final landing: ease-in exit, bounce-in entry
    await new Promise<void>((res) => {
      gsap.to(el, {
        y: yUp,
        duration: 0.14,
        ease: 'power2.in',
        onComplete: () => {
          setSymbol(el, target);
          gsap.set(el, { y: yDown });
          gsap.to(el, {
            y: 0,
            duration: 0.28,
            ease: 'back.out(1.4)',
            onComplete: () => {
              const reelWindow = el.closest('.slot-reel-window') as HTMLElement;
              if (reelWindow) {
                gsap.fromTo(
                  reelWindow,
                  {
                    boxShadow:
                      'inset 0 4px 16px rgba(0,0,0,1), inset 0 -4px 16px rgba(0,0,0,1), 0 0 20px rgba(196,30,58,0.6)',
                  },
                  {
                    boxShadow:
                      'inset 0 4px 16px rgba(0,0,0,1), inset 0 -4px 16px rgba(0,0,0,1), 0 0 0px rgba(196,30,58,0)',
                    duration: 0.5,
                    ease: 'power2.out',
                  },
                );
              }
              res();
            },
          });
        },
      });
    });
  }

  // Main sequence
  setTimeout(async () => {
    // Reveal Hacklanta logo early, while slot machine spins
    gsap.to('.hero-title', { opacity: 1, y: 0, duration: 1.4, ease: 'power2.out' });

    startSpinning();

    await new Promise((r) => setTimeout(r, 1000));

    // Stop reels left to right with stagger
    await stopReel(0, WIN_REELS[0]);
    await new Promise((r) => setTimeout(r, 100));
    await stopReel(1, WIN_REELS[1]);
    await new Promise((r) => setTimeout(r, 100));
    await stopReel(2, WIN_REELS[2]);
    await new Promise((r) => setTimeout(r, 100));
    await stopReel(3, WIN_REELS[3]);

    // === JACKPOT! ===
    // Flash the whole cabinet
    gsap.to(cabinet, {
      boxShadow:
        '0 0 60px rgba(196,30,58,0.5), 0 0 120px rgba(196,30,58,0.2), inset 0 1px 0 rgba(255,255,255,0.06)',
      duration: 0.3,
      yoyo: true,
      repeat: 3,
      ease: 'power2.inOut',
    });

    // Flash marquee text
    marqueeText.textContent = '★ JACKPOT ★';
    gsap.to(marqueeText, {
      color: 'rgba(255,200,100,0.95)',
      textShadow: '0 0 15px rgba(255,200,100,0.6)',
      duration: 0.2,
      yoyo: true,
      repeat: 5,
      ease: 'steps(1)',
    });

    // Payline arrows flash
    gsap.to('.slot-payline-left, .slot-payline-right', {
      color: 'rgba(255,200,100,0.9)',
      textShadow: '0 0 10px rgba(255,200,100,0.6)',
      duration: 0.15,
      yoyo: true,
      repeat: 5,
      ease: 'steps(1)',
    });

    // Wait for jackpot celebration
    await new Promise((r) => setTimeout(r, 1600));

    // Signal other components that jackpot has landed
    window.dispatchEvent(new CustomEvent('jackpot'));

    // === Reveal all hero elements ===
    const revealTl = gsap.timeline({ defaults: { ease: 'power3.out' } });
    revealTl
      .to('.hero-line', { opacity: 1, y: 0, duration: 0.6 }, 0)
      .to('.hero-rule', { opacity: 1, scaleX: 1, duration: 0.6 }, 0.4)
      .to('.hero-suit', { opacity: 1, duration: 1.2 }, 0.2)
      .to('.hero-deco-card', { opacity: 1, duration: 1, stagger: 0.04, ease: 'power2.out' }, 0.2)
      .to('.hero-chip', { opacity: 1, y: 0, duration: 1, stagger: 0.06, ease: 'power2.out' }, 0.3)
      .to('.hero-cta', { opacity: 1, y: 0, duration: 0.6 }, 0.6);

    // === Transition to countdown ===
    // Fade out jackpot text, swap, fade in as "TIME REMAINING"
    await new Promise<void>((res) => {
      gsap.to(marqueeText, {
        opacity: 0,
        y: -4,
        duration: 0.3,
        ease: 'power2.in',
        onComplete: () => {
          marqueeText.textContent = 'TIME REMAINING';
          gsap.set(marqueeText, {
            color: 'rgba(196,30,58,0.6)',
            textShadow: '0 0 10px rgba(196,30,58,0.2)',
            y: 4,
          });
          gsap.to(marqueeText, {
            opacity: 1,
            y: 0,
            duration: 0.4,
            ease: 'power2.out',
            onComplete: res,
          });
        },
      });
    });

    // Reset payline arrows
    gsap.to('.slot-payline-left, .slot-payline-right', {
      color: 'rgba(196,30,58,0.5)',
      textShadow: '0 0 6px rgba(196,30,58,0.3)',
      duration: 0.3,
    });

    // Reset cabinet glow
    gsap.to(cabinet, {
      boxShadow:
        '0 12px 50px rgba(0,0,0,0.8), 0 0 100px rgba(196,30,58,0.05), inset 0 1px 0 rgba(255,255,255,0.06), inset 0 -1px 0 rgba(0,0,0,0.3)',
      duration: 0.5,
    });

    // Swap symbols to countdown numbers — smooth scroll transition
    const real = getCountdownVals();
    for (let i = 0; i < keys.length; i++) {
      const key = keys[i];
      const el = reels[key];
      const label = reelLabels[key] as HTMLElement;

      el.style.fontSize = '';

      // Quick scramble with smooth vertical scrolling
      for (let s = 0; s < 3; s++) {
        await new Promise<void>((res) => {
          gsap.to(el, {
            y: yUp,
            duration: 0.08,
            ease: 'none',
            onComplete: () => {
              el.textContent = String(Math.floor(Math.random() * 100)).padStart(2, '0');
              gsap.set(el, { y: yDown });
              gsap.to(el, { y: 0, duration: 0.08, ease: 'none', onComplete: res });
            },
          });
        });
      }

      // Final land on real value with bounce
      await new Promise<void>((res) => {
        gsap.to(el, {
          y: yUp,
          duration: 0.12,
          ease: 'power1.in',
          onComplete: () => {
            el.textContent = real[key];
            prev[key] = real[key];
            gsap.set(el, { y: yDown });
            gsap.to(el, {
              y: 0,
              duration: 0.3,
              ease: 'back.out(1.2)',
              onComplete: () => {
                gsap.set(el, { clearProps: 'transform' });
                gsap.to(label, { opacity: 1, duration: 0.3 });
                res();
              },
            });
          },
        });
      });

      if (i < keys.length - 1) {
        await new Promise((r) => setTimeout(r, 100));
      }
    }

    // Start live countdown
    setInterval(updateCountdown, 1000);
  }, 800);
</script>
