<style>
  /* ======================================================
     POKER CHIPS — classic dice-stripe style
     ====================================================== */
  .hero-chip {
    opacity: 0;
  }

  .poker-chip {
    --chip-size: 60px;
    --chip-color: #b22234;
    --chip-color-dark: #8a1a28;
    --chip-stripe: #e8dcc8;
    width: var(--chip-size);
    height: var(--chip-size);
    border-radius: 50%;
    position: relative;
    filter: drop-shadow(0 6px 12px rgba(0, 0, 0, 0.7));
  }
  @media (min-width: 768px) {
    .poker-chip {
      --chip-size: 80px;
    }
  }

  /* Outer chip body — solid colored circle */
  .chip-base {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: var(--chip-color);
    overflow: hidden;
    border: 2px solid var(--chip-color-dark);
    box-shadow:
      inset 0 2px 3px rgba(255, 255, 255, 0.12),
      inset 0 -2px 3px rgba(0, 0, 0, 0.25);
  }

  /* White edge stripes — 4 divs, each a rectangle, rotated at 45deg intervals */
  .chip-stripe {
    position: absolute;
    width: 22%;
    height: 100%;
    left: 50%;
    top: 0;
    transform-origin: center center;
    margin-left: -11%;
  }
  .chip-stripe::before,
  .chip-stripe::after {
    content: '';
    position: absolute;
    left: 0;
    width: 100%;
    height: 18%;
    background: var(--chip-stripe);
    border-left: 1px solid rgba(0, 0, 0, 0.06);
    border-right: 1px solid rgba(0, 0, 0, 0.06);
  }
  .chip-stripe::before {
    top: 0;
  }
  .chip-stripe::after {
    bottom: 0;
  }

  .chip-stripe--0 {
    transform: rotate(0deg);
  }
  .chip-stripe--1 {
    transform: rotate(45deg);
  }
  .chip-stripe--2 {
    transform: rotate(90deg);
  }
  .chip-stripe--3 {
    transform: rotate(135deg);
  }

  /* Inner colored infield — sits on top of stripes, reveals them only at edge */
  .chip-infield {
    position: absolute;
    inset: 16%;
    border-radius: 50%;
    background: var(--chip-color);
    box-shadow:
      0 0 0 2px var(--chip-color-dark),
      inset 0 1px 2px rgba(255, 255, 255, 0.08),
      inset 0 -1px 2px rgba(0, 0, 0, 0.15);
    z-index: 1;
  }

  /* Inner ring groove — the recessed circle inside */
  .chip-inner-ring {
    position: absolute;
    inset: 8%;
    border-radius: 50%;
    border: 2px solid var(--chip-color-dark);
    box-shadow:
      inset 0 1px 1px rgba(0, 0, 0, 0.15),
      0 1px 1px rgba(255, 255, 255, 0.06);
  }

  /* ── Color variants ── */

  .poker-chip--red {
    --chip-color: #b22234;
    --chip-color-dark: #8a1a28;
    --chip-stripe: #e8dcc8;
  }

  .poker-chip--gold {
    --chip-color: #b8942a;
    --chip-color-dark: #8a6e1e;
    --chip-stripe: #f0e8d8;
  }

  .poker-chip--dark {
    --chip-color: #2a1218;
    --chip-color-dark: #1a0a0e;
    --chip-stripe: #584048;
  }

  /* Stagger rotations for natural scatter */
  .hero-chip--1 .poker-chip {
    transform: rotate(-15deg);
  }
  .hero-chip--2 .poker-chip {
    transform: rotate(8deg);
  }
  .hero-chip--3 .poker-chip {
    transform: rotate(-5deg);
  }
  .hero-chip--4 .poker-chip {
    transform: rotate(22deg);
