  /* ── Mobile performance: reduce decorative elements ── */
  @media (max-width: 767px) {
    .hero-chip--3,
    .hero-chip--6,
    .hero-chip--7,
    .hero-chip--8,
    .hero-chip--9,
    .hero-chip--10,
