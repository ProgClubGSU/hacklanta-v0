  /* ======================================================
     SLOT MACHINE — physical cabinet design
     ====================================================== */
  .slot-cabinet {
    max-width: 520px;
    width: 100%;
    margin: 0 auto;
    border-radius: 14px;
    background: linear-gradient(180deg, #2a1218 0%, #1a0a0e 40%, #120609 100%);
    border: 2px solid rgba(196, 30, 58, 0.2);
    box-shadow:
      0 12px 50px rgba(0, 0, 0, 0.8),
      0 0 100px rgba(196, 30, 58, 0.05),
      inset 0 1px 0 rgba(255, 255, 255, 0.06),
      inset 0 -1px 0 rgba(0, 0, 0, 0.3);
    position: relative;
    overflow: hidden;
  }

  /* ── Marquee (top) ── */
  .slot-marquee {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 6px 16px;
    background: linear-gradient(180deg, #3a1520 0%, #2a1018 100%);
    border-bottom: 2px solid rgba(196, 30, 58, 0.15);
    position: relative;
  }
  .slot-marquee::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      90deg,
      rgba(196, 30, 58, 0.08),
      rgba(196, 30, 58, 0.02) 30%,
      rgba(196, 30, 58, 0.02) 70%,
      rgba(196, 30, 58, 0.08)
    );
  }

  .marquee-bulb {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: radial-gradient(
      circle at 40% 35%,
      rgba(255, 200, 100, 0.9),
      rgba(196, 30, 58, 0.6)
    );
    box-shadow: 0 0 6px rgba(255, 200, 100, 0.4);
    animation: bulb-blink 2s ease-in-out infinite;
  }
  .marquee-bulb:nth-child(2) {
    animation-delay: 0.3s;
  }
  .marquee-bulb:nth-child(3) {
    animation-delay: 0.6s;
  }
  .marquee-bulb:nth-child(5) {
    animation-delay: 0.9s;
  }
  .marquee-bulb:nth-child(6) {
    animation-delay: 1.2s;
  }
  .marquee-bulb:nth-child(7) {
    animation-delay: 1.5s;
  }

  @keyframes bulb-blink {
    0%,
    100% {
      opacity: 0.4;
      box-shadow: 0 0 4px rgba(255, 200, 100, 0.2);
    }
    50% {
      opacity: 1;
      box-shadow: 0 0 10px rgba(255, 200, 100, 0.6);
    }
  }

  .marquee-text {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.5em;
    color: rgba(196, 30, 58, 0.6);
    text-transform: uppercase;
    text-shadow: 0 0 10px rgba(196, 30, 58, 0.2);
    position: relative;
  }

  /* ── Info strip ── */
  .slot-info {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 10px;
    padding: 6px 16px;
    background: rgba(20, 9, 13, 0.6);
  }
  .slot-info-cell {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.2em;
    color: var(--color-gray);
    text-transform: uppercase;
  }
  .slot-info-dot {
    color: rgba(196, 30, 58, 0.3);
    display: flex;
    align-items: center;
  }
  @media (min-width: 768px) {
    .slot-info-cell {
      font-size: 12px;
    }
    .slot-info {
      gap: 16px;
    }
  }

  /* ── Reel body ── */
  .slot-body {
    position: relative;
    padding: 8px 20px 6px;
    background: linear-gradient(180deg, rgba(15, 7, 10, 0.9) 0%, rgba(10, 4, 6, 0.95) 100%);
    border-top: 1px solid rgba(196, 30, 58, 0.08);
    border-bottom: 1px solid rgba(196, 30, 58, 0.08);
  }
  @media (min-width: 768px) {
    .slot-body {
      padding: 10px 28px 8px;
    }
  }

  /* Payline arrows */
  .slot-payline-left,
  .slot-payline-right {
    position: absolute;
    top: 50%;
    transform: translateY(-60%);
    font-size: 8px;
    color: rgba(196, 30, 58, 0.5);
    text-shadow: 0 0 6px rgba(196, 30, 58, 0.3);
    z-index: 2;
  }
  .slot-payline-left {
    left: 8px;
  }
  .slot-payline-right {
    right: 8px;
  }
  @media (min-width: 768px) {
    .slot-payline-left {
      left: 12px;
    }
    .slot-payline-right {
      right: 12px;
    }
  }

  /* Reels container */
  .slot-reels {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    gap: 6px;
  }
  @media (min-width: 768px) {
    .slot-reels {
      gap: 10px;
    }
  }

  .slot-reel-group {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }

  /* Each reel window — sunken, deep, visible mechanics */
  .slot-reel-window {
    position: relative;
    width: 56px;
    height: 56px;
    border-radius: 6px;
    background: #0a0305;
    border: 2px solid rgba(196, 30, 58, 0.18);
    overflow: hidden;
    box-shadow:
      inset 0 4px 16px rgba(0, 0, 0, 1),
      inset 0 -4px 16px rgba(0, 0, 0, 1),
      inset 2px 0 8px rgba(0, 0, 0, 0.6),
      inset -2px 0 8px rgba(0, 0, 0, 0.6),
      0 2px 0 rgba(196, 30, 58, 0.08),
      0 -2px 0 rgba(196, 30, 58, 0.05);
  }
  @media (min-width: 768px) {
    .slot-reel-window {
      width: 76px;
      height: 72px;
      border-radius: 8px;
    }
  }

  /* Glass shine overlay */
  .reel-shine {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 3;
    border-radius: 5px;
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.06) 0%,
      transparent 30%,
      transparent 70%,
      rgba(0, 0, 0, 0.3) 100%
    );
  }

  /* Reel strip (the scrolling digit) */
  .reel-strip {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1;
  }

  .reel-digit {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 38px;
    letter-spacing: 0.06em;
    color: #c41e3a;
    text-shadow:
      0 0 20px rgba(196, 30, 58, 0.4),
      0 0 40px rgba(196, 30, 58, 0.15);
    line-height: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
  }
  .reel-strip--sec .reel-digit {
    color: rgba(196, 30, 58, 0.65);
    text-shadow: 0 0 15px rgba(196, 30, 58, 0.2);
  }
  @media (min-width: 768px) {
    .reel-digit {
      font-size: 52px;
    }
  }

  /* Tick animation — uses px instead of % to avoid Safari SVG rendering bugs */
  .reel-digit.tick {
    animation: reel-tick 0.35s cubic-bezier(0.22, 1, 0.36, 1);
  }
  @keyframes reel-tick {
    0% {
      transform: translateY(-62px);
      opacity: 0;
      filter: blur(3px);
    }
    60% {
      filter: blur(0);
    }
    75% {
      transform: translateY(4px);
      opacity: 0.85;
    }
    100% {
      transform: translateY(0);
      opacity: 1;
      filter: blur(0);
    }
  }

  /* Colon separator */
  .reel-sep {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 32px;
    color: rgba(196, 30, 58, 0.3);
    padding-top: 12px;
    line-height: 1;
    text-shadow: 0 0 8px rgba(196, 30, 58, 0.12);
    animation: sep-pulse 2s ease-in-out infinite;
  }
  @media (min-width: 768px) {
    .reel-sep {
      font-size: 44px;
      padding-top: 14px;
    }
  }
  @keyframes sep-pulse {
    0%,
    100% {
      opacity: 0.3;
    }
    50% {
      opacity: 1;
    }
  }

  .reel-label {
    font-family: var(--font-mono);
    font-size: 8px;
    letter-spacing: 0.4em;
    color: var(--color-gray-darker);
  }
  @media (min-width: 768px) {
    .reel-label {
      font-size: 9px;
    }
  }

  /* ── Lever ── */
  .slot-lever {
    position: absolute;
    right: -16px;
    top: 50%;
    transform: translateY(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .lever-shaft {
    width: 6px;
    height: 40px;
    background: linear-gradient(90deg, #4a2a30, #6a3a42, #4a2a30);
    border-radius: 3px;
    border: 1px solid rgba(196, 30, 58, 0.15);
    box-shadow: 1px 0 4px rgba(0, 0, 0, 0.4);
  }
  .lever-knob {
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: radial-gradient(circle at 40% 35%, #c41e3a, #7a1024);
    border: 2px solid rgba(196, 30, 58, 0.3);
    box-shadow:
      0 2px 6px rgba(0, 0, 0, 0.5),
      inset 0 1px 2px rgba(255, 255, 255, 0.15);
    margin-top: -2px;
  }
  @media (max-width: 767px) {
    .slot-lever {
      display: none;
    }
  }

  /* ── Bottom tray ── */
  .slot-tray {
    padding: 5px 16px 6px;
    background: linear-gradient(180deg, #1a0a0e 0%, #120608 100%);
  }
  .tray-inner {
    background: rgba(0, 0, 0, 0.3);
    border-radius: 0 0 8px 8px;
    padding: 6px;
    border: 1px solid rgba(196, 30, 58, 0.06);
    border-top: none;
    text-align: center;
  }
  .tray-text {
