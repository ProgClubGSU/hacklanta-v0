---
// Hero — slot machine countdown + dealt track cards overflowing into next section

const tracks = [
  {
    name: 'Web Dev',
    suit: '&#9824;',
    suitChar: '♠',
    rank: 'A',
    label: 'ACE OF SPADES',
    desc: 'Full-stack web applications, from sleek frontends to powerful APIs.',
    accentRgb: '196,30,58',
    suitColor: '#C41E3A',
  },
  {
    name: 'AI / ML',
    suit: '&#9829;',
    suitChar: '♥',
    rank: 'K',
    label: 'KING OF HEARTS',
    desc: 'Machine learning models, AI-powered tools, and intelligent automation.',
    accentRgb: '230,57,70',
    suitColor: '#E63946',
  },
  {
    name: 'Cybersecurity',
    suit: '&#9827;',
    suitChar: '♣',
    rank: 'Q',
    label: 'QUEEN OF CLUBS',
    desc: 'Security tools, CTF-style challenges, and defensive solutions.',
    accentRgb: '196,30,58',
    suitColor: '#C41E3A',
  },
  {
    name: 'Open Innovation',
    suit: '&#9830;',
    suitChar: '♦',
    rank: 'J',
    label: 'JACK OF DIAMONDS',
    desc: 'Anything goes. Hardware hacks, creative tools, wild ideas — surprise us.',
    accentRgb: '201,168,76',
    suitColor: '#C9A84C',
  },
];
---

<section
  id="hero"
  class="relative flex min-h-screen flex-col items-center justify-center bg-black px-4 text-center"
  style="overflow: visible;"
>
  <!-- Deep red ambient glow -->
  <div
    class="pointer-events-none absolute left-1/2 top-[40%] h-[900px] w-[900px] -translate-x-1/2 -translate-y-1/2 rounded-full"
    style="background: radial-gradient(circle, rgba(196,30,58,0.12) 0%, rgba(140,20,40,0.05) 35%, transparent 60%);"
  ></div>
  <div
    class="pointer-events-none absolute left-[60%] top-[30%] h-[400px] w-[400px] rounded-full opacity-[0.04] blur-[100px]"
    style="background: radial-gradient(circle, rgba(201,168,76,0.6) 0%, transparent 70%);"
  ></div>
  <!-- Vignette -->
  <div
    class="pointer-events-none absolute inset-0"
    style="background: radial-gradient(ellipse 65% 60% at 50% 45%, transparent 15%, rgba(26,10,14,0.5) 60%, rgba(10,4,6,0.95) 100%);"
  ></div>

  <!-- Ghosted suit symbols -->
  <div class="pointer-events-none absolute inset-0 select-none overflow-hidden" aria-hidden="true">
    <span class="hero-suit absolute left-[3%] top-[18%] font-display text-[10rem] text-white/[0.015] md:text-[14rem]">&#9824;</span>
    <span class="hero-suit absolute right-[5%] top-[35%] font-display text-[9rem] text-red/[0.025] md:text-[12rem]">&#9829;</span>
    <span class="hero-suit absolute left-[20%] bottom-[25%] font-display text-[8rem] text-gold/[0.03] md:text-[11rem]">&#9830;</span>
    <span class="hero-suit absolute right-[15%] bottom-[35%] font-display text-[7rem] text-white/[0.012] md:text-[10rem]">&#9827;</span>
  </div>

  <!-- Main content -->
  <div class="relative z-10 max-w-4xl">
    <!-- Presented by -->
    <p class="hero-line font-mono text-[12px] tracking-[0.4em] text-white opacity-0 uppercase">
    presented by <span class="text-red/100"> <a href="https://progsu.com/" target="_blank" rel="noopener noreferrer" class="text-red/90 transition-colors hover:text-white">progsu</a></span>
    </p>

    <!-- Logo — tighter spacing -->
    <h1 class="hero-title mt-3 p-12 opacity-0">
      <span class="relative inline-block">
        <img
          src="/logo_trimmed.png"
          alt="Hacklanta"
          class="mx-auto h-auto select-none pointer-events-none"
          style="width: clamp(260px, 50vw, 560px);"
          draggable="false"
          width="620"
          height="140"
        />
        <span class="absolute inset-0 z-10"></span>
      </span>
    </h1>

    <!-- Red rule — tight -->
    <div class="hero-rule mx-auto mt-2 h-px w-48 opacity-0" style="background: linear-gradient(90deg, transparent, #C41E3A, transparent);"></div>

    <!-- ========== SLOT MACHINE ========== -->
    <div class="hero-slot mt-5 opacity-0">
      <div class="slot-cabinet">
        <!-- Top marquee -->
        <div class="slot-marquee">
          <div class="marquee-bulb"></div>
          <div class="marquee-bulb"></div>
          <div class="marquee-bulb"></div>
          <span class="marquee-text">TIME REMAINING</span>
          <div class="marquee-bulb"></div>
          <div class="marquee-bulb"></div>
          <div class="marquee-bulb"></div>
        </div>

        <!-- Event info strip -->
        <div class="slot-info">
          <span class="slot-info-cell">12-hours</span>
          <span class="slot-info-dot">&#9670;</span>
          <span class="slot-info-cell">march 28, 2026</span>
          <span class="slot-info-dot">&#9670;</span>
          <span class="slot-info-cell">atlanta, ga</span>
        </div>

        <!-- Reel housing -->
        <div class="slot-body">
          <!-- Payline arrows -->
          <div class="slot-payline-left">&#9654;</div>
          <div class="slot-payline-right">&#9664;</div>

          <!-- Reels -->
          <div class="slot-reels">
            <div class="slot-reel-group">
              <div class="slot-reel-window">
                <div class="reel-strip" data-unit="days">
                  <span class="reel-digit">00</span>
                </div>
                <div class="reel-shine"></div>
              </div>
              <span class="reel-label">DAYS</span>
            </div>

            <span class="reel-sep">:</span>

            <div class="slot-reel-group">
              <div class="slot-reel-window">
                <div class="reel-strip" data-unit="hours">
                  <span class="reel-digit">00</span>
                </div>
                <div class="reel-shine"></div>
              </div>
              <span class="reel-label">HRS</span>
            </div>

            <span class="reel-sep">:</span>

            <div class="slot-reel-group">
              <div class="slot-reel-window">
                <div class="reel-strip" data-unit="mins">
                  <span class="reel-digit">00</span>
                </div>
                <div class="reel-shine"></div>
              </div>
              <span class="reel-label">MIN</span>
            </div>

            <span class="reel-sep">:</span>

            <div class="slot-reel-group">
              <div class="slot-reel-window">
                <div class="reel-strip reel-strip--sec" data-unit="secs">
                  <span class="reel-digit">00</span>
                </div>
                <div class="reel-shine"></div>
              </div>
              <span class="reel-label">SEC</span>
            </div>
          </div>

          <!-- Lever -->
          <div class="slot-lever" aria-hidden="true">
            <div class="lever-shaft"></div>
            <div class="lever-knob"></div>
          </div>
        </div>

        <!-- Bottom tray -->
        <div class="slot-tray">
          <div class="tray-inner">
            <span class="tray-text">&#9824; &#9829; &#9827; &#9830;</span>
          </div>
        </div>
      </div>
    </div>

    <!-- CTA -->
    <div class="hero-cta mt-6 opacity-0">
      <a
        href="/apply"
        class="group relative inline-flex items-center gap-3 overflow-hidden bg-red px-10 py-4 font-body text-sm font-bold tracking-[0.15em] text-white-pure transition-all duration-300 hover:bg-red-bright hover:shadow-[0_0_50px_rgba(196,30,58,0.35)] hover:scale-[1.03]"
      >
        <span class="relative z-10 uppercase">Apply</span>
        <span class="absolute inset-0 -translate-x-full bg-linear-to-r from-transparent via-white/10 to-transparent transition-transform duration-700 ease-out group-hover:translate-x-full"></span>
      </a>
    </div>
  </div>

  <!-- ===== TRACK CARDS — overflow bottom ===== -->
  <div id="track-cards" class="absolute bottom-0 left-0 right-0 z-20 flex items-end justify-center gap-4 px-4 md:gap-6" style="transform: translateY(55%); perspective: 1200px;">
    {tracks.map((track, i) => (
      <div
        class="track-card-wrapper"
        data-index={i}
      >
        <div class="track-card-flipper" data-flip="false">
          <!-- BACK FACE — Bicycle rider back -->
          <div class="card-back">
            <div class="card-back-inner">
              <div class="card-back-pattern"></div>
              <div class="card-back-border-1"></div>
              <div class="card-back-border-2"></div>
              <div class="card-back-center">
                <div class="card-back-diamond">
                  <span class="card-back-diamond-suit">&#9824;</span>
                </div>
              </div>
              <span class="card-back-corner card-back-corner--tl">&#9830;</span>
              <span class="card-back-corner card-back-corner--tr">&#9827;</span>
              <span class="card-back-corner card-back-corner--bl">&#9829;</span>
              <span class="card-back-corner card-back-corner--br">&#9824;</span>
            </div>
          </div>

          <!-- FRONT FACE — Track info on cream card -->
          <div class="card-front" style={`--card-accent: ${track.suitColor}; --card-accent-rgb: ${track.accentRgb};`}>
            <div class="card-front-inner">
              <div class="card-front-tl">
                <span class="card-rank" set:html={track.rank}></span>
                <span class="card-suit-sm" set:html={track.suit}></span>
              </div>
              <div class="card-front-br">
                <span class="card-rank" set:html={track.rank}></span>
                <span class="card-suit-sm" set:html={track.suit}></span>
              </div>
              <div class="card-center">
                <span class="card-suit-lg" set:html={track.suit}></span>
                <span class="card-track-name">{track.name.toUpperCase()}</span>
                <div class="card-divider"></div>
                <span class="card-track-desc">{track.desc}</span>
              </div>
              <span class="card-label">{track.label}</span>
              <div class="card-inner-border"></div>
            </div>
          </div>
        </div>
      </div>
    ))}
  </div>

  <!-- Scroll indicator -->
  <!-- <div class="hero-scroll absolute bottom-8 left-1/2 -translate-x-1/2 opacity-0" style="z-index: 30;"> -->
  <!--   <div class="flex flex-col items-center gap-3"> -->
  <!--     <span class="font-mono text-[7px] tracking-[0.5em] text-gray-500 uppercase">Scroll</span> -->
  <!--     <div class="h-8 w-px bg-gradient-to-b from-red/30 to-transparent"></div> -->
  <!--   </div> -->
  <!-- </div> -->
</section>

<style>
  /* ======================================================
     SLOT MACHINE — physical cabinet design
     ====================================================== */
  .slot-cabinet {
    max-width: 520px;
    width: 100%;
    margin: 0 auto;
    border-radius: 18px;
    background: linear-gradient(180deg, #2a1218 0%, #1a0a0e 40%, #120609 100%);
    border: 2px solid rgba(196, 30, 58, 0.2);
    box-shadow:
      0 12px 50px rgba(0, 0, 0, 0.8),
      0 0 100px rgba(196, 30, 58, 0.05),
      inset 0 1px 0 rgba(255, 255, 255, 0.06),
      inset 0 -1px 0 rgba(0, 0, 0, 0.3);
    position: relative;
    overflow: hidden;
  }

  /* ── Marquee (top) ── */
  .slot-marquee {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 10px 16px;
    background: linear-gradient(180deg, #3a1520 0%, #2a1018 100%);
    border-bottom: 2px solid rgba(196, 30, 58, 0.15);
    position: relative;
  }
  .slot-marquee::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg,
      rgba(196, 30, 58, 0.08),
      rgba(196, 30, 58, 0.02) 30%,
      rgba(196, 30, 58, 0.02) 70%,
      rgba(196, 30, 58, 0.08)
    );
  }

  .marquee-bulb {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: radial-gradient(circle at 40% 35%, rgba(255, 200, 100, 0.9), rgba(196, 30, 58, 0.6));
    box-shadow: 0 0 6px rgba(255, 200, 100, 0.4);
    animation: bulb-blink 2s ease-in-out infinite;
  }
  .marquee-bulb:nth-child(2) { animation-delay: 0.3s; }
  .marquee-bulb:nth-child(3) { animation-delay: 0.6s; }
  .marquee-bulb:nth-child(5) { animation-delay: 0.9s; }
  .marquee-bulb:nth-child(6) { animation-delay: 1.2s; }
  .marquee-bulb:nth-child(7) { animation-delay: 1.5s; }

  @keyframes bulb-blink {
    0%, 100% { opacity: 0.4; box-shadow: 0 0 4px rgba(255, 200, 100, 0.2); }
    50% { opacity: 1; box-shadow: 0 0 10px rgba(255, 200, 100, 0.6); }
  }

  .marquee-text {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.5em;
    color: rgba(196, 30, 58, 0.6);
    text-transform: uppercase;
    text-shadow: 0 0 10px rgba(196, 30, 58, 0.2);
    position: relative;
  }

  /* ── Info strip ── */
  .slot-info {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 10px;
    padding: 10px 16px;
    background: rgba(20, 9, 13, 0.6);
  }
  .slot-info-cell {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.2em;
    color: var(--color-gray);
    text-transform: uppercase;
  }
  .slot-info-dot {
    font-size: 6px;
    color: rgba(196, 30, 58, 0.3);
  }
  @media (min-width: 768px) {
    .slot-info-cell { font-size: 12px; }
    .slot-info { gap: 16px; }
  }

  /* ── Reel body ── */
  .slot-body {
    position: relative;
    padding: 16px 20px 14px;
    background: linear-gradient(180deg, rgba(15, 7, 10, 0.9) 0%, rgba(10, 4, 6, 0.95) 100%);
    border-top: 1px solid rgba(196, 30, 58, 0.08);
    border-bottom: 1px solid rgba(196, 30, 58, 0.08);
  }
  @media (min-width: 768px) {
    .slot-body { padding: 20px 28px 16px; }
  }

  /* Payline arrows */
  .slot-payline-left, .slot-payline-right {
    position: absolute;
    top: 50%;
    transform: translateY(-60%);
    font-size: 8px;
    color: rgba(196, 30, 58, 0.5);
    text-shadow: 0 0 6px rgba(196, 30, 58, 0.3);
    z-index: 2;
  }
  .slot-payline-left { left: 8px; }
  .slot-payline-right { right: 8px; }
  @media (min-width: 768px) {
    .slot-payline-left { left: 12px; }
    .slot-payline-right { right: 12px; }
  }

  /* Reels container */
  .slot-reels {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    gap: 6px;
  }
  @media (min-width: 768px) {
    .slot-reels { gap: 10px; }
  }

  .slot-reel-group {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }

  /* Each reel window — sunken, deep, visible mechanics */
  .slot-reel-window {
    position: relative;
    width: 56px;
    height: 68px;
    border-radius: 6px;
    background: #0a0305;
    border: 2px solid rgba(196, 30, 58, 0.18);
    overflow: hidden;
    box-shadow:
      inset 0 4px 16px rgba(0, 0, 0, 1),
      inset 0 -4px 16px rgba(0, 0, 0, 1),
      inset 2px 0 8px rgba(0, 0, 0, 0.6),
      inset -2px 0 8px rgba(0, 0, 0, 0.6),
      0 2px 0 rgba(196, 30, 58, 0.08),
      0 -2px 0 rgba(196, 30, 58, 0.05);
  }
  @media (min-width: 768px) {
    .slot-reel-window { width: 76px; height: 88px; border-radius: 8px; }
  }

  /* Glass shine overlay */
  .reel-shine {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 3;
    border-radius: 5px;
    background:
      linear-gradient(180deg,
        rgba(255, 255, 255, 0.06) 0%,
        transparent 30%,
        transparent 70%,
        rgba(0, 0, 0, 0.3) 100%
      );
  }

  /* Reel strip (the scrolling digit) */
  .reel-strip {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1;
  }

  .reel-digit {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 38px;
    letter-spacing: 0.06em;
    color: #C41E3A;
    text-shadow:
      0 0 20px rgba(196, 30, 58, 0.4),
      0 0 40px rgba(196, 30, 58, 0.15);
    line-height: 1;
  }
  .reel-strip--sec .reel-digit {
    color: rgba(196, 30, 58, 0.65);
    text-shadow: 0 0 15px rgba(196, 30, 58, 0.2);
  }
  @media (min-width: 768px) {
    .reel-digit { font-size: 52px; }
  }

  /* Tick animation */
  .reel-digit.tick {
    animation: reel-tick 0.35s cubic-bezier(0.22, 1, 0.36, 1);
  }
  @keyframes reel-tick {
    0% { transform: translateY(-110%); opacity: 0; filter: blur(3px); }
    60% { filter: blur(0); }
    75% { transform: translateY(4px); opacity: 0.85; }
    100% { transform: translateY(0); opacity: 1; filter: blur(0); }
  }

  /* Colon separator */
  .reel-sep {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 32px;
    color: rgba(196, 30, 58, 0.3);
    padding-top: 12px;
    line-height: 1;
    text-shadow: 0 0 8px rgba(196, 30, 58, 0.12);
    animation: sep-pulse 2s ease-in-out infinite;
  }
  @media (min-width: 768px) {
    .reel-sep { font-size: 44px; padding-top: 14px; }
  }
  @keyframes sep-pulse {
    0%, 100% { opacity: 0.3; }
    50% { opacity: 1; }
  }

  .reel-label {
    font-family: var(--font-mono);
    font-size: 8px;
    letter-spacing: 0.4em;
    color: var(--color-gray-darker);
  }
  @media (min-width: 768px) {
    .reel-label { font-size: 9px; }
  }

  /* ── Lever ── */
  .slot-lever {
    position: absolute;
    right: -16px;
    top: 50%;
    transform: translateY(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .lever-shaft {
    width: 6px;
    height: 40px;
    background: linear-gradient(90deg, #4a2a30, #6a3a42, #4a2a30);
    border-radius: 3px;
    border: 1px solid rgba(196, 30, 58, 0.15);
    box-shadow: 1px 0 4px rgba(0,0,0,0.4);
  }
  .lever-knob {
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: radial-gradient(circle at 40% 35%, #C41E3A, #7A1024);
    border: 2px solid rgba(196, 30, 58, 0.3);
    box-shadow: 0 2px 6px rgba(0,0,0,0.5), inset 0 1px 2px rgba(255,255,255,0.15);
    margin-top: -2px;
  }
  @media (max-width: 767px) {
    .slot-lever { display: none; }
  }

  /* ── Bottom tray ── */
  .slot-tray {
    padding: 8px 16px 10px;
    background: linear-gradient(180deg, #1a0a0e 0%, #120608 100%);
  }
  .tray-inner {
    background: rgba(0,0,0,0.3);
    border-radius: 0 0 8px 8px;
    padding: 6px;
    border: 1px solid rgba(196, 30, 58, 0.06);
    border-top: none;
    text-align: center;
  }
  .tray-text {
    font-size: 10px;
    color: rgba(196, 30, 58, 0.3);
    letter-spacing: 0.4em;
  }

  /* ======================================================
     TRACK CARDS — large, Bicycle-style
     ====================================================== */
  .track-card-wrapper {
    width: clamp(150px, 24vw, 260px);
    flex-shrink: 0;
    pointer-events: none;
  }

  .track-card-flipper {
    width: 100%;
    aspect-ratio: 5 / 7;
    position: relative;
    transform-style: preserve-3d;
    transition: transform 0.9s cubic-bezier(0.23, 1, 0.32, 1);
  }
  .track-card-flipper[data-flip="true"] {
    transform: rotateY(180deg);
  }

  /* ── Card Back — Bicycle Rider Back ── */
  .card-back {
    position: absolute;
    inset: 0;
    border-radius: 10px;
    overflow: hidden;
    backface-visibility: hidden;
    box-shadow:
      0 8px 30px rgba(0,0,0,0.6),
      0 2px 8px rgba(0,0,0,0.4);
  }
  .card-back-inner {
    width: 100%;
    height: 100%;
    background: #B22234;
    border: 3px solid #f0e8d8;
    border-radius: 10px;
    position: relative;
    overflow: hidden;
  }
  .card-back-pattern {
    position: absolute;
    inset: 0;
    background:
      repeating-linear-gradient(
        45deg,
        rgba(255,255,255,0.08) 0px,
        rgba(255,255,255,0.08) 1px,
        transparent 1px,
        transparent 8px
      ),
      repeating-linear-gradient(
        -45deg,
        rgba(255,255,255,0.08) 0px,
        rgba(255,255,255,0.08) 1px,
        transparent 1px,
        transparent 8px
      );
  }
  .card-back-border-1 {
    position: absolute;
    inset: 7%;
    border: 2px solid rgba(255,255,255,0.3);
    border-radius: 6px;
  }
  .card-back-border-2 {
    position: absolute;
    inset: 10%;
    border: 1px solid rgba(255,255,255,0.18);
    border-radius: 4px;
  }
  .card-back-center {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }
  .card-back-diamond {
    width: 30px;
    height: 30px;
    transform: rotate(45deg);
    background: rgba(255,255,255,0.12);
    border: 1.5px solid rgba(255,255,255,0.28);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .card-back-diamond-suit {
    transform: rotate(-45deg);
    font-size: 14px;
    color: rgba(255,255,255,0.45);
    line-height: 1;
  }
  .card-back-corner {
    position: absolute;
    font-size: 9px;
    color: rgba(255,255,255,0.2);
    line-height: 1;
  }
  .card-back-corner--tl { top: 12%; left: 14%; }
  .card-back-corner--tr { top: 12%; right: 14%; }
  .card-back-corner--bl { bottom: 12%; left: 14%; }
  .card-back-corner--br { bottom: 12%; right: 14%; }

  /* ── Card Front — cream face ── */
  .card-front {
    position: absolute;
    inset: 0;
    border-radius: 10px;
    overflow: hidden;
    backface-visibility: hidden;
    transform: rotateY(180deg);
    box-shadow:
      0 8px 30px rgba(0,0,0,0.6),
      0 2px 8px rgba(0,0,0,0.4);
  }
  .card-front-inner {
    width: 100%;
    height: 100%;
    background: #F2EDE4;
    border: 2.5px solid #ddd;
    border-radius: 10px;
    position: relative;
    overflow: hidden;
    /* subtle linen */
    background-image:
      repeating-linear-gradient(
        0deg, transparent, transparent 2px, rgba(0,0,0,0.015) 2px, rgba(0,0,0,0.015) 3px
      ),
      repeating-linear-gradient(
        90deg, transparent, transparent 2px, rgba(0,0,0,0.01) 2px, rgba(0,0,0,0.01) 3px
      ),
      linear-gradient(180deg, #F5F0E8, #E8E2D8);
  }

  .card-front-tl {
    position: absolute;
    top: 6%;
    left: 8%;
    display: flex;
    flex-direction: column;
    align-items: center;
    z-index: 2;
  }
  .card-front-br {
    position: absolute;
    bottom: 6%;
    right: 8%;
    display: flex;
    flex-direction: column;
    align-items: center;
    transform: rotate(180deg);
    z-index: 2;
  }
  .card-rank {
    font-family: 'Bebas Neue', serif;
    font-size: clamp(20px, 4vw, 32px);
    font-weight: 700;
    line-height: 1;
    color: var(--card-accent);
  }
  .card-suit-sm {
    font-size: clamp(12px, 2.4vw, 20px);
    line-height: 1;
    color: var(--card-accent);
    opacity: 0.8;
  }

  .card-center {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 20% 8%;
    text-align: center;
    gap: 5px;
  }
  .card-suit-lg {
    font-size: clamp(28px, 6vw, 48px);
    line-height: 1;
    color: var(--card-accent);
    opacity: 0.5;
  }
  .card-track-name {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(13px, 3vw, 22px);
    letter-spacing: 0.12em;
    color: #1a1a1a;
    line-height: 1.1;
  }
  .card-divider {
    width: 50%;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(var(--card-accent-rgb), 0.25), transparent);
    margin: 2px 0;
  }
  .card-track-desc {
    font-family: var(--font-body);
    font-size: clamp(7px, 1.6vw, 12px);
    color: #777;
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .card-label {
    position: absolute;
    bottom: 5%;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--font-mono);
    font-size: clamp(5px, 1.2vw, 9px);
    letter-spacing: 0.18em;
    color: rgba(var(--card-accent-rgb), 0.35);
    white-space: nowrap;
  }
  .card-inner-border {
    position: absolute;
    inset: 7%;
    border: 1px solid rgba(var(--card-accent-rgb), 0.06);
    border-radius: 5px;
    pointer-events: none;
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  // ===== Hero entrance — everything visible on load =====
  const tl = gsap.timeline({ defaults: { ease: 'power3.out' } });

  tl.to('.hero-line', { opacity: 1, y: 0, duration: 0.6 }, 0.3)
    .to('.hero-title', { opacity: 1, y: 0, duration: 1.2, ease: 'power2.out' }, 0.5)
    .to('.hero-rule', { opacity: 1, scaleX: 1, duration: 0.6 }, 1.0)
    .to('.hero-slot', { opacity: 1, y: 0, duration: 0.8 }, 1.2)
    .to('.hero-cta', { opacity: 1, y: 0, duration: 0.6 }, 1.8)
    .to('.hero-scroll', { opacity: 1, duration: 0.6 }, 2.2);

  // ===== Deal cards in after slot machine appears =====
  const cards = gsap.utils.toArray<HTMLElement>('.track-card-wrapper');
  const rotations = [-10, -3, 3, 10];

  // Set initial state
  cards.forEach((card, i) => {
    gsap.set(card, { y: 80, opacity: 0, rotation: rotations[i] * 2 });
  });

  // Animate in
  gsap.to(cards, {
    y: 0,
    opacity: 1,
    rotation: (i: number) => rotations[i],
    duration: 0.8,
    stagger: 0.12,
    ease: 'back.out(1.2)',
    delay: 2.0,
  });

  // ===== Scroll-triggered card flip =====
  const hero = document.getElementById('hero')!;
  const flippers = document.querySelectorAll<HTMLElement>('.track-card-flipper');

  ScrollTrigger.create({
    trigger: hero,
    start: 'bottom 85%',
    onEnter: () => {
      flippers.forEach((flipper, i) => {
        setTimeout(() => {
          flipper.setAttribute('data-flip', 'true');
        }, i * 100);
      });
    },
    onLeaveBack: () => {
      flippers.forEach((flipper) => {
        flipper.setAttribute('data-flip', 'false');
      });
    },
  });

  // ===== Countdown =====
  const EVENT_DATE = new Date('2026-03-28T09:00:00-04:00');

  const reels = {
    days: document.querySelector<HTMLElement>('[data-unit="days"] .reel-digit')!,
    hours: document.querySelector<HTMLElement>('[data-unit="hours"] .reel-digit')!,
    mins: document.querySelector<HTMLElement>('[data-unit="mins"] .reel-digit')!,
    secs: document.querySelector<HTMLElement>('[data-unit="secs"] .reel-digit')!,
  };

  const prev = { days: '', hours: '', mins: '', secs: '' };

  function pad(n: number) {
    return String(n).padStart(2, '0');
  }

  function updateCountdown() {
    const now = new Date();
    const diff = Math.max(0, EVENT_DATE.getTime() - now.getTime());

    const days = pad(Math.floor(diff / (1000 * 60 * 60 * 24)));
    const hours = pad(Math.floor((diff / (1000 * 60 * 60)) % 24));
    const mins = pad(Math.floor((diff / (1000 * 60)) % 60));
    const secs = pad(Math.floor((diff / 1000) % 60));

    const vals = { days, hours, mins, secs } as const;

    for (const [key, val] of Object.entries(vals) as [keyof typeof vals, string][]) {
      const el = reels[key];
      if (val !== prev[key]) {
        el.textContent = val;
        el.classList.remove('tick');
        void el.offsetWidth;
        el.classList.add('tick');
        prev[key] = val;
      }
    }
  }

  // Initial spin effect then start ticking
  setTimeout(() => {
    // Quick spin through random numbers before landing
    const allDigits = Object.values(reels);
    allDigits.forEach((el, i) => {
      let count = 0;
      const max = 6 + i * 3;
      const interval = setInterval(() => {
        el.textContent = String(Math.floor(Math.random() * 100)).padStart(2, '0');
        count++;
        if (count >= max) {
          clearInterval(interval);
          updateCountdown();
        }
      }, 50);
    });

    // Start ticking after spin settles
    setTimeout(() => {
      setInterval(updateCountdown, 1000);
    }, 1200);
  }, 1400);

  // ===== Mouse parallax for suit symbols =====
  const heroSection = document.getElementById('hero')!;
  const heroSuits = document.querySelectorAll<HTMLElement>('.hero-suit');

  const suitAnims = Array.from(heroSuits).map((el) => ({
    x: gsap.quickTo(el, 'x', { duration: 0.8, ease: 'power2.out' }),
    y: gsap.quickTo(el, 'y', { duration: 0.8, ease: 'power2.out' }),
  }));

  heroSection.addEventListener('mousemove', (e) => {
    const rect = heroSection.getBoundingClientRect();
    const nx = (e.clientX - rect.left) / rect.width - 0.5;
    const ny = (e.clientY - rect.top) / rect.height - 0.5;

    suitAnims.forEach((anim, i) => {
      const speed = 12 + i * 6;
      anim.x(nx * speed);
      anim.y(ny * speed * 0.5);
    });
  });

  heroSection.addEventListener('mouseleave', () => {
    suitAnims.forEach((a) => { a.x(0); a.y(0); });
  });
</script>
