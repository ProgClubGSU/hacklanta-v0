---
// [01] About — bento grid, editorial, cinematic
---

<section id="about" class="relative overflow-hidden bg-black px-4 py-28 md:py-40">
  <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-red/30 to-transparent"></div>

  <!-- Ambient glows -->
  <div
    class="pointer-events-none absolute left-[-10%] top-[20%] h-[700px] w-[700px] rounded-full"
    style="background: radial-gradient(circle, rgba(196,30,58,0.07) 0%, rgba(196,30,58,0.015) 40%, transparent 65%);"
  ></div>
  <div
    class="pointer-events-none absolute right-[5%] bottom-[10%] h-[400px] w-[400px] rounded-full opacity-[0.04] blur-[80px]"
    style="background: radial-gradient(circle, rgba(201,168,76,0.6) 0%, transparent 70%);"
  ></div>

  <!-- CSS 3D Floating Poker Chips -->
  <div class="pointer-events-none absolute inset-0 overflow-hidden about-floaters" aria-hidden="true" style="perspective: 1000px;">
    <!-- Chip 1 — top right (red, large) -->
    <div
      class="about-floater absolute right-[5%] top-[8%] hidden md:block"
      style="animation: chip-float 7s ease-in-out infinite;"
    >
      <div class="chip chip--lg" style="--chip-base-transform: rotateY(-20deg) rotateX(55deg) rotateZ(-8deg); transform: var(--chip-base-transform);">
        <div class="chip-face chip-face--front chip-face--lg chip-face--red">
          <div class="chip-ring chip-ring--outer chip-ring--lg chip-ring--red-outer"></div>
          <div class="chip-ring chip-ring--inner chip-ring--lg chip-ring--red-inner"></div>
          <span class="chip-suit chip-suit--lg">&#9824;</span>
        </div>
        <div class="chip-edge chip-edge--lg chip-edge--red" style="transform: translateZ(5px);"></div>
        <div class="chip-edge chip-edge--lg chip-edge--red" style="transform: translateZ(3px);"></div>
        <div class="chip-edge chip-edge--lg chip-edge--red" style="transform: translateZ(1px);"></div>
        <div class="chip-edge chip-edge--lg chip-edge--red" style="transform: translateZ(-1px);"></div>
        <div class="chip-edge chip-edge--lg chip-edge--red" style="transform: translateZ(-3px);"></div>
        <div class="chip-edge chip-edge--lg chip-edge--red" style="transform: translateZ(-5px);"></div>
        <div class="chip-face chip-face--back chip-face--lg chip-face--red-back">
          <div class="chip-ring chip-ring--outer chip-ring--lg chip-ring--red-outer"></div>
          <span class="chip-suit chip-suit--lg chip-suit--back">&#9824;</span>
        </div>
      </div>
    </div>

    <!-- Chip 2 — left (gold) -->
    <div
      class="about-floater absolute left-[4%] top-[45%] hidden lg:block"
      style="animation: chip-float 8.5s ease-in-out infinite 1.2s;"
    >
      <div class="chip chip--md" style="--chip-base-transform: rotateY(18deg) rotateX(50deg) rotateZ(10deg); transform: var(--chip-base-transform);">
        <div class="chip-face chip-face--front chip-face--md chip-face--gold">
          <div class="chip-ring chip-ring--outer chip-ring--md chip-ring--gold-outer"></div>
          <div class="chip-ring chip-ring--inner chip-ring--md chip-ring--gold-inner"></div>
          <span class="chip-suit chip-suit--md chip-suit--gold">&#9830;</span>
        </div>
        <div class="chip-edge chip-edge--md chip-edge--gold" style="transform: translateZ(4px);"></div>
        <div class="chip-edge chip-edge--md chip-edge--gold" style="transform: translateZ(2px);"></div>
        <div class="chip-edge chip-edge--md chip-edge--gold" style="transform: translateZ(0px);"></div>
        <div class="chip-edge chip-edge--md chip-edge--gold" style="transform: translateZ(-2px);"></div>
        <div class="chip-edge chip-edge--md chip-edge--gold" style="transform: translateZ(-4px);"></div>
        <div class="chip-face chip-face--back chip-face--md chip-face--gold-back">
          <div class="chip-ring chip-ring--outer chip-ring--md chip-ring--gold-outer"></div>
          <span class="chip-suit chip-suit--md chip-suit--back chip-suit--gold">&#9830;</span>
        </div>
      </div>
    </div>

    <!-- Chip 3 — bottom right (red, small) -->
    <div
      class="about-floater absolute bottom-[15%] right-[8%] hidden md:block"
      style="animation: chip-float 6.5s ease-in-out infinite 0.8s;"
    >
      <div class="chip chip--sm" style="--chip-base-transform: rotateY(14deg) rotateX(58deg) rotateZ(6deg); transform: var(--chip-base-transform);">
        <div class="chip-face chip-face--front chip-face--sm chip-face--red">
          <div class="chip-ring chip-ring--outer chip-ring--sm chip-ring--red-outer"></div>
          <div class="chip-ring chip-ring--inner chip-ring--sm chip-ring--red-inner"></div>
          <span class="chip-suit chip-suit--sm">&#9829;</span>
        </div>
        <div class="chip-edge chip-edge--sm chip-edge--red" style="transform: translateZ(3px);"></div>
        <div class="chip-edge chip-edge--sm chip-edge--red" style="transform: translateZ(1px);"></div>
        <div class="chip-edge chip-edge--sm chip-edge--red" style="transform: translateZ(-1px);"></div>
        <div class="chip-edge chip-edge--sm chip-edge--red" style="transform: translateZ(-3px);"></div>
        <div class="chip-face chip-face--back chip-face--sm chip-face--red-back">
          <div class="chip-ring chip-ring--outer chip-ring--sm chip-ring--red-outer"></div>
          <span class="chip-suit chip-suit--sm chip-suit--back">&#9829;</span>
        </div>
      </div>
    </div>
  </div>

  <div class="relative z-10 mx-auto max-w-6xl">
    <!-- Section header -->
    <div class="about-header mb-16">
      <div class="flex items-center gap-3 font-mono text-[10px] tracking-[0.3em] text-gray-darker">
        <span class="text-red/60">[01]</span>
        <span class="h-px flex-1 bg-gradient-to-r from-border/80 to-transparent"></span>
        <span>ABOUT</span>
      </div>
      <h2 class="mt-6 font-display text-5xl tracking-wide text-white-pure md:text-7xl">
        WHAT'S THE PLAY
      </h2>
      <div class="mt-4 h-px w-24 bg-gradient-to-r from-red/60 to-transparent"></div>
    </div>

    <!-- ===== BENTO GRID ===== -->
    <div class="about-grid grid gap-3 md:grid-cols-3 md:grid-rows-[auto_auto]">

      <!-- TILE 1: Hero description — spans 2 cols -->
      <div class="group relative overflow-hidden rounded-2xl border border-border/50 bg-gradient-to-br from-black-card via-black-card/80 to-black/60 p-8 md:col-span-2 md:p-10">
        <!-- Decorative oversized suit -->
        <div class="pointer-events-none absolute -right-6 -top-6 text-[220px] leading-none text-red/[0.025] transition-all duration-1000 group-hover:text-red/[0.045] md:text-[280px]" aria-hidden="true">&#9824;</div>

        <!-- Top-left corner accent -->
        <div class="absolute left-0 top-0 h-16 w-px bg-gradient-to-b from-red/40 to-transparent"></div>
        <div class="absolute left-0 top-0 h-px w-16 bg-gradient-to-r from-red/40 to-transparent"></div>

        <div class="relative max-w-xl">
          <p class="font-mono text-[9px] tracking-[0.3em] text-red/50">// THE PITCH</p>
          <p class="mt-5 font-body text-[17px] leading-[1.9] text-gray md:text-lg md:leading-[1.9]">
            Hacklanta is a <span class="font-semibold text-white">12-hour hackathon</span> hosted
            by <span class="text-red">progsu</span> — the Programming Club at Georgia State University.
            Whether you're a seasoned dev or writing your first line of code, this is your table.
          </p>
          <p class="mt-5 font-body text-[15px] leading-[1.9] text-gray-dark">
            Build something wild. Learn something new. Break something on purpose.
            No buy-in required — just pure creative energy
            and the willingness to go all in.
          </p>
        </div>
      </div>

      <!-- TILE 2: Pull quote -->
      <div class="group relative flex items-center overflow-hidden rounded-2xl border border-border/50 bg-gradient-to-br from-black-card to-black/60 p-8 md:row-span-2 md:p-10">
        <!-- Decorative -->
        <div class="absolute right-4 top-4 font-display text-[140px] leading-none text-red/[0.04] md:text-[180px]" aria-hidden="true">&ldquo;</div>

        <!-- Corner accents -->
        <div class="absolute left-0 top-0 h-12 w-px bg-gradient-to-b from-gold/30 to-transparent"></div>
        <div class="absolute left-0 top-0 h-px w-12 bg-gradient-to-r from-gold/30 to-transparent"></div>
        <div class="absolute bottom-0 right-0 h-12 w-px bg-gradient-to-t from-gold/20 to-transparent"></div>
        <div class="absolute bottom-0 right-0 h-px w-12 bg-gradient-to-l from-gold/20 to-transparent"></div>

        <div class="relative">
          <p class="font-display text-[26px] leading-[1.25] tracking-wide text-white/90 md:text-3xl">
            THE HOUSE ALWAYS WINS —
            <span class="text-red">UNLESS YOU'RE THE ONE BUILDING THE HOUSE.</span>
          </p>
          <div class="mt-6 h-px w-12 bg-gradient-to-r from-red/40 to-transparent"></div>
          <p class="mt-4 font-mono text-[8px] tracking-[0.35em] text-gray-darker">HACKLANTA MANIFESTO</p>
        </div>
      </div>

      <!-- TILE 3: Stats row — spans 2 cols -->
      <div class="grid grid-cols-4 gap-3 md:col-span-2">
        <!-- 12 HOURS -->
        <div class="group relative overflow-hidden rounded-2xl border border-border/50 bg-gradient-to-b from-black-card/90 to-black/60 p-5 text-center md:p-6">
          <div class="absolute inset-0 bg-gradient-to-b from-red/[0.03] to-transparent opacity-0 transition-opacity duration-500 group-hover:opacity-100"></div>
          <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-red/20 to-transparent opacity-0 transition-opacity duration-500 group-hover:opacity-100"></div>
          <p class="relative font-display text-4xl text-red sm:text-5xl md:text-6xl">12</p>
          <p class="relative mt-1.5 font-mono text-[7px] tracking-[0.3em] text-gray-dark md:text-[8px]">HOURS</p>
        </div>

        <!-- 4 PER TEAM -->
        <div class="group relative overflow-hidden rounded-2xl border border-border/50 bg-gradient-to-b from-black-card/90 to-black/60 p-5 text-center md:p-6">
          <div class="absolute inset-0 bg-gradient-to-b from-red/[0.03] to-transparent opacity-0 transition-opacity duration-500 group-hover:opacity-100"></div>
          <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-red/20 to-transparent opacity-0 transition-opacity duration-500 group-hover:opacity-100"></div>
          <p class="relative font-display text-4xl text-red sm:text-5xl md:text-6xl">4</p>
          <p class="relative mt-1.5 font-mono text-[7px] tracking-[0.3em] text-gray-dark md:text-[8px]">PER TEAM</p>
        </div>

        <!-- INFINITY -->
        <div class="group relative overflow-hidden rounded-2xl border border-border/50 bg-gradient-to-b from-black-card/90 to-black/60 p-5 text-center md:p-6">
          <div class="absolute inset-0 bg-gradient-to-b from-gold/[0.03] to-transparent opacity-0 transition-opacity duration-500 group-hover:opacity-100"></div>
          <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-gold-dim/20 to-transparent opacity-0 transition-opacity duration-500 group-hover:opacity-100"></div>
          <p class="relative font-display text-4xl text-gold sm:text-5xl md:text-6xl">&#8734;</p>
          <p class="relative mt-1.5 font-mono text-[7px] tracking-[0.3em] text-gray-dark md:text-[8px]">IDEAS</p>
        </div>

        <!-- $0 -->
        <div class="group relative overflow-hidden rounded-2xl border border-border/50 bg-gradient-to-b from-black-card/90 to-black/60 p-5 text-center md:p-6">
          <div class="absolute inset-0 bg-gradient-to-b from-white/[0.015] to-transparent opacity-0 transition-opacity duration-500 group-hover:opacity-100"></div>
          <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-white/10 to-transparent opacity-0 transition-opacity duration-500 group-hover:opacity-100"></div>
          <p class="relative font-display text-4xl text-white-pure sm:text-5xl md:text-6xl">$0</p>
          <p class="relative mt-1.5 font-mono text-[7px] tracking-[0.3em] text-gray-dark md:text-[8px]">TO ENTER</p>
        </div>
      </div>
    </div>

    <!-- ===== WHAT TO EXPECT ===== -->
    <div class="about-expect mt-20">
      <h3 class="mb-10 text-center font-mono text-[9px] tracking-[0.4em] text-gray-darker">WHAT TO EXPECT</h3>
      <div class="grid gap-3 md:grid-cols-3">

        <!-- Workshops -->
        <div class="group relative overflow-hidden rounded-2xl border border-border/40 bg-gradient-to-b from-black-card/60 to-black/40 p-8 transition-all duration-500 hover:border-red/20">
          <div class="absolute inset-0 bg-gradient-to-b from-red/[0.02] to-transparent opacity-0 transition-opacity duration-500 group-hover:opacity-100"></div>
          <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-red/20 to-transparent opacity-0 transition-opacity duration-500 group-hover:opacity-100"></div>
          <!-- Large suit background -->
          <div class="pointer-events-none absolute -bottom-2 -right-2 text-[120px] leading-none text-red/[0.025] transition-all duration-700 group-hover:text-red/[0.05]" aria-hidden="true">&#9824;</div>

          <div class="relative">
            <div class="flex h-10 w-10 items-center justify-center rounded-lg border border-red/15 bg-red/[0.06]">
              <span class="text-lg text-red/70">&#9824;</span>
            </div>
            <h4 class="mt-5 font-display text-xl tracking-wide text-white">WORKSHOPS</h4>
            <p class="mt-3 font-body text-[13px] leading-[1.8] text-gray-dark">
              Hands-on sessions from industry pros. Level up your stack before you build.
            </p>
          </div>
        </div>

        <!-- Mini-Games -->
        <div class="group relative overflow-hidden rounded-2xl border border-border/40 bg-gradient-to-b from-black-card/60 to-black/40 p-8 transition-all duration-500 hover:border-red/20">
          <div class="absolute inset-0 bg-gradient-to-b from-red/[0.02] to-transparent opacity-0 transition-opacity duration-500 group-hover:opacity-100"></div>
          <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-red/20 to-transparent opacity-0 transition-opacity duration-500 group-hover:opacity-100"></div>
          <div class="pointer-events-none absolute -bottom-2 -right-2 text-[120px] leading-none text-red/[0.025] transition-all duration-700 group-hover:text-red/[0.05]" aria-hidden="true">&#9830;</div>

          <div class="relative">
            <div class="flex h-10 w-10 items-center justify-center rounded-lg border border-red/15 bg-red/[0.06]">
              <span class="text-lg text-red/70">&#9830;</span>
            </div>
            <h4 class="mt-5 font-display text-xl tracking-wide text-white">MINI-GAMES</h4>
            <p class="mt-3 font-body text-[13px] leading-[1.8] text-gray-dark">
              Side quests and challenges throughout the event. Prizes for the bold.
            </p>
          </div>
        </div>

        <!-- Free Food -->
        <div class="group relative overflow-hidden rounded-2xl border border-border/40 bg-gradient-to-b from-black-card/60 to-black/40 p-8 transition-all duration-500 hover:border-red/20">
          <div class="absolute inset-0 bg-gradient-to-b from-red/[0.02] to-transparent opacity-0 transition-opacity duration-500 group-hover:opacity-100"></div>
          <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-red/20 to-transparent opacity-0 transition-opacity duration-500 group-hover:opacity-100"></div>
          <div class="pointer-events-none absolute -bottom-2 -right-2 text-[120px] leading-none text-red/[0.025] transition-all duration-700 group-hover:text-red/[0.05]" aria-hidden="true">&#9829;</div>

          <div class="relative">
            <div class="flex h-10 w-10 items-center justify-center rounded-lg border border-red/15 bg-red/[0.06]">
              <span class="text-lg text-red/70">&#9829;</span>
            </div>
            <h4 class="mt-5 font-display text-xl tracking-wide text-white">FREE FOOD</h4>
            <p class="mt-3 font-body text-[13px] leading-[1.8] text-gray-dark">
              Meals and snacks provided all day. Fuel your grind, on the house.
            </p>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  gsap.from('.about-header', {
    scrollTrigger: { trigger: '.about-header', start: 'top 80%' },
    opacity: 0, y: 40, duration: 1, ease: 'power3.out',
  });

  // Stagger the bento tiles
  gsap.from('.about-grid > *', {
    scrollTrigger: { trigger: '.about-grid', start: 'top 80%' },
    opacity: 0, y: 50, stagger: 0.12, duration: 0.9, ease: 'power3.out',
  });

  gsap.from('.about-expect', {
    scrollTrigger: { trigger: '.about-expect', start: 'top 82%' },
    opacity: 0, y: 40, duration: 1, ease: 'power3.out',
  });

  // ===== Parallax on floating elements =====
  const aboutSection = document.getElementById('about')!;
  const aboutFloaters = aboutSection.querySelectorAll<HTMLElement>('.about-floater');
  const aboutSpeeds = [0.09, -0.07, 0.06];

  const aboutAnims = Array.from(aboutFloaters).map((el) => ({
    x: gsap.quickTo(el, 'x', { duration: 0.6, ease: 'power2.out' }),
    y: gsap.quickTo(el, 'y', { duration: 0.6, ease: 'power2.out' }),
  }));

  aboutSection.addEventListener('mousemove', (e) => {
    const rect = aboutSection.getBoundingClientRect();
    const nx = ((e.clientX - rect.left) / rect.width - 0.5) * 2;
    const ny = ((e.clientY - rect.top) / rect.height - 0.5) * 2;
    aboutAnims.forEach((anim, i) => {
      const s = aboutSpeeds[i];
      anim.x(nx * rect.width * Math.abs(s) * Math.sign(s));
      anim.y(ny * rect.height * Math.abs(s) * 0.5 * Math.sign(s));
    });
  });
  aboutSection.addEventListener('mouseleave', () => {
    aboutAnims.forEach((a) => { a.x(0); a.y(0); });
  });

  // ===== Scroll parallax =====
  const aboutScrollSpeeds = [60, -45, 55];
  aboutFloaters.forEach((el, i) => {
    gsap.to(el, {
      yPercent: aboutScrollSpeeds[i],
      ease: 'none',
      scrollTrigger: {
        trigger: aboutSection,
        start: 'top bottom',
        end: 'bottom top',
        scrub: true,
      },
    });
  });
</script>

<style>
  /* ── 3D Poker Chips ── */
  .chip {
    transform-style: preserve-3d;
    transform: var(--chip-base-transform);
  }

  .chip--sm  { width: 85px;  height: 85px; }
  .chip--md  { width: 95px;  height: 95px; }
  .chip--lg  { width: 110px; height: 110px; }
  .chip--xl  { width: 130px; height: 130px; }
  @media (min-width: 1024px) {
    .chip--md  { width: 125px; height: 125px; }
    .chip--lg  { width: 145px; height: 145px; }
    .chip--xl  { width: 160px; height: 160px; }
  }

  .chip-face {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    backface-visibility: hidden;
  }

  .chip-face--front {
    transform: translateZ(7px);
    box-shadow: 0 2px 8px rgba(0,0,0,0.4);
  }
  .chip-face--back {
    transform: translateZ(-7px) rotateY(180deg);
  }
  .chip-face--sm.chip-face--front  { transform: translateZ(5px); }
  .chip-face--sm.chip-face--back   { transform: translateZ(-5px) rotateY(180deg); }
  .chip-face--xl.chip-face--front  { transform: translateZ(8px); }
  .chip-face--xl.chip-face--back   { transform: translateZ(-8px) rotateY(180deg); }

  .chip-face--red {
    background: linear-gradient(145deg, rgba(122,16,36,0.85), rgba(196,30,58,0.5) 40%, rgba(122,16,36,0.9));
    border: 3px solid rgba(196,30,58,0.3);
    box-shadow: 0 2px 12px rgba(0,0,0,0.5), inset 0 1px 0 rgba(255,255,255,0.06);
  }
  .chip-face--red-back {
    background: linear-gradient(145deg, rgba(90,12,26,0.85), rgba(150,20,40,0.4) 40%, rgba(90,12,26,0.9));
    border: 3px solid rgba(196,30,58,0.15);
  }
  .chip-face--gold {
    background: linear-gradient(145deg, rgba(42,34,16,0.9), rgba(139,118,53,0.4) 40%, rgba(42,34,16,0.95));
    border: 3px solid rgba(201,168,76,0.3);
    box-shadow: 0 2px 12px rgba(0,0,0,0.5), inset 0 1px 0 rgba(255,255,255,0.06);
  }
  .chip-face--gold-back {
    background: linear-gradient(145deg, rgba(30,24,10,0.9), rgba(100,84,38,0.35) 40%, rgba(30,24,10,0.95));
    border: 3px solid rgba(201,168,76,0.15);
  }

  .chip-edge {
    position: absolute;
    inset: 2px;
    border-radius: 50%;
    backface-visibility: hidden;
  }
  .chip-edge--red {
    background: linear-gradient(180deg, rgba(196,30,58,0.35), rgba(122,16,36,0.6) 30%, rgba(60,8,16,0.8) 70%, rgba(196,30,58,0.25));
    border: 2px solid rgba(196,30,58,0.2);
    box-shadow: inset 0 0 6px rgba(0,0,0,0.4);
  }
  .chip-edge--gold {
    background: linear-gradient(180deg, rgba(201,168,76,0.3), rgba(139,118,53,0.5) 30%, rgba(42,34,16,0.8) 70%, rgba(201,168,76,0.2));
    border: 2px solid rgba(201,168,76,0.18);
    box-shadow: inset 0 0 6px rgba(0,0,0,0.4);
  }

  .chip-ring {
    position: absolute;
    border-radius: 50%;
  }
  .chip-ring--outer {
    inset: 10%;
    border-width: 2px;
    border-style: dashed;
  }
  .chip-ring--inner {
    inset: 22%;
    border-width: 1px;
    border-style: solid;
  }
  .chip-ring--red-outer  { border-color: rgba(196,30,58,0.25); }
  .chip-ring--red-inner  { border-color: rgba(196,30,58,0.12); }
  .chip-ring--gold-outer { border-color: rgba(201,168,76,0.25); }
  .chip-ring--gold-inner { border-color: rgba(201,168,76,0.12); }

  .chip-suit {
    position: relative;
    z-index: 1;
    color: rgba(0,0,0,0.35);
    font-family: var(--font-display);
  }
  .chip-suit--gold { color: rgba(0,0,0,0.25); }
  .chip-suit--back { opacity: 0.5; }
  .chip-suit--sm { font-size: 16px; }
  .chip-suit--md { font-size: 18px; }
  .chip-suit--lg { font-size: 22px; }
  .chip-suit--xl { font-size: 28px; }
  @media (min-width: 1024px) {
    .chip-suit--md { font-size: 22px; }
    .chip-suit--lg { font-size: 26px; }
    .chip-suit--xl { font-size: 32px; }
  }
</style>
