---
// Opening hero — stripped back, no countdown, pure identity
---

<section
  id="top"
  class="recap-hero-section relative flex min-h-screen flex-col items-center justify-center overflow-hidden px-4 py-24"
>
  <!-- Background gradient: deep black → dark purple -->
  <div
    class="absolute inset-0"
    style="background: radial-gradient(ellipse 80% 60% at 50% 40%, rgba(88,28,220,0.12) 0%, rgba(45,10,100,0.06) 40%, transparent 70%), #05050a;"
  ></div>

  <!-- Ghosted suit symbols -->
  <div class="pointer-events-none absolute inset-0 select-none overflow-hidden" aria-hidden="true">
    <span
      class="absolute left-[4%] top-[20%] text-[clamp(5rem,16vw,14rem)]"
      style="color: rgba(139,92,246,0.04);"
    >♠</span>
    <span
      class="absolute right-[6%] top-[30%] text-[clamp(4rem,12vw,11rem)]"
      style="color: rgba(167,139,250,0.03);"
    >♥</span>
    <span
      class="absolute bottom-[18%] left-[18%] text-[clamp(3rem,9vw,9rem)]"
      style="color: rgba(139,92,246,0.03);"
    >♦</span>
    <span
      class="absolute bottom-[25%] right-[14%] text-[clamp(3rem,8vw,8rem)]"
      style="color: rgba(167,139,250,0.025);"
    >♣</span>
  </div>

  <!-- Top fade in from pure black -->
  <div
    class="pointer-events-none absolute inset-x-0 top-0 h-24"
    style="background: linear-gradient(to bottom, #05050a, transparent);"
  ></div>

  <div class="relative z-10 mx-auto max-w-4xl text-center">

    <!-- Eyebrow -->
    <div class="hero-eyebrow mb-8 flex items-center justify-center gap-3">
      <div class="h-px w-8" style="background: rgba(139,92,246,0.4);"></div>
      <span class="font-mono text-[10px] tracking-[0.45em] uppercase" style="color: rgba(167,139,250,0.55);">
        progsu · Atlanta, GA
      </span>
      <div class="h-px w-8" style="background: rgba(139,92,246,0.4);"></div>
    </div>

    <!-- Main title -->
    <h1
      class="hero-title font-display italic leading-[0.88] tracking-tight text-white"
      style="font-size: clamp(3.5rem, 12vw, 8rem);"
    >
      Hacklanta
    </h1>

    <!-- Year badge -->
    <div class="hero-year mt-5 flex items-center justify-center gap-4">
      <div class="h-px flex-1 max-w-[80px]" style="background: linear-gradient(to right, transparent, rgba(139,92,246,0.3));"></div>
      <span
        class="font-mono text-[11px] tracking-[0.4em] uppercase"
        style="color: rgba(255,255,255,0.35);"
      >A 12-Hour Hackathon</span>
      <div class="h-px flex-1 max-w-[80px]" style="background: linear-gradient(to left, transparent, rgba(139,92,246,0.3));"></div>
    </div>

    <!-- Tagline -->
    <p
      class="hero-tagline mx-auto mt-8 max-w-lg font-body text-base leading-[1.75]"
      style="color: rgba(255,255,255,0.38);"
    >
      Georgia State University's first hackathon.<br />
      One night. Four tracks. All in.
    </p>

    <!-- Scroll cue -->
    <div class="hero-scroll mt-16 flex flex-col items-center gap-2">
      <span class="font-mono text-[9px] tracking-[0.35em] uppercase" style="color: rgba(139,92,246,0.4);">
        scroll
      </span>
      <div
        class="h-8 w-px"
        style="background: linear-gradient(to bottom, rgba(139,92,246,0.4), transparent);"
      ></div>
    </div>

  </div>

  <!-- Bottom vignette into next section -->
  <div
    class="pointer-events-none absolute inset-x-0 bottom-0 h-32"
    style="background: linear-gradient(to top, #05050a, transparent);"
  ></div>
</section>

<script>
  import { gsap } from 'gsap';

  const tl = gsap.timeline({ delay: 0.2 });

  tl.from('.hero-eyebrow', {
    opacity: 0, y: 20, duration: 0.8, ease: 'power3.out',
  })
    .from('.hero-title', {
      opacity: 0, y: 30, duration: 1, ease: 'power3.out',
    }, '-=0.5')
    .from('.hero-year', {
      opacity: 0, duration: 0.7, ease: 'power2.out',
    }, '-=0.5')
    .from('.hero-tagline', {
      opacity: 0, y: 16, duration: 0.8, ease: 'power3.out',
    }, '-=0.4')
    .from('.hero-scroll', {
      opacity: 0, duration: 0.6, ease: 'power2.out',
    }, '-=0.2');
</script>
