---
const currentYear = new Date().getFullYear();
---

<footer id="footer" class="relative bg-black px-4 pb-8 pt-16">
  <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-red/20 to-transparent"></div>

  <div class="relative z-10 mx-auto max-w-5xl">

    <div class="flex flex-col items-center gap-6 text-center">
      <a href="/" class="inline-block transition-opacity hover:opacity-70">
        <img
          src="/logo_trimmed.png"
          alt="Hacklanta"
          class="h-7 w-auto opacity-80 select-none pointer-events-none"
          draggable="false"
          width="40"
          height="15"
        />
      </a>

      <div class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2">
        <a href="/apply" class="font-mono text-[11px] tracking-[0.2em] text-white/50 uppercase transition-colors hover:text-white">Apply</a>
        <span class="text-white/15">|</span>
        <a href="#schedule" class="font-mono text-[11px] tracking-[0.2em] text-white/50 uppercase transition-colors hover:text-white">Schedule</a>
        <span class="text-white/15">|</span>
        <a href="#faq" class="font-mono text-[11px] tracking-[0.2em] text-white/50 uppercase transition-colors hover:text-white">FAQ</a>
        <span class="text-white/15">|</span>
        <a href="https://discord.com/invite/BgKg9gskM2" target="_blank" rel="noopener noreferrer" class="font-mono text-[11px] tracking-[0.2em] text-white/50 uppercase transition-colors hover:text-white">Discord</a>
        <span class="text-white/15">|</span>
        <a href="https://instagram.com/progclubgsu" target="_blank" rel="noopener noreferrer" class="font-mono text-[11px] tracking-[0.2em] text-white/50 uppercase transition-colors hover:text-white">Instagram</a>
        <span class="text-white/15">|</span>
        <a href="mailto:programmingclubatgsu@gmail.com" class="font-mono text-[11px] tracking-[0.2em] text-white/50 uppercase transition-colors hover:text-red">Contact</a>
      </div>
    </div>

    <div class="mt-10 border-t border-white/[0.06] pt-5 text-center">
      <p class="font-mono text-[10px] tracking-[0.2em] text-white/25">
        &copy; {currentYear} <a href="https://progsu.com/" target="_blank" rel="noopener noreferrer" class="transition-colors hover:text-white/50">progsu</a> &middot; Casino-night themed hackathon. No gambling involved.
      </p>
    </div>

  </div>
</footer>
