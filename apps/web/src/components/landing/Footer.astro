---
// Footer — minimal, dark
const currentYear = new Date().getFullYear();
---

<footer id="footer" class="relative bg-black px-4 pb-8 pt-14">
  <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-red/20 to-transparent"></div>

  <div class="mx-auto max-w-5xl">
    <div class="grid gap-10 md:grid-cols-3">
      <!-- Brand -->
      <div>
        <a href="/" class="font-display text-2xl tracking-wider text-white-pure transition-opacity duration-300 hover:opacity-70">
          HACKLANTA
        </a>
        <p class="mt-3 font-body text-[12px] leading-[1.8] text-gray-dark">
          A 12-hour hackathon by progsu.<br />
          Go all in. Build something wild.
        </p>
        <div class="mt-4 flex gap-2.5 text-sm">
          <span class="text-red/30 transition-colors duration-300 hover:text-red/60">&#9829;</span>
          <span class="text-white/20 transition-colors duration-300 hover:text-white/50">&#9824;</span>
          <span class="text-white/20 transition-colors duration-300 hover:text-white/50">&#9827;</span>
          <span class="text-red/30 transition-colors duration-300 hover:text-red/60">&#9830;</span>
        </div>
      </div>

      <!-- Links -->
      <div>
        <p class="mb-3 font-mono text-[8px] tracking-[0.4em] text-gray-darker">LINKS</p>
        <ul class="space-y-2.5">
          <li><a href="/apply" class="font-body text-[12px] text-gray-dark transition-colors duration-300 hover:text-red">Apply</a></li>
          <li><a href="#schedule" class="font-body text-[12px] text-gray-dark transition-colors duration-300 hover:text-red">Schedule</a></li>
          <li><a href="#faq" class="font-body text-[12px] text-gray-dark transition-colors duration-300 hover:text-red">FAQ</a></li>
          <li><a href="#sponsors" class="font-body text-[12px] text-gray-dark transition-colors duration-300 hover:text-red">Sponsors</a></li>
        </ul>
      </div>

      <!-- Social -->
      <div>
        <p class="mb-3 font-mono text-[8px] tracking-[0.4em] text-gray-darker">CONNECT</p>
        <ul class="space-y-2.5">
          <li><a href="https://instagram.com/progsu" target="_blank" rel="noopener noreferrer" class="font-body text-[12px] text-gray-dark transition-colors duration-300 hover:text-red">Instagram</a></li>
          <li><a href="https://discord.gg/progsu" target="_blank" rel="noopener noreferrer" class="font-body text-[12px] text-gray-dark transition-colors duration-300 hover:text-white">Discord</a></li>
          <li><a href="https://github.com/progsu" target="_blank" rel="noopener noreferrer" class="font-body text-[12px] text-gray-dark transition-colors duration-300 hover:text-white">GitHub</a></li>
          <li><a href="mailto:hello@hacklanta.com" class="font-body text-[12px] text-gray-dark transition-colors duration-300 hover:text-red">Email</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-12 flex flex-col items-center justify-between gap-3 border-t border-border/30 pt-6 md:flex-row">
      <p class="font-mono text-[9px] tracking-wider text-gray-darker">
        &copy; {currentYear} progsu &mdash; Programming Club @ Georgia State University
      </p>
      <p class="font-mono text-[9px] tracking-wider text-gray-darker">
        built with <span class="text-red/50">&#9829;</span> and too much caffeine
      </p>
    </div>
  </div>
</footer>
