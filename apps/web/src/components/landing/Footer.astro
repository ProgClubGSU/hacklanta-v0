---
const currentYear = new Date().getFullYear();

const POSTERS = [
  '/images/posters/poster-1.png',
  '/images/posters/poster-2.png',
  '/images/posters/poster-3.png',
  '/images/posters/poster-4.png',
  '/images/posters/poster-5.png',
];
---

<footer id="footer" class="relative bg-black px-4 pb-8 pt-16 overflow-hidden">
  <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-red/20 to-transparent"></div>

  <!-- Poster marquee background -->
  <div class="pointer-events-none absolute inset-0 opacity-[0.4]">
    <div class="absolute inset-x-0 top-0 z-10 h-24 bg-gradient-to-b from-black to-transparent"></div>
    <div class="absolute inset-x-0 bottom-0 z-10 h-16 bg-gradient-to-t from-black to-transparent"></div>
    <div class="absolute inset-y-0 left-0 z-10 w-16 bg-gradient-to-r from-black to-transparent"></div>
    <div class="absolute inset-y-0 right-0 z-10 w-16 bg-gradient-to-l from-black to-transparent"></div>
    <div class="footer-marquee-track flex h-full items-center">
      {/* 3 copies for seamless loop */}
      {[...POSTERS, ...POSTERS, ...POSTERS].map((src) => (
        <img
          src={src}
          alt=""
          class="h-full w-auto flex-shrink-0 object-cover"
          loading="lazy"
          draggable="false"
        />
      ))}
    </div>
  </div>

  <div class="relative z-10 mx-auto max-w-5xl">

    <div class="flex flex-col items-center gap-6 text-center">
      <a href="/" class="inline-block transition-opacity hover:opacity-70">
        <img
          src="/logo_trimmed.png"
          alt="Hacklanta"
          class="h-7 w-auto opacity-80 select-none pointer-events-none"
          draggable="false"
          width="40"
          height="15"
        />
      </a>

      <div class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2">
        <a href="/apply" class="font-mono text-[11px] tracking-[0.2em] text-white/50 uppercase transition-colors hover:text-white">Apply</a>
        <span class="text-white/15">|</span>
        <a href="/dashboard/team" class="font-mono text-[11px] tracking-[0.2em] text-white/50 uppercase transition-colors hover:text-white">Team Matcher Login</a>
        <span class="text-white/15">|</span>
        <a href="#schedule" class="font-mono text-[11px] tracking-[0.2em] text-white/50 uppercase transition-colors hover:text-white">Schedule</a>
        <span class="text-white/15">|</span>
        <a href="#faq" class="font-mono text-[11px] tracking-[0.2em] text-white/50 uppercase transition-colors hover:text-white">FAQ</a>
        <span class="text-white/15">|</span>
        <a href="https://discord.com/invite/BgKg9gskM2" target="_blank" rel="noopener noreferrer" class="font-mono text-[11px] tracking-[0.2em] text-white/50 uppercase transition-colors hover:text-white">Discord</a>
        <span class="text-white/15">|</span>
        <a href="https://www.instagram.com/progsuhq/" target="_blank" rel="noopener noreferrer" class="font-mono text-[11px] tracking-[0.2em] text-white/50 uppercase transition-colors hover:text-white">Instagram</a>
        <span class="text-white/15">|</span>
        <a href="mailto:programmingclubatgsu@gmail.com" class="font-mono text-[11px] tracking-[0.2em] text-white/50 uppercase transition-colors hover:text-red">Contact</a>
      </div>
    </div>

    <div class="mt-10 border-t border-white/[0.06] pt-5 text-center">
      <p class="font-mono text-[10px] tracking-[0.2em] text-white/25">
        &copy; {currentYear} <a href="https://progsu.com/" target="_blank" rel="noopener noreferrer" class="transition-colors hover:text-white/50">progsu</a> &middot; Casino-night themed hackathon. No gambling involved.
      </p>
    </div>

  </div>
</footer>

<script>
  const track = document.querySelector<HTMLElement>('.footer-marquee-track');
  if (track) {
    const images = track.querySelectorAll('img');
    let loaded = 0;
    const total = images.length;

    function measure() {
      const setWidth = track!.scrollWidth / 3;
      if (setWidth > 0) {
        track!.style.animation = `footer-marquee ${35}s linear infinite`;

        // Inject keyframes
        let style = document.getElementById('footer-marquee-style');
        if (!style) {
          style = document.createElement('style');
          style.id = 'footer-marquee-style';
          document.head.appendChild(style);
        }
        style.textContent = `
          @keyframes footer-marquee {
            0% { transform: translateX(0); }
            100% { transform: translateX(-${setWidth}px); }
          }
        `;
      }
    }

    images.forEach((img) => {
      if (img.complete) {
        loaded++;
      } else {
        img.addEventListener('load', () => {
          loaded++;
          if (loaded >= total) measure();
        }, { once: true });
      }
    });

    if (loaded >= total) measure();

    window.addEventListener('resize', measure);
  }
</script>
