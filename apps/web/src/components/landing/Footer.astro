---
const currentYear = new Date().getFullYear();
---

<footer id="footer" class="relative overflow-hidden bg-black px-4 pb-10 pt-20">
  <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-red/30 to-transparent"></div>

  <div class="relative z-10 mx-auto max-w-5xl">

    <!-- Top row: brand + nav -->
    <div class="flex flex-col gap-10 md:flex-row md:items-start md:justify-between">

      <!-- Brand -->
      <div>
        <a href="/" class="font-display text-4xl tracking-widest text-white transition-opacity hover:opacity-70">
          HACKLANTA
        </a>
        <p class="mt-3 font-body text-sm text-white/35">
          A 12-hour hackathon by <span class="text-white/55">progsu</span> at Georgia State University.
        </p>
      </div>

      <!-- Nav + Social side by side -->
      <div class="flex gap-16">
        <div>
          <p class="mb-4 font-mono text-[9px] tracking-[0.35em] text-white/25 uppercase">Navigate</p>
          <ul class="space-y-2.5">
            <li><a href="/apply" class="font-body text-sm text-white/45 transition-colors hover:text-white">Apply</a></li>
            <li><a href="#schedule" class="font-body text-sm text-white/45 transition-colors hover:text-white">Schedule</a></li>
            <li><a href="#faq" class="font-body text-sm text-white/45 transition-colors hover:text-white">FAQ</a></li>
            <li><a href="#sponsors" class="font-body text-sm text-white/45 transition-colors hover:text-white">Sponsors</a></li>
          </ul>
        </div>

        <div>
          <p class="mb-4 font-mono text-[9px] tracking-[0.35em] text-white/25 uppercase">Connect</p>
          <ul class="space-y-2.5">
            <li><a href="https://instagram.com/progsu" target="_blank" rel="noopener noreferrer" class="font-body text-sm text-white/45 transition-colors hover:text-red">Instagram</a></li>
            <li><a href="https://discord.gg/progsu" target="_blank" rel="noopener noreferrer" class="font-body text-sm text-white/45 transition-colors hover:text-white">Discord</a></li>
            <li><a href="https://github.com/progsu" target="_blank" rel="noopener noreferrer" class="font-body text-sm text-white/45 transition-colors hover:text-white">GitHub</a></li>
            <li><a href="mailto:hello@hacklanta.com" class="font-body text-sm text-white/45 transition-colors hover:text-red">Email</a></li>
          </ul>
        </div>
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="mt-16 border-t border-white/[0.06] pt-7 flex flex-col gap-2 md:flex-row md:items-center md:justify-between">
      <p class="font-mono text-[10px] tracking-widest text-white/20 uppercase">
        &copy; {currentYear} progsu · Programming Club @ Georgia State University
      </p>
      <p class="font-mono text-[10px] tracking-widest text-white/20 uppercase">
        built with <span class="text-red/40">♥</span> and too much caffeine
      </p>
    </div>

  </div>
</footer>
