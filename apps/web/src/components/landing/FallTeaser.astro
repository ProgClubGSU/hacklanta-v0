---
// Fall 2026 — concert-hall dark, music lyric vibe, IN WORKS
---

<section
  id="fall-2026"
  class="fall-section relative flex min-h-screen flex-col items-center justify-center overflow-hidden px-4 py-24"
>
  <!-- ── Deep purple layered base ── -->
  <div
    class="absolute inset-0"
    style="background: linear-gradient(155deg, #060310 0%, #0e0524 28%, #14092e 52%, #0b0420 76%, #040209 100%);"
  ></div>

  <!-- Central bloom -->
  <div
    class="pointer-events-none absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2"
    style="width: 900px; height: 900px; background: radial-gradient(circle, rgba(100,30,230,0.13) 0%, rgba(80,20,190,0.06) 38%, transparent 68%); border-radius: 50%;"
  ></div>
  <!-- Side bleeds -->
  <div class="pointer-events-none absolute -left-32 top-1/4" style="width: 500px; height: 500px; background: radial-gradient(circle, rgba(120,50,240,0.07) 0%, transparent 65%); border-radius: 50%;"></div>
  <div class="pointer-events-none absolute -right-20 bottom-1/4" style="width: 400px; height: 400px; background: radial-gradient(circle, rgba(160,80,250,0.05) 0%, transparent 65%); border-radius: 50%;"></div>

  <!-- ── Scattered music notes — background atmosphere ── -->
  <div class="pointer-events-none absolute inset-0 select-none overflow-hidden" aria-hidden="true">
    <span class="absolute font-display note-place" style="--rot: -8deg; top: 8%;  left: 6%;  font-size: clamp(1.4rem, 3vw, 2.4rem); color: rgba(167,139,250,0.28); animation-delay: 0.3s;">♩</span>
    <span class="absolute font-display note-place" style="--rot: 6deg;  top: 14%; right: 8%; font-size: clamp(0.9rem, 2vw, 1.6rem); color: rgba(139,92,246,0.22); animation-delay: 0.7s;">♪</span>
    <span class="absolute font-display note-place" style="--rot: -4deg; top: 27%; left: 3%;  font-size: clamp(0.7rem, 1.5vw, 1.2rem); color: rgba(167,139,250,0.18); animation-delay: 1.1s;">♫</span>
    <span class="absolute font-display note-place" style="--rot: 10deg; top: 38%; right: 5%; font-size: clamp(2rem, 5vw, 4rem);   color: rgba(120,50,240,0.12); animation-delay: 0.5s;">♬</span>
    <span class="absolute font-display note-place" style="--rot: -6deg; top: 51%; left: 8%;  font-size: clamp(1.1rem, 2.5vw, 2rem); color: rgba(160,80,250,0.16); animation-delay: 1.4s;">♩</span>
    <span class="absolute font-display note-place" style="--rot: 3deg;  top: 63%; right: 12%;font-size: clamp(0.8rem, 1.8vw, 1.4rem); color: rgba(139,92,246,0.2); animation-delay: 0.9s;">♪</span>
    <span class="absolute font-display note-place" style="--rot: -5deg; top: 74%; left: 5%;  font-size: clamp(0.65rem, 1.4vw, 1.1rem); color: rgba(167,139,250,0.18); animation-delay: 1.7s;">♫</span>
    <span class="absolute font-display note-place" style="--rot: 7deg;  top: 85%; right: 6%; font-size: clamp(1.2rem, 2.5vw, 2rem); color: rgba(139,92,246,0.2); animation-delay: 1.2s;">♬</span>
    <!-- Large ghost note center-left -->
    <span class="absolute font-display note-place" style="--rot: -3deg; top: 30%; left: 12%; font-size: clamp(4rem, 10vw, 9rem);  color: rgba(100,30,220,0.055); animation-delay: 0.6s;">♪</span>
  </div>

  <!-- ── On-staff notes — animate dropping onto staff lines ── -->
  <div class="pointer-events-none absolute inset-0 select-none overflow-hidden" aria-hidden="true">
    <span class="absolute font-display note-drop" style="--rot: -3deg; top: 22%; left: 18%;  font-size: clamp(1.1rem, 2.5vw, 1.8rem); color: rgba(167,139,250,0.45); animation-delay: 0.4s;">♩</span>
    <span class="absolute font-display note-drop" style="--rot: 2deg;  top: 26%; left: 32%;  font-size: clamp(0.9rem, 2vw, 1.5rem); color: rgba(139,92,246,0.4);  animation-delay: 0.75s;">♪</span>
    <span class="absolute font-display note-drop" style="--rot: -5deg; top: 30%; left: 52%;  font-size: clamp(1.2rem, 2.8vw, 2rem); color: rgba(167,139,250,0.38); animation-delay: 1.0s;">♫</span>
    <span class="absolute font-display note-drop" style="--rot: 4deg;  top: 34%; left: 68%;  font-size: clamp(0.85rem, 1.9vw, 1.4rem); color: rgba(139,92,246,0.35); animation-delay: 1.3s;">♬</span>
    <span class="absolute font-display note-drop" style="--rot: -2deg; top: 38%; left: 82%;  font-size: clamp(1rem, 2.2vw, 1.6rem); color: rgba(160,80,250,0.4);  animation-delay: 1.6s;">♩</span>
    <span class="absolute font-display note-drop" style="--rot: 6deg;  top: 26%; left: 44%;  font-size: clamp(0.8rem, 1.8vw, 1.3rem); color: rgba(167,139,250,0.32); animation-delay: 1.9s;">♪</span>
  </div>

  <!-- ── Horizontal staff lines (musical score) ── -->
  <div class="pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true">
    {[22, 26, 30, 34, 38].map((top) => (
      <div
        class="absolute left-0 right-0 h-px"
        style={`top: ${top}%; background: linear-gradient(to right, transparent 5%, rgba(139,92,246,0.04) 25%, rgba(139,92,246,0.06) 50%, rgba(139,92,246,0.04) 75%, transparent 95%);`}
      ></div>
    ))}
  </div>

  <!-- ── Scrolling lyric marquee — bottom ── -->
  <div class="pointer-events-none absolute bottom-20 inset-x-0 overflow-hidden" aria-hidden="true">
    <div class="lyric-marquee-track flex gap-0 whitespace-nowrap">
      {[...Array(3)].map(() => (
        <span class="inline-flex items-center gap-8 pr-8 font-display italic" style="font-size: clamp(0.65rem, 1.5vw, 0.85rem); color: rgba(167,139,250,0.45); letter-spacing: 0.08em;">
          <span>different rhythm</span>
          <span style="color: rgba(139,92,246,0.65);">♩</span>
          <span>higher stakes</span>
          <span style="color: rgba(139,92,246,0.65);">♪</span>
          <span>the drop hits different</span>
          <span style="color: rgba(139,92,246,0.65);">♫</span>
          <span>fall 2026</span>
          <span style="color: rgba(139,92,246,0.65);">♬</span>
          <span>stay tuned</span>
          <span style="color: rgba(139,92,246,0.65);">♩</span>
          <span>turn it up</span>
          <span style="color: rgba(139,92,246,0.65);">♪</span>
        </span>
      ))}
    </div>
  </div>

  <!-- ── Top + bottom borders ── -->
  <div class="absolute inset-x-0 top-0 h-px" style="background: linear-gradient(to right, transparent, rgba(139,92,246,0.22), transparent);"></div>
  <div class="absolute inset-x-0 bottom-0 h-px" style="background: linear-gradient(to right, transparent, rgba(109,40,217,0.18), transparent);"></div>

  <!-- ── Main content ── -->
  <div class="relative z-10 mx-auto max-w-3xl text-center">

    <!-- In Progress badge -->
    <div class="fall-inworks mb-10 flex justify-center">
      <div
        class="inline-flex items-center gap-2.5 border px-4 py-2"
        style="border-color: rgba(234,179,8,0.4); background: rgba(234,179,8,0.1);"
      >
        <span class="relative flex h-2 w-2" aria-hidden="true">
          <span
            class="absolute inline-flex h-full w-full rounded-full"
            style="background: #eab308; opacity: 0.8; animation: fall-ping 1.5s cubic-bezier(0,0,0.2,1) infinite;"
          ></span>
          <span class="relative inline-flex h-2 w-2 rounded-full" style="background: #eab308;"></span>
        </span>
        <span class="font-display italic text-[10px] tracking-[0.45em] uppercase" style="color: #eab308; text-shadow: 0 0 12px rgba(234,179,8,0.5);">
          Coming Soon
        </span>
      </div>
    </div>

    <!-- Presented by -->
    <div class="mb-4 flex justify-center">
      <span class="font-mono text-[9px] tracking-[0.3em] uppercase" style="color: rgba(255,255,255,0.5);">Presented by <a href="https://progsu.com" target="_blank" rel="noopener noreferrer" class="fall-progsu-link">progsu</a></span>
    </div>

    <!-- Tag -->
    <div class="fall-tag mb-8 flex items-center justify-center gap-3">
      <div class="h-px w-8" style="background: linear-gradient(to right, transparent, rgba(167,139,250,0.28));"></div>
      <span class="font-mono text-[9px] tracking-[0.5em] uppercase" style="color: rgba(167,139,250,0.32);">Next Chapter</span>
      <div class="h-px w-8" style="background: linear-gradient(to left, transparent, rgba(167,139,250,0.28));"></div>
    </div>

    <!-- Heading -->
    <h1
      class="fall-heading font-display italic leading-[0.86] tracking-tight"
      style="font-size: clamp(3.6rem, 11vw, 8rem);"
    >
      <a href="https://hacklanta.dev" class="text-white hover:opacity-80 transition-opacity duration-200">Hacklanta</a><br />
      <span class="fall-title-span"
        style="background: linear-gradient(135deg, #a78bfa 0%, #c4b5fd 40%, #e879f9 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; font-size: clamp(2rem, 6vw, 4.5rem); display: block; margin-top: -0.15em;"
      >fall 2026</span>
    </h1>

    <!-- Lyric-style tagline -->
    <p
      class="fall-tagline mt-10 font-display italic"
      style="font-size: clamp(1rem, 2.5vw, 1.35rem); color: rgba(255,255,255,0.32); letter-spacing: 0.02em; line-height: 1.6;"
    >
      Different rhythm.<span class="mx-3" style="color: rgba(139,92,246,0.75);">♪</span>Higher stakes.
    </p>

    <!-- Vertical divider line -->
    <div class="fall-divider mx-auto mt-10 w-px h-14" style="background: linear-gradient(to bottom, rgba(139,92,246,0.35), transparent);"></div>

    <!-- Scroll cue -->
    <div class="fall-scroll mt-6 flex flex-col items-center gap-2">
      <span class="font-mono text-[9px] tracking-[0.4em] uppercase" style="color: rgba(167,139,250,0.75);">Spring 2026 below</span>
      <svg class="h-4 w-4" style="color: rgba(167,139,250,0.7);" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
      </svg>
    </div>

  </div>
</section>

<style>
  /* Fall 2026 title hover — stroke through gradient via filter */
  .fall-title-span {
    display: inline-block;
    cursor: default;
    transition: filter 0.35s ease, -webkit-text-fill-color 0.35s ease;
  }
  .fall-title-span:hover {
    filter: drop-shadow(0 0 18px rgba(167,139,250,0.7)) drop-shadow(0 0 50px rgba(232,121,249,0.35)) brightness(1.15);
  }

  .fall-s26-btn {
    background: rgba(139,92,246,0.06);
    transition: border-color 0.25s ease, background 0.25s ease, color 0.25s ease, box-shadow 0.25s ease;
  }
  .fall-s26-btn:hover {
    border-color: rgba(167,139,250,0.65) !important;
    background: rgba(139,92,246,0.14);
    color: rgba(196,181,253,1) !important;
    box-shadow: 0 0 22px rgba(139,92,246,0.2);
  }

  .fall-progsu-link {
    color: rgba(167,139,250,0.85);
    transition: color 0.2s, text-shadow 0.2s;
  }
  .fall-progsu-link:hover {
    color: rgba(167,139,250,1);
    text-shadow: 0 0 14px rgba(167,139,250,0.55);
  }

  /* Hacklanta heading — outlined stroke on hover (matches TextLogo effect) */
  .fall-heading a {
    display: inline-block;
    -webkit-text-stroke: 2px transparent;
    transition: color 0.35s ease, -webkit-text-stroke-color 0.35s ease, filter 0.35s ease, opacity 0.2s;
  }
  .fall-heading a:hover {
    opacity: 1 !important;
    color: transparent !important;
    -webkit-text-stroke-color: rgba(255, 255, 255, 0.88);
    filter: drop-shadow(0 0 18px rgba(167,139,250,0.55)) drop-shadow(0 0 40px rgba(139,92,246,0.28));
  }

  /* Note drop-onto-staff animation */
  @keyframes note-drop {
    0%   { opacity: 0; transform: translateY(-60px) rotate(var(--rot, 0deg)) scale(1.3); }
    55%  { opacity: 1; transform: translateY(6px)   rotate(var(--rot, 0deg)) scale(0.95); }
    72%  {             transform: translateY(-4px)  rotate(var(--rot, 0deg)) scale(1.02); }
    85%  {             transform: translateY(2px)   rotate(var(--rot, 0deg)) scale(0.98); }
    100% { opacity: 1; transform: translateY(0)     rotate(var(--rot, 0deg)) scale(1); }
  }
  .note-drop {
    opacity: 0;
    animation: note-drop 0.7s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  /* Scattered background notes — fade up into position */
  @keyframes note-place {
    0%   { opacity: 0; transform: translateY(20px) rotate(var(--rot, 0deg)); }
    100% { opacity: 1; transform: translateY(0)    rotate(var(--rot, 0deg)); }
  }
  .note-place {
    opacity: 0;
    animation: note-place 0.9s ease-out both;
  }

  @keyframes fall-ping {
    75%, 100% { transform: scale(2.2); opacity: 0; }
  }
  @keyframes lyric-marquee {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-33.333%); }
  }
  .lyric-marquee-track {
    animation: lyric-marquee 28s linear infinite;
  }
</style>

<script>
  import { gsap } from 'gsap';

  const tl = gsap.timeline({ delay: 0.2 });
  tl.from('.fall-inworks', { opacity: 0, y: -12, duration: 0.65, ease: 'power3.out' })
    .from('.fall-tag',     { opacity: 0, y: 18,  duration: 0.7,  ease: 'power3.out' }, '-=0.3')
    .from('.fall-heading', { opacity: 0, y: 45,  duration: 1.1,  ease: 'power3.out' }, '-=0.45')
    .from('.fall-tagline', { opacity: 0, y: 22,  duration: 0.85, ease: 'power3.out' }, '-=0.55')
    .from('.fall-divider', { opacity: 0, scaleY: 0, duration: 0.55, ease: 'power2.out', transformOrigin: 'top' }, '-=0.3')
    .from('.fall-scroll',  { opacity: 0, y: 10, duration: 0.6, ease: 'power2.out' }, '-=0.15');
</script>
