---
// [05] FAQ

const faqs = [
  { q: 'Who can participate?', a: 'Any college student! You don\'t need to be a CS major or have prior hackathon experience. Beginners are absolutely welcome — we\'ll have workshops to get you started.' },
  { q: 'How much does it cost?', a: 'Nothing. Hacklanta is completely free. We provide food, swag, workspace, WiFi, and good vibes. All you need is a laptop and the drive to build.' },
  { q: 'Do I need a team?', a: 'Nope! You can come solo and find a team at the event using our team finder, or you can register with a pre-formed team of up to 4 people.' },
  { q: 'What can I build?', a: 'Anything! Web apps, mobile apps, hardware projects, games, AI tools — if you can demo it, you can submit it. We\'ll announce specific prize tracks closer to the event.' },
  { q: 'What should I bring?', a: 'Your laptop, charger, and any hardware you want to hack on. We provide everything else — food, drinks, snacks, WiFi, and power outlets.' },
  { q: 'How does judging work?', a: 'Teams demo their projects to a panel of judges at the end. Projects are evaluated on creativity, technical complexity, design, and impact. Multiple prize categories means more chances to win.' },
  { q: 'When and where is it?', a: 'Hacklanta takes place at Georgia State University in Atlanta, GA. Check the countdown timer above for the exact date. Doors open at 9 AM, hacking ends at 8 PM.' },
  { q: 'Is there a code of conduct?', a: 'Yes. We follow the MLH Code of Conduct. Hacklanta is an inclusive, harassment-free event. We\'re here to build, learn, and have fun together.' },
];
---

<section id="faq" class="relative bg-black-card px-4 py-24 md:py-32">
  <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-border-light/60 to-transparent"></div>

  <div class="mx-auto max-w-3xl">
    <div class="faq-header mb-12">
      <div class="flex items-center gap-3 font-mono text-[10px] tracking-[0.3em] text-gray-darker">
        <span class="text-red/60">[05]</span>
        <span class="h-px flex-1 bg-border/60"></span>
        <span>FAQ</span>
      </div>
      <h2 class="mt-5 font-display text-5xl tracking-wide text-white-pure md:text-6xl">
        THE FINE PRINT
      </h2>
    </div>

    <div class="faq-list space-y-1.5">
      {faqs.map((faq, i) => (
        <details class="faq-item group border border-border/50 bg-black/40 transition-all duration-300 hover:border-border-light open:border-red/20 open:bg-black-card/60">
          <summary class="flex cursor-pointer items-center justify-between px-6 py-4 select-none [&::-webkit-details-marker]:hidden">
            <span class="flex items-center gap-3">
              <span class="font-mono text-[10px] text-gray-darker">{String(i + 1).padStart(2, '0')}</span>
              <span class="font-body text-[14px] font-medium text-white/90">{faq.q}</span>
            </span>
            <span class="ml-4 shrink-0 font-mono text-sm text-red/40 transition-all duration-300 group-hover:text-red/70 group-open:rotate-45 group-open:text-red">+</span>
          </summary>
          <div class="border-t border-border/30 px-6 py-4">
            <p class="pl-8 font-body text-[13px] leading-[1.8] text-gray">
              {faq.a}
            </p>
          </div>
        </details>
      ))}
    </div>

    <div class="faq-cta mt-10 text-center">
      <p class="font-body text-[13px] text-gray-dark">still have questions?</p>
      <div class="mt-4 flex justify-center gap-3">
        <a
          href="mailto:hello@hacklanta.com"
          class="group inline-flex items-center gap-2 border border-red/30 bg-red/[0.06] px-5 py-2.5 font-body text-[10px] font-semibold tracking-[0.15em] text-red/80 transition-all duration-300 hover:border-red/50 hover:text-red"
        >
          EMAIL <span class="transition-transform duration-300 group-hover:translate-x-0.5">&rarr;</span>
        </a>
        <a
          href="https://discord.gg/progsu"
          target="_blank"
          rel="noopener noreferrer"
          class="group inline-flex items-center gap-2 border border-border bg-black/40 px-5 py-2.5 font-body text-[10px] font-semibold tracking-[0.15em] text-gray transition-all duration-300 hover:border-border-light hover:text-white"
        >
          DISCORD <span class="transition-transform duration-300 group-hover:translate-x-0.5">&rarr;</span>
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  gsap.from('.faq-header', {
    scrollTrigger: { trigger: '.faq-header', start: 'top 80%' },
    opacity: 0, y: 30, duration: 0.8,
  });
  gsap.from('.faq-item', {
    scrollTrigger: { trigger: '.faq-list', start: 'top 80%' },
    opacity: 0, y: 15, stagger: 0.06, duration: 0.5, ease: 'power2.out',
  });
  gsap.from('.faq-cta', {
    scrollTrigger: { trigger: '.faq-cta', start: 'top 85%' },
    opacity: 0, y: 20, duration: 0.6,
  });
</script>
