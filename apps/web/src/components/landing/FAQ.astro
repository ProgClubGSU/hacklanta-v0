---
// [05] FAQ — casino fine print

const faqs = [
  { q: 'Who can participate?', a: 'Any college student. No CS degree required, no prior hackathon experience needed. All skill levels are welcome!' },
  { q: 'How much does it cost?', a: 'Zero. Free entry, free food, free swag. All you need is a laptop and the will to build something.' },
  { q: 'Do I need a team?', a: 'Nope. Come solo and squad up at the event, or bring a pre-formed team of up to 4. You\'ll be granted access to the team finder within your user dashboard upon acceptance.' },
  { q: 'Can I use AI tools?', a: 'Yes — go crazy. ChatGPT, Copilot, whatever. Judges care about what you built, not whether you typed every line yourself.' },
];
---

<section id="faq" class="relative overflow-hidden bg-black px-4 py-16 md:py-24">
  <!-- Top gradient border -->
  <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-red/30 to-transparent"></div>

  <!-- Ambient glow — center-left -->
  <div
    class="pointer-events-none absolute left-[10%] top-[30%] h-[600px] w-[500px] rounded-full"
    style="background: radial-gradient(circle, rgba(196,30,58,0.05) 0%, rgba(196,30,58,0.012) 40%, transparent 65%);"
  ></div>
  <!-- Gold accent glow — bottom right -->
  <div
    class="pointer-events-none absolute right-[15%] bottom-[10%] h-[300px] w-[300px] rounded-full opacity-[0.03] blur-[80px]"
    style="background: radial-gradient(circle, rgba(201,168,76,0.5) 0%, transparent 70%);"
  ></div>

  <div class="relative z-10 mx-auto max-w-3xl">
    <div class="faq-header mb-14">
      <div class="flex items-center gap-3 font-mono text-[11px] tracking-[0.3em] text-gray-500">
        <span class="text-red/60">[05]</span>
        <span class="h-px flex-1 bg-gradient-to-r from-border/80 to-transparent"></span>
        <span>FAQ</span>
      </div>
      <h2 class="mt-6 font-display text-5xl tracking-wide text-white-pure md:text-7xl">
        THE FINE PRINT
      </h2>
      <div class="mt-4 h-px w-24 bg-gradient-to-r from-red/60 to-transparent"></div>
    </div>

    <div class="faq-list grid gap-4 sm:grid-cols-2">
      {faqs.map((faq) => (
        <div class="faq-item border border-border/40 bg-black-card/20 p-6 transition-all duration-300 hover:border-red/25 hover:bg-black-card/40">
          <h3 class="mb-3 font-display text-xl tracking-wide text-white">{faq.q}</h3>
          <p class="font-body text-sm leading-[1.9] text-gray">{faq.a}</p>
        </div>
      ))}
    </div>

    <div class="faq-cta mt-12 text-center">
      <p class="font-body text-[13px] text-gray-dark">still have questions?</p>
      <div class="mt-5 flex justify-center gap-3">
        <a
          href="mailto:programmingclubatgsu@gmail.com"
          class="group relative inline-flex items-center gap-2 overflow-hidden border border-red/30 bg-red/[0.06] px-6 py-3 font-body text-[11px] font-semibold tracking-[0.15em] text-red/80 transition-all duration-500 hover:border-red/50 hover:text-red hover:shadow-[0_0_24px_rgba(196,30,58,0.08)]"
        >
          <span class="relative z-10">EMAIL</span>
          <span class="absolute inset-0 -translate-x-full bg-gradient-to-r from-transparent via-red/[0.06] to-transparent transition-transform duration-700 ease-out group-hover:translate-x-full"></span>
        </a>
        <a
          href="https://discord.com/invite/BgKg9gskM2"
          target="_blank"
          rel="noopener noreferrer"
          class="group relative inline-flex items-center gap-2 overflow-hidden border border-border/80 bg-black-card/30 px-6 py-3 font-body text-[11px] font-semibold tracking-[0.15em] text-gray transition-all duration-500 hover:border-border-light hover:text-white hover:shadow-[0_0_24px_rgba(0,0,0,0.2)]"
        >
          <span class="relative z-10">DISCORD</span>
          <span class="absolute inset-0 -translate-x-full bg-gradient-to-r from-transparent via-white/[0.02] to-transparent transition-transform duration-700 ease-out group-hover:translate-x-full"></span>
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  gsap.from('.faq-header', {
    scrollTrigger: { trigger: '.faq-header', start: 'top 80%' },
    opacity: 0, y: 40, duration: 1, ease: 'power3.out',
  });
  gsap.from('.faq-item', {
    scrollTrigger: { trigger: '.faq-list', start: 'top bottom', once: true },
    immediateRender: false,
    opacity: 0, y: 16, stagger: 0.06, duration: 0.5, ease: 'power3.out',
  });
  gsap.from('.faq-cta', {
    scrollTrigger: { trigger: '.faq-cta', start: 'top 85%' },
    opacity: 0, y: 25, duration: 0.8, ease: 'power3.out',
  });
</script>
