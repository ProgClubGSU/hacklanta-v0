---
// Track cards — poker table grid with Bicycle-style cards

const suitSvg = {
  spade: '<svg viewBox="0 0 100 100" fill="currentColor" aria-hidden="true" style="width:1em;height:1em;display:inline-block;vertical-align:-0.125em;"><path d="M50 5C50 5 20 40 20 58c0 12 8 20 18 20 6 0 10-3 12-7v14H40v6h20v-6H50V71c2 4 6 7 12 7 10 0 18-8 18-20C80 40 50 5 50 5z"/></svg>',
  heart: '<svg viewBox="0 0 100 100" fill="currentColor" aria-hidden="true" style="width:1em;height:1em;display:inline-block;vertical-align:-0.125em;"><path d="M50 90C50 90 5 55 5 35 5 18 20 5 35 10c7 3 12 8 15 15 3-7 8-12 15-15 15-5 30 8 30 25C95 55 50 90 50 90z"/></svg>',
  club: '<svg viewBox="0 0 100 100" fill="currentColor" aria-hidden="true" style="width:1em;height:1em;display:inline-block;vertical-align:-0.125em;"><path d="M50 50m-16 0a16 16 0 1 1 32 0 16 16 0 1 1-32 0M50 5a20 20 0 0 1 0 40A20 20 0 0 1 50 5M22 30a20 20 0 0 0 18 35A20 20 0 0 0 22 30M60 65a20 20 0 0 0 18-35A20 20 0 0 0 60 65M44 85h12V65H44z"/></svg>',
  diamond: '<svg viewBox="0 0 100 100" fill="currentColor" aria-hidden="true" style="width:1em;height:1em;display:inline-block;vertical-align:-0.125em;"><path d="M50 5L5 50 50 95 95 50z"/></svg>',
};

const tracks = [
  {
    name: 'Bluff Track',
    suit: suitSvg.spade,
    rank: 'A',
    label: 'ACE OF SPADES',
    desc: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit.',
    accentRgb: '196,30,58',
    suitColor: '#C41E3A',
  },
  {
    name: 'Jackpot Track',
    suit: suitSvg.heart,
    rank: 'K',
    label: 'KING OF HEARTS',
    desc: 'Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam.',
    accentRgb: '230,57,70',
    suitColor: '#E63946',
  },
  {
    name: 'Highroller',
    suit: suitSvg.club,
    rank: 'Q',
    label: 'QUEEN OF CLUBS',
    desc: 'Duis aute irure dolor in reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla pariatur.',
    accentRgb: '196,30,58',
    suitColor: '#C41E3A',
  },
  {
    name: 'House Pick',
    suit: suitSvg.diamond,
    rank: 'J',
    label: 'JACK OF DIAMONDS',
    desc: 'Excepteur sint occaecat cupidatat non proident.',
    accentRgb: '201,168,76',
    suitColor: '#C9A84C',
  },
];
---

<section id="tracks" class="relative bg-black px-4 py-16 md:py-24">
  <!-- Subtle felt texture overlay -->
  <div class="pointer-events-none absolute inset-0 opacity-[0.03]" style="background-image: url(&quot;data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='f'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23f)'/%3E%3C/svg%3E&quot;); background-size: 200px;"></div>

  <!-- Section header -->
  <div class="tracks-header relative z-10 mx-auto mb-12 max-w-5xl text-center">
    <div class="flex items-center justify-center gap-3 font-mono text-[11px] tracking-[0.3em] text-gray-400">
      <span class="h-px w-12 bg-gradient-to-r from-transparent to-border/80"></span>
      <span class="text-red/80">[01]</span>
      <span>TRACKS</span>
      <span class="h-px w-12 bg-gradient-to-l from-transparent to-border/80"></span>
    </div>
    <h2 class="section-heading mt-5 font-serif italic text-[clamp(2.2rem,8vw,5rem)] leading-[0.9] tracking-tight text-white">Pick a Card, Any Card</h2>
    <div class="mx-auto mt-3 h-px w-24 bg-gradient-to-r from-transparent via-red/40 to-transparent"></div>
  </div>

  <!-- Card grid with placemat outlines -->
  <div class="relative z-20 mx-auto max-w-6xl">
    <div class="track-grid grid grid-cols-2 gap-4 md:grid-cols-4 md:gap-6 lg:gap-8">
      {tracks.map((track, i) => (
        <div class="track-slot group relative">
          <!-- Placemat outline (visible before/behind card) -->
          <div class="placemat absolute inset-0 rounded-xl border-2 border-dashed border-red/10 transition-colors duration-500 group-hover:border-red/20" style="aspect-ratio: 5/7;"></div>

          <!-- The card -->
          <div class="track-card" data-index={i}>
            <div class="track-card-flipper" data-flip="false">
              <!-- BACK FACE — Bicycle rider back -->
              <div class="card-back">
                <div class="card-back-inner">
                  <div class="card-back-pattern"></div>
                  <div class="card-back-border-1"></div>
                  <div class="card-back-border-2"></div>
                  <div class="card-back-center">
                    <div class="card-back-diamond">
                      <span class="card-back-diamond-suit"><svg viewBox="0 0 100 100" fill="currentColor" width="1em" height="1em" aria-hidden="true"><path d="M50 5C50 5 20 40 20 58c0 12 8 20 18 20 6 0 10-3 12-7v14H40v6h20v-6H50V71c2 4 6 7 12 7 10 0 18-8 18-20C80 40 50 5 50 5z"/></svg></span>
                    </div>
                  </div>
                  <span class="card-back-corner card-back-corner--tl"><svg viewBox="0 0 100 100" fill="currentColor" width="1em" height="1em" aria-hidden="true"><path d="M50 5L5 50 50 95 95 50z"/></svg></span>
                  <span class="card-back-corner card-back-corner--tr"><svg viewBox="0 0 100 100" fill="currentColor" width="1em" height="1em" aria-hidden="true"><path d="M50 50m-16 0a16 16 0 1 1 32 0 16 16 0 1 1-32 0M50 5a20 20 0 0 1 0 40A20 20 0 0 1 50 5M22 30a20 20 0 0 0 18 35A20 20 0 0 0 22 30M60 65a20 20 0 0 0 18-35A20 20 0 0 0 60 65M44 85h12V65H44z"/></svg></span>
                  <span class="card-back-corner card-back-corner--bl"><svg viewBox="0 0 100 100" fill="currentColor" width="1em" height="1em" aria-hidden="true"><path d="M50 90C50 90 5 55 5 35 5 18 20 5 35 10c7 3 12 8 15 15 3-7 8-12 15-15 15-5 30 8 30 25C95 55 50 90 50 90z"/></svg></span>
                  <span class="card-back-corner card-back-corner--br"><svg viewBox="0 0 100 100" fill="currentColor" width="1em" height="1em" aria-hidden="true"><path d="M50 5C50 5 20 40 20 58c0 12 8 20 18 20 6 0 10-3 12-7v14H40v6h20v-6H50V71c2 4 6 7 12 7 10 0 18-8 18-20C80 40 50 5 50 5z"/></svg></span>
                </div>
              </div>

              <!-- FRONT FACE — Track info on cream card -->
              <div class="card-front" style={`--card-accent: ${track.suitColor}; --card-accent-rgb: ${track.accentRgb};`}>
                <div class="card-front-inner">
                  <div class="card-front-tl">
                    <span class="card-rank" set:html={track.rank}></span>
                    <span class="card-suit-sm" set:html={track.suit}></span>
                  </div>
                  <div class="card-front-br">
                    <span class="card-rank" set:html={track.rank}></span>
                    <span class="card-suit-sm" set:html={track.suit}></span>
                  </div>
                  <div class="card-center">
                    <span class="card-suit-lg" set:html={track.suit}></span>
                    <span class="card-track-name">{track.name.toUpperCase()}</span>
                    <div class="card-divider"></div>
                    <span class="card-track-desc">{track.desc}</span>
                  </div>
                  <span class="card-label">{track.label}</span>
                  <div class="card-inner-border"></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- Prize Pool — crash game style -->
  <div class="prize-pool relative z-10 mx-auto mt-16 min-h-[280px] max-w-5xl md:min-h-0">
    <canvas class="crash-canvas pointer-events-none absolute inset-0 h-full w-full opacity-50"></canvas>

    <div class="relative z-10 flex flex-col items-center py-16 text-center md:py-10">
      <span class="font-mono text-[10px] tracking-[0.3em] text-gold/50 uppercase">prize pool</span>
      <div class="mt-3 flex items-baseline">
        <span class="font-display text-2xl text-gold/50 md:text-3xl">$</span>
        <span
          class="prize-number font-display text-6xl tracking-wider text-gold md:text-8xl"
          style="text-shadow: 0 0 60px rgba(201,168,76,0.25), 0 0 120px rgba(201,168,76,0.08);"
        >4,300</span>
      </div>
      <div class="mt-2 flex items-center gap-1.5">
        <svg class="h-3 w-3 animate-bounce text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7" />
        </svg>
        <span class="font-mono text-[10px] tracking-[0.2em] text-green-400/70 uppercase">and growing</span>
      </div>
    </div>
  </div>
</section>

<style>
  /* ── Track slot and placemat ── */
  .track-slot {
    aspect-ratio: 5 / 7;
    position: relative;
  }
  .placemat {
    box-shadow: inset 0 0 30px rgba(196,30,58,0.03);
  }

  /* ── Card wrapper ── */
  .track-card {
    width: 100%;
    height: 100%;
    position: relative;
  }
  .track-card-flipper {
    width: 100%;
    height: 100%;
    position: relative;
    transform-style: preserve-3d;
    transition: transform 0.9s cubic-bezier(0.23, 1, 0.32, 1);
  }
  .track-card-flipper[data-flip="true"] {
    transform: rotateY(180deg);
  }

  /* ── Card Back — Bicycle Rider Back ── */
  .card-back {
    position: absolute;
    inset: 0;
    border-radius: 10px;
    overflow: hidden;
    backface-visibility: hidden;
    box-shadow: 0 8px 30px rgba(0,0,0,0.6), 0 2px 8px rgba(0,0,0,0.4);
  }
  .card-back-inner {
    width: 100%;
    height: 100%;
    background: #B22234;
    border: 3px solid #d4c8b0;
    border-radius: 10px;
    position: relative;
    overflow: hidden;
  }
  .card-back-pattern {
    position: absolute;
    inset: 0;
    background:
      repeating-linear-gradient(45deg, rgba(255,255,255,0.08) 0px, rgba(255,255,255,0.08) 1px, transparent 1px, transparent 8px),
      repeating-linear-gradient(-45deg, rgba(255,255,255,0.08) 0px, rgba(255,255,255,0.08) 1px, transparent 1px, transparent 8px);
  }
  .card-back-border-1 {
    position: absolute;
    inset: 7%;
    border: 2px solid rgba(255,255,255,0.3);
    border-radius: 6px;
  }
  .card-back-border-2 {
    position: absolute;
    inset: 10%;
    border: 1px solid rgba(255,255,255,0.18);
    border-radius: 4px;
  }
  .card-back-center {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }
  .card-back-diamond {
    width: 30px;
    height: 30px;
    transform: rotate(45deg);
    background: rgba(255,255,255,0.12);
    border: 1.5px solid rgba(255,255,255,0.28);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .card-back-diamond-suit {
    transform: rotate(-45deg);
    font-size: 14px;
    color: rgba(255,255,255,0.45);
    line-height: 1;
  }
  .card-back-corner {
    position: absolute;
    font-size: 9px;
    color: rgba(255,255,255,0.2);
    line-height: 1;
  }
  .card-back-corner--tl { top: 12%; left: 14%; }
  .card-back-corner--tr { top: 12%; right: 14%; }
  .card-back-corner--bl { bottom: 12%; left: 14%; }
  .card-back-corner--br { bottom: 12%; right: 14%; }

  /* ── Card Front — cream face ── */
  .card-front {
    position: absolute;
    inset: 0;
    border-radius: 10px;
    overflow: hidden;
    backface-visibility: hidden;
    transform: rotateY(180deg);
    box-shadow: 0 8px 30px rgba(0,0,0,0.6), 0 2px 8px rgba(0,0,0,0.4);
  }
  .card-front-inner {
    width: 100%;
    height: 100%;
    background: #e8dcc8;
    border: 2.5px solid #d4c8b0;
    border-radius: 10px;
    position: relative;
    overflow: hidden;
    background-image:
      repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0,0,0,0.015) 2px, rgba(0,0,0,0.015) 3px),
      repeating-linear-gradient(90deg, transparent, transparent 2px, rgba(0,0,0,0.01) 2px, rgba(0,0,0,0.01) 3px),
      linear-gradient(180deg, #ebe0ce, #ddd0ba);
  }

  .card-front-tl {
    position: absolute;
    top: 6%;
    left: 8%;
    display: flex;
    flex-direction: column;
    align-items: center;
    z-index: 2;
  }
  .card-front-br {
    position: absolute;
    bottom: 6%;
    right: 8%;
    display: flex;
    flex-direction: column;
    align-items: center;
    transform: rotate(180deg);
    z-index: 2;
  }
  .card-rank {
    font-family: 'Bebas Neue', serif;
    font-size: clamp(18px, 3.5vw, 32px);
    font-weight: 700;
    line-height: 1;
    color: var(--card-accent);
  }
  .card-suit-sm {
    font-size: clamp(11px, 2vw, 20px);
    line-height: 1;
    color: var(--card-accent);
    opacity: 0.8;
  }

  .card-center {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 22% 8%;
    text-align: center;
    gap: 4px;
  }
  .card-suit-lg {
    font-size: clamp(24px, 5vw, 48px);
    line-height: 1;
    color: var(--card-accent);
    opacity: 0.5;
  }
  .card-track-name {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(12px, 2.5vw, 22px);
    letter-spacing: 0.12em;
    color: #1a1a1a;
    line-height: 1.1;
  }
  .card-divider {
    width: 50%;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(var(--card-accent-rgb), 0.25), transparent);
    margin: 2px 0;
  }
  .card-track-desc {
    font-family: var(--font-body);
    font-size: clamp(7px, 1.4vw, 12px);
    color: #777;
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    filter: blur(4px);
    user-select: none;
  }
  .card-label {
    position: absolute;
    bottom: 5%;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--font-mono);
    font-size: clamp(5px, 1vw, 9px);
    letter-spacing: 0.18em;
    color: rgba(var(--card-accent-rgb), 0.35);
    white-space: nowrap;
  }
  .card-inner-border {
    position: absolute;
    inset: 7%;
    border: 1px solid rgba(var(--card-accent-rgb), 0.06);
    border-radius: 5px;
    pointer-events: none;
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const hero = document.getElementById('hero')!;
  const cards = gsap.utils.toArray<HTMLElement>('.track-card');
  const flippers = document.querySelectorAll<HTMLElement>('.track-card-flipper');

  // ===== Section header entrance =====
  gsap.from('.tracks-header', {
    scrollTrigger: { trigger: '.tracks-header', start: 'top 85%' },
    opacity: 0, y: 30, duration: 0.8, ease: 'power3.out',
  });

  // ===== Fan → Grid: scroll-linked card transition =====
  // Cards live in the TrackGrid DOM but start positioned at the hero
  // bottom in a fan layout. As user scrolls, they scrub into the grid.

  const fanRotations = [-12, -4, 4, 12];

  // Calculate offsets from each card's natural grid position to the hero fan
  // IMPORTANT: measure rects BEFORE any gsap.set moves them
  const heroRect = hero.getBoundingClientRect();
  const heroCenterX = heroRect.left + heroRect.width / 2;
  const heroBottomY = heroRect.bottom - 80; // 80px above hero bottom edge

  // Cap fan card height so cards don't overwhelm the hero on large screens
  const MAX_FAN_CARD_H = 320;

  const fanPositions = cards.map((card, i) => {
    const rect = card.getBoundingClientRect();
    const cardCenterX = rect.left + rect.width / 2;
    const cardCenterY = rect.top + rect.height / 2;
    const fanSpreadX = (i - 1.5) * rect.width * 0.25;
    return {
      x: heroCenterX + fanSpreadX - cardCenterX,
      y: heroBottomY - cardCenterY,
      rotation: fanRotations[i],
    };
  });

  // Measure card heights BEFORE gsap transforms (scale=1 natural size)
  const cardNaturalHeights = cards.map((card) => (card as HTMLElement).offsetHeight);

  // Initial state: off-screen right, invisible — ready to be dealt in
  const dealOffsetX = window.innerWidth * 0.7;
  cards.forEach((card, i) => {
    gsap.set(card, {
      x: fanPositions[i].x + dealOffsetX,
      y: fanPositions[i].y - 60,
      rotation: fanPositions[i].rotation + 25,
      scale: 1.08,
      transformOrigin: '50% 100%',
      opacity: 0,
    });
  });

  // Deal cards one by one after jackpot win, then set up scroll scrub
  window.addEventListener('jackpot', () => {
    const lastIndex = cards.length - 1;

    cards.forEach((card, i) => {
      const pos = fanPositions[i];
      const dealTl = gsap.timeline({ delay: i * 0.22 });
      // Compute a scale so the card is at most MAX_FAN_CARD_H px tall in fan view
      const naturalH = cardNaturalHeights[i];
      const maxScale = naturalH > 0 ? Math.min(1.1, MAX_FAN_CARD_H / naturalH) : 1.0;

      dealTl
        .to(card, { opacity: 1, duration: 0.1, ease: 'power1.out' })
        .to(card, {
          x: pos.x,
          y: pos.y,
          rotation: pos.rotation,
          scale: maxScale,
          duration: 0.45,
          ease: 'power3.out',
          onComplete: i === lastIndex ? () => {
            // After all cards are dealt, set up the scroll scrub from fan → grid
            cards.forEach((c) => {
              gsap.to(c, {
                x: 0,
                y: 0,
                rotation: 0,
                scale: 1,
                ease: 'none',
                scrollTrigger: {
                  trigger: hero,
                  start: 'bottom bottom',
                  endTrigger: '.track-grid',
                  end: 'top 60%',
                  scrub: true,
                },
              });
            });
            ScrollTrigger.refresh();
          } : undefined,
        }, '<');
    });
  });

  // Flip cards face-up when landing in grid, face-down when scrolling back
  ScrollTrigger.create({
    trigger: '.track-grid',
    start: 'top 58%',
    onEnter: () => {
      flippers.forEach((flipper, i) => {
        setTimeout(() => {
          flipper.setAttribute('data-flip', 'true');
        }, 100 + i * 120);
      });
    },
    onLeaveBack: () => {
      flippers.forEach((flipper, i) => {
        setTimeout(() => {
          flipper.setAttribute('data-flip', 'false');
        }, i * 60);
      });
    },
  });

  // ===== Placemat glow on card hover =====
  const placemats = document.querySelectorAll<HTMLElement>('.placemat');
  placemats.forEach((pm) => {
    const slot = pm.parentElement!;
    slot.addEventListener('mouseenter', () => {
      gsap.to(pm, { borderColor: 'rgba(196,30,58,0.25)', duration: 0.3 });
    });
    slot.addEventListener('mouseleave', () => {
      gsap.to(pm, { borderColor: 'rgba(196,30,58,0.1)', duration: 0.3 });
    });
  });

  // ===== Prize pool + Crash game (synced, plays once) =====
  const prizeEl = document.querySelector('.prize-number') as HTMLElement | null;
  const crashCanvas = document.querySelector('.crash-canvas') as HTMLCanvasElement | null;

  if (crashCanvas && prizeEl) {
    const ctx = crashCanvas.getContext('2d')!;
    let crashAnim: number;
    let hasPlayed = false;
    let animStart = 0;
    const animDuration = 5000;

    // Cashout markers along the curve
    const cashouts = [
      { t: 0.12, name: 'auramaxxer', amount: '$130.00', side: 'right' as const },
      { t: 0.25, name: 'chudlord', amount: '$345.00', side: 'left' as const },
      { t: 0.38, name: 'progsu_dev', amount: '$660.00', side: 'right' as const },
      { t: 0.52, name: 'joey zhang', amount: '$890.00', side: 'left' as const },
      { t: 0.68, name: 'sam altman', amount: '$1,500', side: 'right' as const },
      { t: 0.88, name: 'elon musk', amount: '$2,870', side: 'left' as const },
    ];

    // Y-axis multiplier levels
    const yMultipliers = [
      { value: 1, label: '1.0x' },
      { value: 2, label: '2.0x' },
      { value: 3, label: '3.0x' },
      { value: 4, label: '4.0x' },
      { value: 5, label: '5.0x' },
    ];

    function resizeCrash() {
      const dpr = window.devicePixelRatio;
      const rect = crashCanvas!.parentElement!.getBoundingClientRect();
      crashCanvas!.width = rect.width * dpr;
      crashCanvas!.height = rect.height * dpr;
      crashCanvas!.style.width = rect.width + 'px';
      crashCanvas!.style.height = rect.height + 'px';
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    }

    function curveY(px: number): number {
      return Math.pow(px, 2.8);
    }

    function getPoint(t: number, graphW: number, graphH: number, pad: number, h: number) {
      return {
        x: pad + t * graphW,
        y: (h - pad) - curveY(t) * graphH * 0.85,
      };
    }

    function drawCrash(now: number) {
      const w = crashCanvas!.width / window.devicePixelRatio;
      const h = crashCanvas!.height / window.devicePixelRatio;
      const pad = w < 400 ? 25 : 40;

      const elapsed = now - animStart;
      const rawProgress = Math.min(elapsed / animDuration, 1);
      const drawProgress = 1 - Math.pow(1 - rawProgress, 2);

      const graphW = w - pad * 2;
      const graphH = h - pad * 2;

      ctx.clearRect(0, 0, w, h);

      // --- Grid ---
      // Horizontal grid lines
      ctx.setLineDash([2, 6]);
      ctx.lineWidth = 0.5;
      for (let i = 0; i < yMultipliers.length; i++) {
        const yFrac = yMultipliers[i].value / 5.5;
        const y = (h - pad) - yFrac * graphH;
        ctx.strokeStyle = 'rgba(255,255,255,0.06)';
        ctx.beginPath();
        ctx.moveTo(pad, y);
        ctx.lineTo(w - pad, y);
        ctx.stroke();

        // Y-axis labels
        ctx.font = `${w < 400 ? 7 : 9}px JetBrains Mono, monospace`;
        ctx.fillStyle = 'rgba(255,255,255,0.15)';
        ctx.textAlign = 'right';
        ctx.fillText(yMultipliers[i].label, pad - (w < 400 ? 4 : 8), y + 3);
      }
      ctx.setLineDash([]);

      // Vertical time ticks
      ctx.setLineDash([2, 6]);
      for (let i = 1; i <= 6; i++) {
        const x = pad + (graphW * i / 7);
        ctx.strokeStyle = 'rgba(255,255,255,0.04)';
        ctx.beginPath();
        ctx.moveTo(x, pad);
        ctx.lineTo(x, h - pad);
        ctx.stroke();
      }
      ctx.setLineDash([]);

      // Axes
      ctx.strokeStyle = 'rgba(255,255,255,0.1)';
      ctx.lineWidth = 1;
      ctx.beginPath();
      ctx.moveTo(pad, pad);
      ctx.lineTo(pad, h - pad);
      ctx.lineTo(w - pad, h - pad);
      ctx.stroke();

      // --- Curve ---
      const steps = Math.floor(drawProgress * 400);

      // Wide glow trail
      ctx.beginPath();
      ctx.moveTo(pad, h - pad);
      for (let i = 0; i <= steps; i++) {
        const px = i / 400;
        const pt = getPoint(px, graphW, graphH, pad, h);
        ctx.lineTo(pt.x, pt.y);
      }
      ctx.strokeStyle = 'rgba(196,30,58,0.18)';
      ctx.lineWidth = 20;
      ctx.shadowColor = 'rgba(196,30,58,0.35)';
      ctx.shadowBlur = 40;
      ctx.stroke();
      ctx.shadowBlur = 0;

      // Secondary glow
      ctx.beginPath();
      ctx.moveTo(pad, h - pad);
      for (let i = 0; i <= steps; i++) {
        const px = i / 400;
        const pt = getPoint(px, graphW, graphH, pad, h);
        ctx.lineTo(pt.x, pt.y);
      }
      ctx.strokeStyle = 'rgba(230,57,70,0.2)';
      ctx.lineWidth = 8;
      ctx.stroke();

      // Gradient fill under curve
      const lastPx = steps / 400;
      const lastPt = getPoint(lastPx, graphW, graphH, pad, h);
      ctx.lineTo(lastPt.x, h - pad);
      ctx.closePath();
      const grad = ctx.createLinearGradient(0, pad, 0, h);
      grad.addColorStop(0, 'rgba(196,30,58,0.18)');
      grad.addColorStop(0.4, 'rgba(196,30,58,0.08)');
      grad.addColorStop(1, 'rgba(196,30,58,0)');
      ctx.fillStyle = grad;
      ctx.fill();

      // Main curve line
      ctx.beginPath();
      ctx.moveTo(pad, h - pad);
      for (let i = 0; i <= steps; i++) {
        const px = i / 400;
        const pt = getPoint(px, graphW, graphH, pad, h);
        ctx.lineTo(pt.x, pt.y);
      }
      ctx.strokeStyle = '#E63946';
      ctx.lineWidth = 3;
      ctx.shadowColor = '#E63946';
      ctx.shadowBlur = 12;
      ctx.stroke();
      ctx.shadowBlur = 0;

      // --- Cashout markers ---
      for (const c of cashouts) {
        if (c.t > drawProgress) continue;

        const markerAge = (drawProgress - c.t) / 0.08;
        const alpha = Math.min(markerAge, 1);
        const pt = getPoint(c.t, graphW, graphH, pad, h);

        ctx.globalAlpha = alpha;

        // Dot on curve
        ctx.beginPath();
        ctx.arc(pt.x, pt.y, 4, 0, Math.PI * 2);
        ctx.fillStyle = '#E63946';
        ctx.shadowColor = '#E63946';
        ctx.shadowBlur = 8;
        ctx.fill();
        ctx.shadowBlur = 0;

        // Name + amount as plain text
        const isMobile = w < 400;
        const offsetX = c.side === 'right' ? (isMobile ? 8 : 12) : (isMobile ? -8 : -12);
        ctx.textAlign = c.side === 'right' ? 'left' : 'right';

        ctx.font = `bold ${isMobile ? 8 : 10}px JetBrains Mono, monospace`;
        ctx.fillStyle = 'rgba(255,255,255,0.55)';
        ctx.fillText(c.name, pt.x + offsetX, pt.y - (isMobile ? 4 : 6));

        ctx.font = `${isMobile ? 7 : 9}px JetBrains Mono, monospace`;
        ctx.fillStyle = 'rgba(201,168,76,0.7)';
        ctx.fillText(c.amount, pt.x + offsetX, pt.y + (isMobile ? 6 : 8));

        ctx.globalAlpha = 1;
      }

      // --- Tip dot (pulsing while animating) ---
      if (rawProgress < 1) {
        const pulse = 1 + Math.sin(now * 0.008) * 0.4;

        // Outer pulse ring
        ctx.beginPath();
        ctx.arc(lastPt.x, lastPt.y, 14 * pulse, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(230,57,70,0.06)';
        ctx.fill();

        ctx.beginPath();
        ctx.arc(lastPt.x, lastPt.y, 8 * pulse, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(230,57,70,0.1)';
        ctx.fill();

        // Inner dot
        ctx.beginPath();
        ctx.arc(lastPt.x, lastPt.y, 5, 0, Math.PI * 2);
        ctx.fillStyle = '#E63946';
        ctx.shadowColor = '#E63946';
        ctx.shadowBlur = 30;
        ctx.fill();
        ctx.shadowBlur = 0;

        // White center
        ctx.beginPath();
        ctx.arc(lastPt.x, lastPt.y, 2, 0, Math.PI * 2);
        ctx.fillStyle = '#fff';
        ctx.fill();
      }

      // --- Sync prize number ---
      const currentValue = Math.round(drawProgress * 4300);
      prizeEl!.textContent = currentValue.toLocaleString();

      if (rawProgress < 1) {
        crashAnim = requestAnimationFrame(drawCrash);
      }
    }

    gsap.from('.prize-pool', {
      scrollTrigger: { trigger: '.prize-pool', start: 'top 85%' },
      opacity: 0, y: 20, duration: 0.6, ease: 'power3.out',
    });

    const crashObserver = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting && !hasPlayed) {
          hasPlayed = true;
          resizeCrash();
          animStart = performance.now();
          crashAnim = requestAnimationFrame(drawCrash);
          window.addEventListener('resize', () => {
            resizeCrash();
            if (performance.now() - animStart >= animDuration) {
              drawCrash(animStart + animDuration);
            }
          });
        }
      });
    }, { threshold: 0.2 });
    crashObserver.observe(crashCanvas);
  }

</script>
