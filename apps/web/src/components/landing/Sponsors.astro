---
// [04] Sponsors

const tiers = [
  {
    name: 'DIAMOND',
    color: 'text-gold',
    border: 'border-gold-dim/20',
    sponsors: [{ name: 'Your Company Here', logo: null }],
  },
  {
    name: 'GOLD',
    color: 'text-red',
    border: 'border-red/15',
    sponsors: [{ name: 'Sponsor 1', logo: null }, { name: 'Sponsor 2', logo: null }],
  },
  {
    name: 'SILVER',
    color: 'text-gray',
    border: 'border-border',
    sponsors: [{ name: 'Sponsor 3', logo: null }, { name: 'Sponsor 4', logo: null }, { name: 'Sponsor 5', logo: null }],
  },
];
---

<section id="sponsors" class="relative bg-black px-4 py-24 md:py-32">
  <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-border-light/60 to-transparent"></div>

  <div class="mx-auto max-w-5xl">
    <div class="sponsors-header mb-14 text-center">
      <div class="flex items-center justify-center gap-4 font-mono text-[10px] tracking-[0.3em] text-gray-darker">
        <span class="h-px w-12 bg-gradient-to-r from-transparent to-border"></span>
        <span class="text-red/60">[04]</span>
        <span>SPONSORS</span>
        <span class="h-px w-12 bg-gradient-to-l from-transparent to-border"></span>
      </div>
      <h2 class="mt-5 font-display text-5xl tracking-wide text-white-pure md:text-6xl">
        THE HOUSE BACKERS
      </h2>
      <p class="mx-auto mt-4 max-w-md font-body text-sm leading-relaxed text-gray-dark">
        These orgs keep the table funded.
      </p>
    </div>

    <div class="sponsors-grid space-y-10">
      {tiers.map((tier) => (
        <div>
          <p class={`mb-4 text-center font-mono text-[8px] tracking-[0.4em] ${tier.color}/60`}>
            &#9670; {tier.name} TIER &#9670;
          </p>
          <div class={`grid gap-3 ${
            tier.sponsors.length === 1 ? 'grid-cols-1 max-w-md mx-auto' :
            tier.sponsors.length === 2 ? 'grid-cols-2 max-w-2xl mx-auto' :
            'grid-cols-2 md:grid-cols-3'
          }`}>
            {tier.sponsors.map((sponsor) => (
              <div class={`group flex items-center justify-center border ${tier.border} bg-black-card/50 p-10 transition-all duration-300 hover:bg-black-card hover:shadow-[0_4px_20px_rgba(0,0,0,0.3)]`}>
                {sponsor.logo ? (
                  <img src={sponsor.logo} alt={sponsor.name} class="h-10 max-w-[160px] object-contain opacity-40 grayscale transition-all duration-300 group-hover:opacity-70 group-hover:grayscale-0" />
                ) : (
                  <span class="font-body text-sm text-gray-darker transition-colors duration-300 group-hover:text-gray-dark">{sponsor.name}</span>
                )}
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>

    <div class="sponsors-cta mt-14 text-center">
      <p class="font-body text-[13px] text-gray-dark">want to sponsor hacklanta?</p>
      <a
        href="mailto:sponsor@hacklanta.com"
        class="group mt-4 inline-flex items-center gap-2 border border-red/30 bg-red/[0.06] px-7 py-2.5 font-body text-[11px] font-semibold tracking-[0.15em] text-red/80 transition-all duration-300 hover:border-red/50 hover:text-red hover:shadow-[0_0_24px_rgba(196,30,58,0.1)]"
      >
        <span>CONTACT US</span>
        <span class="transition-transform duration-300 group-hover:translate-x-0.5">&rarr;</span>
      </a>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  gsap.from('.sponsors-header', {
    scrollTrigger: { trigger: '.sponsors-header', start: 'top 80%' },
    opacity: 0, y: 30, duration: 0.8,
  });
  gsap.from('.sponsors-grid', {
    scrollTrigger: { trigger: '.sponsors-grid', start: 'top 80%' },
    opacity: 0, y: 30, duration: 0.8,
  });
  gsap.from('.sponsors-cta', {
    scrollTrigger: { trigger: '.sponsors-cta', start: 'top 85%' },
    opacity: 0, y: 20, duration: 0.6,
  });
</script>
