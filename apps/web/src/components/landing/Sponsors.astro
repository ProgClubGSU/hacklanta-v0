          <span class="absolute inset-0 -translate-x-full bg-gradient-to-r from-transparent via-gold-dim/[0.1] to-transparent transition-transform duration-700 ease-out group-hover:translate-x-full"></span>
        </a>
        <a
          href="https://docs.google.com/forms/d/e/1FAIpQLSdiYJGmNAEw3oDQVBEwQgHL3IT--F7_bGgeaLbV_-YU3WG5fg/viewform?usp=header"
