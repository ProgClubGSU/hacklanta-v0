---
// [04] Sponsors — luxury casino noir
---

<section id="sponsors" class="relative overflow-hidden bg-black px-4 py-16 md:py-24">
  <!-- Top gradient border -->
  <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-red/30 to-transparent"></div>

  <!-- Ambient red glow — left -->
  <div
    class="pointer-events-none absolute left-[-8%] top-[40%] h-[600px] w-[600px] rounded-full"
    style="background: radial-gradient(circle, rgba(196,30,58,0.05) 0%, rgba(196,30,58,0.012) 40%, transparent 65%);"
  ></div>
  <!-- Gold glow — top right for Diamond tier -->
  <div
    class="pointer-events-none absolute right-[10%] top-[5%] h-[400px] w-[400px] rounded-full opacity-[0.04] blur-[100px]"
    style="background: radial-gradient(circle, rgba(201,168,76,0.5) 0%, transparent 70%);"
  ></div>

  <!-- CSS 3D Floating Dice -->
  <div class="pointer-events-none absolute inset-0 overflow-hidden sponsor-floaters" aria-hidden="true" style="perspective: 900px;">
    <!-- Die 1 — top left, showing faces 5 (front), 3 (top), 2 (right) -->
    <div
      class="sponsor-floater absolute left-[3%] top-[8%] hidden md:block"
      style="animation: dice-float 7.5s ease-in-out infinite;"
    >
      <div class="die die--lg" style="--dice-base-transform: rotateX(-25deg) rotateY(30deg) rotateZ(8deg); transform: var(--dice-base-transform);">
        <div class="die-face die-face--front die-face--lg">
          <i class="pip pip--lg" style="grid-area: 1/1;"></i>
          <i class="pip pip--lg" style="grid-area: 1/3;"></i>
          <i class="pip pip--lg" style="grid-area: 2/2;"></i>
          <i class="pip pip--lg" style="grid-area: 3/1;"></i>
          <i class="pip pip--lg" style="grid-area: 3/3;"></i>
        </div>
        <div class="die-face die-face--top die-face--lg">
          <i class="pip pip--lg" style="grid-area: 1/3;"></i>
          <i class="pip pip--lg" style="grid-area: 2/2;"></i>
          <i class="pip pip--lg" style="grid-area: 3/1;"></i>
        </div>
        <div class="die-face die-face--right die-face--lg">
          <i class="pip pip--lg" style="grid-area: 1/3;"></i>
          <i class="pip pip--lg" style="grid-area: 3/1;"></i>
        </div>
        <div class="die-face die-face--bottom die-face--lg"></div>
      </div>
    </div>

    <!-- Die 2 — right side, showing faces 4 (front), 1 (top), 6 (left) -->
    <div
      class="sponsor-floater absolute right-[4%] top-[18%] hidden md:block"
      style="animation: dice-float 8s ease-in-out infinite 1.5s;"
    >
      <div class="die die--md" style="--dice-base-transform: rotateX(-20deg) rotateY(-25deg) rotateZ(-6deg); transform: var(--dice-base-transform);">
        <div class="die-face die-face--front die-face--md">
          <i class="pip pip--md" style="grid-area: 1/1;"></i>
          <i class="pip pip--md" style="grid-area: 1/3;"></i>
          <i class="pip pip--md" style="grid-area: 3/1;"></i>
          <i class="pip pip--md" style="grid-area: 3/3;"></i>
        </div>
        <div class="die-face die-face--top die-face--md">
          <i class="pip pip--md" style="grid-area: 2/2;"></i>
        </div>
        <div class="die-face die-face--left die-face--md">
          <i class="pip pip--md" style="grid-area: 1/1;"></i>
          <i class="pip pip--md" style="grid-area: 1/3;"></i>
          <i class="pip pip--md" style="grid-area: 2/1;"></i>
          <i class="pip pip--md" style="grid-area: 2/3;"></i>
          <i class="pip pip--md" style="grid-area: 3/1;"></i>
          <i class="pip pip--md" style="grid-area: 3/3;"></i>
        </div>
        <div class="die-face die-face--bottom die-face--md"></div>
      </div>
    </div>

    <!-- Die 3 — bottom left, showing faces 6 (front), 2 (top), 1 (right) -->
    <div
      class="sponsor-floater absolute bottom-[12%] left-[6%] hidden lg:block"
      style="animation: dice-float 6.5s ease-in-out infinite 0.5s;"
    >
      <div class="die die--sm" style="--dice-base-transform: rotateX(-18deg) rotateY(22deg) rotateZ(15deg); transform: var(--dice-base-transform);">
        <div class="die-face die-face--front die-face--sm">
          <i class="pip pip--sm" style="grid-area: 1/1;"></i>
          <i class="pip pip--sm" style="grid-area: 1/3;"></i>
          <i class="pip pip--sm" style="grid-area: 2/1;"></i>
          <i class="pip pip--sm" style="grid-area: 2/3;"></i>
          <i class="pip pip--sm" style="grid-area: 3/1;"></i>
          <i class="pip pip--sm" style="grid-area: 3/3;"></i>
        </div>
        <div class="die-face die-face--top die-face--sm">
          <i class="pip pip--sm" style="grid-area: 1/3;"></i>
          <i class="pip pip--sm" style="grid-area: 3/1;"></i>
        </div>
        <div class="die-face die-face--right die-face--sm">
          <i class="pip pip--sm" style="grid-area: 2/2;"></i>
        </div>
        <div class="die-face die-face--bottom die-face--sm"></div>
      </div>
    </div>
  </div>

  <div class="relative z-10 mx-auto max-w-5xl">
    <div class="sponsors-header mb-16 text-center">
      <div class="flex items-center justify-center gap-4 font-mono text-[11px] tracking-[0.3em] text-gray-400">
        <span class="h-px w-16 bg-gradient-to-r from-transparent to-border/80"></span>
        <span class="text-red/80">[03]</span>
        <span>SPONSORS</span>
        <span class="h-px w-16 bg-gradient-to-l from-transparent to-border/80"></span>
      </div>
      <h2 class="section-heading mt-6 font-serif italic text-[clamp(2.2rem,8vw,5rem)] leading-[0.9] tracking-tight text-white">
        The House Backers
      </h2>
      <p class="mx-auto mt-5 max-w-md font-body text-sm leading-relaxed text-gray-dark">
        These orgs keep the table funded.
      </p>
    </div>

    <!-- Sponsor tiers -->
    <div class="sponsors-grid space-y-16">

      <!-- TITLE PARTNER — Cox -->
      <div class="text-center">
        <p class="mb-4 font-serif italic text-[clamp(1.8rem,5vw,3.5rem)] leading-[1] tracking-tight text-[#ffd700]" style="text-shadow: 0 0 30px rgba(255,215,0,0.15);">
          Title Partner
        </p>
        <div class="mx-auto max-w-3xl">
          <a href="https://www.coxautoinc.com/" target="_blank" rel="noopener noreferrer" class="group relative flex items-center justify-center overflow-hidden border border-[#ffd700]/20 bg-black/50 p-14 transition-all duration-500 hover:border-[#ffd700]/40 hover:shadow-[0_8px_60px_rgba(255,215,0,0.1)] md:p-20">
            <img src="/images/sponsors/cox-icon.svg" alt="Cox" class="h-20 w-auto opacity-90 transition-opacity group-hover:opacity-100 md:h-28" />
            <span class="absolute inset-0 -translate-x-full bg-gradient-to-r from-transparent via-[#ffd700]/[0.04] to-transparent transition-transform duration-700 ease-out group-hover:translate-x-full"></span>
          </a>
        </div>
      </div>

      <!-- Silver — Nexlayer -->
      <div class="mx-auto max-w-xl text-center">
        <p class="mb-4 font-serif italic text-3xl tracking-tight text-white/60 md:text-4xl" style="text-shadow: 0 0 20px rgba(200,200,220,0.1);">
          Silver
        </p>
        <a href="https://nexlayer.com/" target="_blank" rel="noopener noreferrer" class="group relative flex items-center justify-center overflow-hidden border border-white/10 bg-black/50 p-14 transition-all duration-500 hover:border-white/20 hover:shadow-[0_8px_40px_rgba(255,255,255,0.04)]">
          <img src="/images/sponsors/nexlayer-dark.png" alt="Nexlayer" class="h-10 w-auto opacity-90 transition-opacity group-hover:opacity-100 md:h-14" />
          <span class="absolute inset-0 -translate-x-full bg-gradient-to-r from-transparent via-white/[0.03] to-transparent transition-transform duration-700 ease-out group-hover:translate-x-full"></span>
        </a>
      </div>

      <!-- SUPPORTERS -->
      <div>
        <p class="mb-8 text-center font-serif italic text-xl tracking-tight text-white md:text-2xl">
          Supporters
        </p>
        <div class="mx-auto flex max-w-2xl flex-col gap-4">

          <!-- Joey Zhang -->
