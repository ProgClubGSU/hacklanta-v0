</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  gsap.from('.sponsors-header', {
    scrollTrigger: { trigger: '.sponsors-header', start: 'top 80%' },
    opacity: 0, y: 40, duration: 1, ease: 'power3.out',
  });
  gsap.from('.sponsors-grid', {
    scrollTrigger: { trigger: '.sponsors-grid', start: 'top 82%' },
    opacity: 0, y: 40, duration: 1, ease: 'power3.out',
  });
  gsap.from('.sponsors-cta', {
    scrollTrigger: { trigger: '.sponsors-cta', start: 'top 85%' },
    opacity: 0, y: 25, duration: 0.8, ease: 'power3.out',
  });

  // ===== Parallax on floating elements =====
  const sponsorSection = document.getElementById('sponsors')!;
  const sponsorFloaters = sponsorSection.querySelectorAll<HTMLElement>('.sponsor-floater');
  const sponsorSpeeds = [0.08, -0.06, 0.07];

  const sponsorAnims = Array.from(sponsorFloaters).map((el) => ({
    x: gsap.quickTo(el, 'x', { duration: 0.6, ease: 'power2.out' }),
    y: gsap.quickTo(el, 'y', { duration: 0.6, ease: 'power2.out' }),
  }));

  sponsorSection.addEventListener('mousemove', (e) => {
    const rect = sponsorSection.getBoundingClientRect();
    const nx = ((e.clientX - rect.left) / rect.width - 0.5) * 2;
    const ny = ((e.clientY - rect.top) / rect.height - 0.5) * 2;
    sponsorAnims.forEach((anim, i) => {
      const s = sponsorSpeeds[i];
      anim.x(nx * rect.width * Math.abs(s) * Math.sign(s));
      anim.y(ny * rect.height * Math.abs(s) * 0.5 * Math.sign(s));
    });
  });
  sponsorSection.addEventListener('mouseleave', () => {
    sponsorAnims.forEach((a) => { a.x(0); a.y(0); });
  });

  // ===== Scroll parallax =====
  const sponsorScrollSpeeds = [50, -60, 45];
  sponsorFloaters.forEach((el, i) => {
    gsap.to(el, {
      yPercent: sponsorScrollSpeeds[i],
      ease: 'none',
      scrollTrigger: {
        trigger: sponsorSection,
        start: 'top bottom',
        end: 'bottom top',
        scrub: true,
      },
    });
  });
</script>

