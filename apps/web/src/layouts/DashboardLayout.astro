---
import BaseLayout from './BaseLayout.astro';
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = 'Dashboard — Hacklanta' } = Astro.props;
---

<BaseLayout title={title}>
  <div class="relative min-h-screen bg-black overflow-x-hidden">

    <!-- Ambient glows -->
    <div
      class="pointer-events-none fixed right-0 top-0 h-[500px] w-[500px] opacity-60"
      style="background: radial-gradient(ellipse at top right, rgba(196,30,58,0.07) 0%, transparent 65%);"
    ></div>
    <div
      class="pointer-events-none fixed bottom-0 left-0 h-[400px] w-[400px] opacity-50"
      style="background: radial-gradient(ellipse at bottom left, rgba(201,168,76,0.05) 0%, transparent 65%);"
    ></div>

    <!-- Faint suit watermarks -->
    <span
      class="pointer-events-none fixed right-6 top-20 select-none font-display text-[18rem] leading-none text-white/[0.012]"
      aria-hidden="true"
    >♠</span>
    <span
      class="pointer-events-none fixed -bottom-8 left-4 select-none font-display text-[14rem] leading-none text-gold/[0.025]"
      aria-hidden="true"
    >♦</span>

    <main class="relative z-10 mx-auto w-full max-w-7xl overflow-x-hidden px-4 py-8 sm:px-6">
      <slot />
    </main>
  </div>
</BaseLayout>
