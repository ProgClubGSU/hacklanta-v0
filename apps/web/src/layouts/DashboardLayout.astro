---
import BaseLayout from './BaseLayout.astro';
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = 'Dashboard — Hacklanta' } = Astro.props;
---

<BaseLayout title={title}>
  <div class="min-h-screen bg-base-black">
    <nav class="border-b border-base-border px-6 py-4">
      <span class="font-mono text-neon-green">hacklanta</span>
      <span class="text-text-muted"> // dashboard</span>
    </nav>
    <main class="mx-auto max-w-7xl px-6 py-8">
      <slot />
    </main>
  </div>
</BaseLayout>
