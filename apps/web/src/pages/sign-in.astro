---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SignIn } from '@clerk/astro/components';
---

<BaseLayout title="Sign In — Hacklanta">
  <div class="min-h-screen flex items-center justify-center px-4">
    <div class="w-full max-w-md">
      <div class="text-center mb-8">
        <h1 class="text-4xl font-bold mb-2" style="color: #00ff88; font-family: 'Inter', ui-sans-serif, system-ui, sans-serif;">
          $ sign_in
        </h1>
        <p class="text-sm" style="color: #666666; font-family: 'JetBrains Mono', ui-monospace, monospace;">
          // authenticate to place your bet
        </p>
      </div>
      <div class="clerk-wrapper">
        <SignIn afterSignInUrl="/apply" />
      </div>
      <div class="mt-6 text-center">
        <p class="text-sm" style="color: #666666; font-family: 'JetBrains Mono', ui-monospace, monospace;">
          // new player? <a href="/sign-up" class="hover:underline" style="color: #00ff88;">$ create_account</a>
        </p>
      </div>
    </div>
  </div>
</BaseLayout>

<style is:global>
  /* Clerk component overrides for casino theme */
  .cl-rootBox {
    width: 100%;
  }

  .cl-card {
    background-color: #1a1a1a !important;
    border: 1px solid #2a2a2a !important;
    box-shadow: 0 10px 40px rgba(0, 255, 136, 0.1) !important;
  }

  .cl-headerTitle {
    color: #f5f5f5 !important;
    font-family: 'JetBrains Mono', ui-monospace, monospace !important;
  }

  .cl-headerSubtitle {
    color: #666666 !important;
    font-family: 'JetBrains Mono', ui-monospace, monospace !important;
    font-size: 0.875rem !important;
  }

  .cl-socialButtonsBlockButton {
    background-color: #0a0a0a !important;
    border: 1px solid #2a2a2a !important;
    color: #f5f5f5 !important;
    transition: all 0.2s !important;
  }

  .cl-socialButtonsBlockButton:hover {
    border-color: #00ff88 !important;
    background-color: #121212 !important;
  }

  .cl-formButtonPrimary {
    background-color: #00ff88 !important;
    color: #0a0a0a !important;
    font-weight: 600 !important;
    box-shadow: 0 10px 30px rgba(0, 255, 136, 0.3) !important;
    transition: all 0.2s !important;
  }

  .cl-formButtonPrimary:hover {
    background-color: #00cc6a !important;
    box-shadow: 0 15px 40px rgba(0, 255, 136, 0.5) !important;
  }

  .cl-formFieldInput {
    background-color: #0a0a0a !important;
    border: 1px solid #2a2a2a !important;
    color: #f5f5f5 !important;
    font-family: 'JetBrains Mono', ui-monospace, monospace !important;
  }

  .cl-formFieldInput:focus {
    border-color: #00ff88 !important;
    box-shadow: 0 0 0 1px #00ff88 !important;
  }

  .cl-formFieldLabel {
    color: #a0a0a0 !important;
    font-family: 'JetBrains Mono', ui-monospace, monospace !important;
    font-size: 0.875rem !important;
  }

  .cl-footerActionLink {
    color: #00ff88 !important;
    font-family: 'JetBrains Mono', ui-monospace, monospace !important;
  }

  .cl-footerActionLink:hover {
    color: #00cc6a !important;
  }

  .cl-footerActionText {
    color: #666666 !important;
    font-family: 'JetBrains Mono', ui-monospace, monospace !important;
  }

  .cl-identityPreviewText {
    color: #f5f5f5 !important;
    font-family: 'JetBrains Mono', ui-monospace, monospace !important;
  }

  .cl-formResendCodeLink {
    color: #00ff88 !important;
  }

  .cl-formResendCodeLink:hover {
    color: #00cc6a !important;
  }

  .cl-otpCodeFieldInput {
    background-color: #0a0a0a !important;
    border: 1px solid #2a2a2a !important;
    color: #00ff88 !important;
    font-family: 'JetBrains Mono', ui-monospace, monospace !important;
    font-size: 1.25rem !important;
  }

  .cl-otpCodeFieldInput:focus {
    border-color: #00ff88 !important;
  }

  .cl-dividerRow {
    color: #666666 !important;
  }

  .cl-internal-b3fm6y {
    color: #666666 !important;
  }
</style>
