---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SignUp as ClerkSignUp } from '@clerk/astro/components';
---

<BaseLayout title="Sign Up — Hacklanta">
  <div class="min-h-screen bg-black flex flex-col">

    <!-- Ambient glows -->
    <div
      class="pointer-events-none fixed right-0 top-0 h-[500px] w-[500px] opacity-60"
      style="background: radial-gradient(ellipse at top right, rgba(196,30,58,0.07) 0%, transparent 65%);"
    ></div>
    <div
      class="pointer-events-none fixed bottom-0 left-0 h-[400px] w-[400px] opacity-50"
      style="background: radial-gradient(ellipse at bottom left, rgba(201,168,76,0.05) 0%, transparent 65%);"
    ></div>

    <!-- Faint suit watermarks -->
    <span class="pointer-events-none fixed right-6 top-20 select-none font-display text-[18rem] leading-none" style="color: rgba(255,255,255,0.012);" aria-hidden="true">♠</span>
    <span class="pointer-events-none fixed -bottom-8 left-4 select-none font-display text-[14rem] leading-none" style="color: rgba(201,168,76,0.025);" aria-hidden="true">♦</span>

    <div class="relative z-10 flex flex-1 flex-col items-center justify-center px-4 py-12">

      <!-- Header label -->
      <div class="mb-6 text-center">
        <p class="font-mono text-[10px] tracking-[0.35em] uppercase" style="color: #4a4a4a;">
          HACKLANTA — APPLICATION
        </p>
      </div>

      <!-- Title -->
      <div class="mb-8 text-center">
        <h1 class="font-display text-4xl tracking-widest text-white mb-3">
          CREATE ACCOUNT
        </h1>
        <div class="mx-auto h-px w-10" style="background: rgba(196,30,58,0.5);"></div>
        <p class="mt-4 font-body text-base" style="color: #555;">
          Get in the game. It only takes a minute.
        </p>
      </div>

      <!-- Clerk component -->
      <div class="w-full max-w-md clerk-wrapper">
        <ClerkSignUp fallbackRedirectUrl="/apply" />
      </div>

      <!-- Back link -->
      <p class="mt-8 font-mono text-xs" style="color: #3a3a3a;">
        <a href="/" class="transition-colors hover:text-white/40">← back to home</a>
      </p>

    </div>
  </div>
</BaseLayout>

<style is:global>
  .cl-rootBox {
    width: 100%;
    display: flex;
    justify-content: center;
  }

  .cl-card {
    width: 100%;
    background: #000 !important;
    background-image: none !important;
    border: 1px solid #1e1e1e !important;
    border-radius: 0 !important;
    box-shadow: none !important;
  }

  .cl-headerTitle {
    color: #f5f5f5 !important;
    font-family: var(--font-display, 'Georgia'), serif !important;
    letter-spacing: 0.1em !important;
  }

  .cl-headerSubtitle {
    color: #555 !important;
    font-size: 0.875rem !important;
  }

  .cl-socialButtonsBlockButton {
    background: #000 !important;
    background-image: none !important;
    border: 1px solid #1e1e1e !important;
    border-radius: 0 !important;
    color: #f5f5f5 !important;
    transition: all 0.2s !important;
  }

  .cl-socialButtonsBlockButton:hover {
    border-color: rgba(196, 30, 58, 0.5) !important;
    background: rgba(196, 30, 58, 0.05) !important;
  }

  .cl-formButtonPrimary {
    background: rgba(196, 30, 58, 0.12) !important;
    background-image: none !important;
    border: 1px solid rgba(196, 30, 58, 0.6) !important;
    border-radius: 0 !important;
    color: #e8e8e8 !important;
    font-family: var(--font-mono, monospace) !important;
    font-size: 0.7rem !important;
    font-weight: 600 !important;
    letter-spacing: 0.2em !important;
    text-transform: uppercase !important;
    box-shadow: none !important;
    transition: all 0.2s !important;
  }

  .cl-formButtonPrimary:hover {
    background: rgba(196, 30, 58, 0.22) !important;
    border-color: #c41e3a !important;
    box-shadow: 0 0 16px rgba(196, 30, 58, 0.15) !important;
  }

  .cl-formFieldInput {
    background: #000 !important;
    background-image: none !important;
    border: 1px solid #1e1e1e !important;
    border-radius: 0 !important;
    color: #f5f5f5 !important;
  }

  .cl-formFieldInput:focus {
    border-color: rgba(196, 30, 58, 0.6) !important;
    box-shadow: 0 0 0 1px rgba(196, 30, 58, 0.12) !important;
  }

  .cl-formFieldLabel {
    color: #888 !important;
    font-size: 0.75rem !important;
    letter-spacing: 0.1em !important;
    text-transform: uppercase !important;
  }

  .cl-footerActionLink {
    color: #c41e3a !important;
  }

  .cl-footerActionLink:hover {
    color: #e0304a !important;
  }

  .cl-footerActionText {
    color: #555 !important;
  }

  .cl-dividerLine {
    background-color: #1e1e1e !important;
  }

  .cl-dividerText {
    color: #555 !important;
  }

  .cl-identityPreviewText {
    color: #f5f5f5 !important;
  }

  .cl-formResendCodeLink {
    color: #c41e3a !important;
  }

  .cl-otpCodeFieldInput {
    background: #000 !important;
    background-image: none !important;
    border: 1px solid #1e1e1e !important;
    border-radius: 0 !important;
    color: #c41e3a !important;
    font-size: 1.25rem !important;
  }

  .cl-otpCodeFieldInput:focus {
    border-color: #c41e3a !important;
  }

  /* Kill cardBox shadow that creates the faint 1px outline */
  .cl-cardBox {
    box-shadow: none !important;
  }

  /* Hide Secured by Clerk + Development mode footer section */
  .cl-footer > *:last-child,
  .cl-internal-1dauvpw,
  .cl-internal-b3fm6y,
  .cl-badge,
  [data-localization-key="badge__devMode"] {
    display: none !important;
  }
</style>
