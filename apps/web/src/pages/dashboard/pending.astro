---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { checkDashboardAccess } from '../../lib/dashboard-gate';

const { userId } = await Astro.locals.auth();
if (!userId) {
  return Astro.redirect('/sign-in');
}

// Gate: prevent post-cutoff users without applications from sitting on this page
const gate = await checkDashboardAccess(userId);

if (gate.status === 'accepted') {
  return Astro.redirect('/dashboard/team');
}
if (gate.status === 'no-application') {
  return Astro.redirect('/dashboard/no-application');
}
---

<BaseLayout title="Application Pending | Hacklanta">
  <main class="min-h-screen bg-black px-4 py-16 font-body">
    <div class="mx-auto max-w-4xl">
      <!-- Header -->
      <div
        class="mb-8 overflow-hidden rounded-lg border border-primary/20 bg-[linear-gradient(135deg,#161313_0%,#191414_58%,#241414_100%)] shadow-[0_16px_40px_rgba(0,0,0,0.28)]"
      >
        <div class="flex items-center justify-between gap-6 px-4 py-3 sm:px-6">
          <a
            href="/"
            class="shrink-0 transition-opacity hover:opacity-85"
            aria-label="Hacklanta home"
          >
            <img src="/logo_trimmed.png" alt="Hacklanta" class="h-6 w-auto object-contain sm:h-7" />
          </a>
          <div class="flex items-center gap-4">
            <a
              href="/"
              class="font-body text-xs font-bold uppercase tracking-[0.08em] text-white/75 transition-colors hover:text-white"
            >
              Home
            </a>
          </div>
        </div>
      </div>

      <!-- Pending Status Card -->
      <div
        class="relative overflow-hidden rounded-lg border border-[#c9a84c]/30 bg-[linear-gradient(135deg,#161313_0%,#191414_58%,#241414_100%)] p-8 sm:p-12"
      >
        <div
          class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(201,168,76,0.12),transparent_40%)]"
        >
        </div>

        <div class="relative z-10 text-center">
          <!-- Icon -->
          <div class="mb-6 inline-flex items-center justify-center">
            <div class="relative">
              <div class="absolute inset-0 animate-ping rounded-full bg-[#c9a84c]/20"></div>
              <div
                class="relative flex h-20 w-20 items-center justify-center rounded-full border-2 border-[#c9a84c]/40 bg-[#c9a84c]/10"
              >
                <svg
                  class="h-10 w-10 text-[#c9a84c]"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
              </div>
            </div>
          </div>

          <!-- Status Label -->
          <div class="mb-3 font-mono text-xs uppercase tracking-[0.28em] text-[#c9a84c]">
            System Status
          </div>

          <!-- Main Heading -->
          <h1
            class="mb-4 font-display text-4xl uppercase leading-tight tracking-[-0.04em] text-white sm:text-5xl"
          >
            Application<br />
            <span class="text-[#c9a84c]">Under Review</span>
          </h1>

          <!-- Description -->
          <p
            class="mx-auto mb-8 max-w-2xl font-body text-base leading-relaxed text-white/70 sm:text-lg"
          >
            Thanks for applying to Hacklanta! Your application is currently being reviewed by our
            team. You'll receive an email once your application has been processed.
          </p>

          <!-- Info Boxes -->
          <div class="mx-auto grid max-w-2xl gap-4 sm:grid-cols-2">
            <div class="rounded-lg border border-white/10 bg-black/40 p-5 text-left">
              <div class="mb-2 flex items-center gap-2">
                <svg
                  class="h-5 w-5 text-[#c9a84c]"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                  ></path>
                </svg>
                <h3 class="font-mono text-xs uppercase tracking-wider text-white/90">
                  What's Next?
                </h3>
              </div>
              <p class="font-body text-sm text-white/60">
                Keep an eye on your email. We'll notify you as soon as your application is reviewed.
              </p>
            </div>

            <div class="rounded-lg border border-white/10 bg-black/40 p-5 text-left">
              <div class="mb-2 flex items-center gap-2">
                <svg
                  class="h-5 w-5 text-[#c9a84c]"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <h3 class="font-mono text-xs uppercase tracking-wider text-white/90">How Long?</h3>
              </div>
              <p class="font-body text-sm text-white/60">
                Most applications are reviewed within 24-48 hours. Hang tight!
              </p>
            </div>
          </div>

          <!-- CTA -->
          <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
            <a
              href="/"
              class="inline-flex items-center gap-2 rounded-lg border border-white/10 bg-white/5 px-6 py-3 font-body text-sm font-semibold uppercase tracking-wider text-white/80 transition-colors hover:border-white/20 hover:bg-white/10 hover:text-white"
            >
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
              </svg>
              Back to Home
            </a>
          </div>

          <!-- Terminal-style accent -->
          <div
            class="mt-8 rounded border border-white/10 bg-black/60 p-4 font-mono text-xs text-white/40"
          >
            <span class="text-[#c9a84c]">$</span> access_status --user=current
            <br />
            <span class="text-white/60">&gt; STATUS: PENDING_APPROVAL</span>
            <br />
            <span class="text-white/60">&gt; ACCESS_LEVEL: LIMITED</span>
            <br />
            <span class="text-white/60">&gt; MESSAGE: Awaiting admin authorization...</span>
          </div>
        </div>

        <!-- Decorative poker suit -->
        <div
          class="pointer-events-none absolute bottom-6 right-6 select-none text-6xl text-white/5"
        >
          ♠
        </div>
      </div>

      <!-- FAQ Section -->
      <div class="mt-8 rounded-lg border border-white/10 bg-black/60 p-6">
        <h2 class="mb-4 font-display text-2xl uppercase tracking-[-0.04em] text-white">
          Frequently Asked Questions
        </h2>
        <div class="space-y-4">
          <div>
            <h3 class="mb-1 font-body font-semibold text-white/90">Can I edit my application?</h3>
            <p class="font-body text-sm text-white/60">
              Not at this time. If you need to update critical information, please reach out to our
              team.
            </p>
          </div>
          <div>
            <h3 class="mb-1 font-body font-semibold text-white/90">
              What if I don't get accepted?
            </h3>
            <p class="font-body text-sm text-white/60">
              We review all applications fairly. If capacity is limited, we may need to waitlist
              some applicants.
            </p>
          </div>
          <div>
            <h3 class="mb-1 font-body font-semibold text-white/90">Need help?</h3>
            <p class="font-body text-sm text-white/60">
              Contact us at <a href="mailto:official@progsu.com" class="text-[#c9a84c] underline"
                >official@progsu.com</a
              >
            </p>
          </div>
        </div>
      </div>
    </div>
  </main>

  <style>
    @keyframes ping {
      75%,
      100% {
        transform: scale(2);
        opacity: 0;
      }
    }
    .animate-ping {
      animation: ping 2s cubic-bezier(0, 0, 0.2, 1) infinite;
    }
  </style>
</BaseLayout>
