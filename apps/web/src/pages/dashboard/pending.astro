---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { checkDashboardAccess } from '../../lib/dashboard-gate';

const { userId } = await Astro.locals.auth();
if (!userId) {
  return Astro.redirect('/sign-in');
}

// Gate: prevent post-cutoff users without applications from sitting on this page
const gate = await checkDashboardAccess(userId);

if (gate.status === 'accepted') {
  return Astro.redirect('/dashboard/team');
}
if (gate.status === 'no-application') {
  return Astro.redirect('/dashboard/no-application');
}
---

<BaseLayout title="Application Pending | Hacklanta">
  <main class="gate-page relative flex min-h-screen flex-col items-center justify-center overflow-hidden bg-[#121212] px-4 py-12 sm:px-6 sm:py-20">

    <!-- Grid background -->
    <div class="pointer-events-none absolute inset-0 gate-grid opacity-[0.35]" aria-hidden="true"></div>

    <!-- Radial glow -->
    <div class="pointer-events-none absolute inset-0" aria-hidden="true">
      <div class="absolute left-1/2 top-1/2 h-[600px] w-[600px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-[radial-gradient(circle,rgba(196,30,58,0.06)_0%,transparent_70%)] sm:h-[800px] sm:w-[800px]"></div>
    </div>

    <!-- Decorative compass / star — hidden on small screens -->
    <div class="pointer-events-none absolute right-[8%] top-[12%] hidden select-none opacity-[0.07] sm:block" aria-hidden="true">
      <svg width="180" height="180" viewBox="0 0 100 100" fill="none" stroke="currentColor" class="text-red">
        <circle cx="50" cy="50" r="35" stroke-width="0.5" />
        <circle cx="50" cy="50" r="25" stroke-width="0.3" />
        <line x1="50" y1="10" x2="50" y2="90" stroke-width="0.5" />
        <line x1="10" y1="50" x2="90" y2="50" stroke-width="0.5" />
        <line x1="22" y1="22" x2="78" y2="78" stroke-width="0.3" />
        <line x1="78" y1="22" x2="22" y2="78" stroke-width="0.3" />
        <path d="M50 15 L53 47 L85 50 L53 53 L50 85 L47 53 L15 50 L47 47 Z" stroke-width="0.5" fill="currentColor" opacity="0.3" />
      </svg>
    </div>

    <!-- Floating suit SVGs — text-rendering forces monochrome, hidden on very small screens -->
    <div class="pointer-events-none absolute left-[5%] top-[20%] hidden select-none opacity-[0.025] sm:block" aria-hidden="true">
      <svg width="120" height="120" viewBox="0 0 100 100" fill="currentColor" class="text-white">
        <path d="M50 10 C50 10 20 40 20 60 C20 75 35 85 50 70 C65 85 80 75 80 60 C80 40 50 10 50 10 Z M45 75 L35 95 L65 95 L55 75 Z"/>
      </svg>
    </div>
    <div class="pointer-events-none absolute bottom-[10%] right-[12%] hidden select-none opacity-[0.03] sm:block" aria-hidden="true">
      <svg width="80" height="80" viewBox="0 0 100 100" fill="currentColor" class="text-red">
        <path d="M50 15 L61 40 L88 44 L68 63 L73 90 L50 78 L27 90 L32 63 L12 44 L39 40 Z"/>
      </svg>
    </div>

    <div class="relative z-10 mx-auto w-full max-w-4xl">

      <!-- Top nav -->
      <nav class="mb-10 flex items-center justify-between sm:mb-16">
        <a href="/" class="transition-opacity hover:opacity-70" aria-label="Home">
          <img src="/logo_trimmed.png" alt="Hacklanta" class="h-5 w-auto opacity-80 select-none sm:h-6" draggable="false" />
        </a>
        <a href="/" class="font-mono text-[10px] uppercase tracking-[0.25em] text-white/40 transition-colors hover:text-white/70">
          &larr; Home
        </a>
      </nav>

      <!-- Main typography block -->
      <div class="mb-10 sm:mb-16">
        <!-- "Your application" — outline italic with hover fill -->
        <div class="gate-outline-wrap relative mb-1 cursor-default sm:mb-2">
          <!-- Glow layer -->
          <h1
            class="gate-outline-glow absolute inset-0 font-serif italic text-[clamp(2.6rem,12vw,7rem)] leading-[0.85] tracking-tight"
            aria-hidden="true"
          >Your application</h1>
          <!-- Sharp layer -->
          <h1
            class="gate-outline relative font-serif italic text-[clamp(2.6rem,12vw,7rem)] leading-[0.85] tracking-tight"
          >Your application</h1>
        </div>

        <!-- "is" — red italic accent with hover pop + tilt -->
        <div class="mb-0.5 ml-[2%] sm:mb-1 sm:ml-[5%]">
          <span class="gate-accent inline-block font-serif italic text-[clamp(1.8rem,5vw,3rem)] text-red-bright">is</span>
        </div>

        <!-- "under review" — solid white serif with hover glow -->
        <div class="ml-[4%] sm:ml-[20%]">
          <h2 class="gate-solid cursor-default font-serif text-[clamp(2.8rem,13vw,8rem)] leading-[0.85] tracking-tight text-white">
            under review
          </h2>
        </div>

        <!-- Social CTAs — right under the heading -->
        <div class="mt-5 ml-[4%] flex flex-wrap items-center gap-3 sm:mt-6 sm:ml-[20%] sm:gap-4">
          <a
            href="https://discord.com/invite/BgKg9gskM2"
            target="_blank"
            rel="noopener noreferrer"
            class="group inline-flex items-center gap-2.5 border border-white/[0.08] bg-white/[0.03] px-5 py-2.5 font-mono text-[10px] uppercase tracking-[0.2em] text-white/50 transition-all duration-300 hover:border-[#5865F2]/40 hover:bg-[#5865F2]/10 hover:text-[#5865F2] hover:shadow-[0_0_20px_rgba(88,101,242,0.12)] sm:px-6 sm:py-3 sm:text-[11px]"
          >
            <svg class="h-4 w-4 opacity-60 transition-opacity duration-300 group-hover:opacity-100" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03z"/>
            </svg>
            Discord
          </a>
          <a
            href="https://www.instagram.com/progsuhq/"
            target="_blank"
            rel="noopener noreferrer"
            class="group inline-flex items-center gap-2.5 border border-white/[0.08] bg-white/[0.03] px-5 py-2.5 font-mono text-[10px] uppercase tracking-[0.2em] text-white/50 transition-all duration-300 hover:border-[#E1306C]/40 hover:bg-[#E1306C]/10 hover:text-[#E1306C] hover:shadow-[0_0_20px_rgba(225,48,108,0.12)] sm:px-6 sm:py-3 sm:text-[11px]"
          >
            <svg class="h-4 w-4 opacity-60 transition-opacity duration-300 group-hover:opacity-100" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/>
            </svg>
            Instagram
          </a>
        </div>
      </div>

      <!-- Divider -->
      <div class="mb-8 h-px w-full bg-gradient-to-r from-transparent via-white/10 to-transparent sm:mb-12"></div>

      <!-- Content -->
      <div class="grid gap-8 sm:grid-cols-2 sm:gap-12">
        <div>
          <p class="mb-4 font-body text-sm leading-relaxed text-white/60 sm:mb-6 sm:text-[15px]">
            Thanks for applying to Hacklanta. Your application is currently being reviewed by our team. You'll receive an email once a decision has been made.
          </p>
          <p class="font-body text-sm leading-relaxed text-white/60 sm:text-[15px]">
            Most applications are reviewed within 24–48 hours. Keep an eye on your inbox.
          </p>
        </div>

        <div class="space-y-5 sm:space-y-6">
          <div class="border-l-2 border-red/30 pl-4 sm:pl-5">
            <h3 class="mb-1 font-mono text-[10px] uppercase tracking-[0.25em] text-red-bright">What's next</h3>
            <p class="font-body text-xs text-white/50 sm:text-sm">
              We'll notify you via email as soon as your application has been processed.
            </p>
          </div>
          <div class="border-l-2 border-white/10 pl-4 sm:pl-5">
            <h3 class="mb-1 font-mono text-[10px] uppercase tracking-[0.25em] text-white/60">Need help?</h3>
            <p class="font-body text-xs text-white/50 sm:text-sm">
              Reach out at <a href="mailto:official@progsu.com" class="text-red-bright/80 underline decoration-red/30 transition-colors hover:text-red-bright">official@progsu.com</a>
            </p>
          </div>
        </div>
      </div>

      <!-- Terminal accent -->
      <div class="mt-10 rounded border border-white/[0.06] bg-white/[0.02] px-4 py-3 font-mono text-[10px] leading-relaxed text-white/30 sm:mt-16 sm:px-5 sm:py-4 sm:text-[11px]">
        <span class="text-red-bright/60">$</span> access_status --user=current<br />
        <span class="text-white/40">&gt; STATUS: PENDING_REVIEW</span><br />
        <span class="text-white/40">&gt; ACCESS_LEVEL: LIMITED</span><br />
        <span class="text-white/40">&gt; MESSAGE: Awaiting authorization...</span>
      </div>

      <!-- CTA -->
      <div class="mt-8 flex items-center gap-6 sm:mt-10">
        <a
          href="/"
          class="font-mono text-[10px] uppercase tracking-[0.2em] text-white/30 transition-colors hover:text-white/60 sm:text-[11px]"
        >
          &larr; Back to home
        </a>
      </div>

    </div>
  </main>

  <style>
    .gate-grid {
      background-image:
        linear-gradient(to right, rgba(255,255,255,0.03) 1px, transparent 1px),
        linear-gradient(to bottom, rgba(255,255,255,0.03) 1px, transparent 1px);
      background-size: 40px 40px;
    }

    @media (min-width: 640px) {
      .gate-grid {
        background-size: 60px 60px;
      }
    }

    /* Outline text — sharp stroke */
    .gate-outline {
      -webkit-text-stroke: 1px rgba(255,255,255,0.7);
      color: transparent;
      transition: color 0.4s ease, -webkit-text-stroke-color 0.4s ease, filter 0.4s ease;
    }

    @media (min-width: 640px) {
      .gate-outline {
        -webkit-text-stroke-width: 1.5px;
      }
    }

    /* Outline text — glow behind */
    .gate-outline-glow {
      -webkit-text-stroke: 5px rgba(255,255,255,0.06);
      color: transparent;
      transition: -webkit-text-stroke-color 0.4s ease;
    }

    @media (min-width: 640px) {
      .gate-outline-glow {
        -webkit-text-stroke-width: 8px;
      }
    }

    /* Hover: outline fills in + red glow */
    .gate-outline-wrap:hover .gate-outline {
      color: rgba(230, 57, 70, 0.08);
      -webkit-text-stroke-color: #E63946;
      filter: drop-shadow(0 0 25px rgba(230, 57, 70, 0.35));
    }

    .gate-outline-wrap:hover .gate-outline-glow {
      -webkit-text-stroke-color: rgba(230, 57, 70, 0.15);
    }

    /* Solid text — hover glow */
    .gate-solid {
      transition: filter 0.4s ease, text-shadow 0.4s ease;
    }

    .gate-solid:hover {
      filter: drop-shadow(0 0 20px rgba(230, 57, 70, 0.3));
      text-shadow: 0 0 40px rgba(230, 57, 70, 0.2);
    }

    /* Accent text — hover pop + tilt + glow */
    .gate-accent {
      cursor: default;
      transform-origin: center center;
      transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1), filter 0.4s ease, text-shadow 0.4s ease;
    }

    .gate-accent:hover {
      transform: scale(1.2) rotate(-6deg);
      filter: drop-shadow(0 0 15px rgba(230, 57, 70, 0.5));
      text-shadow: 0 0 30px rgba(230, 57, 70, 0.3);
    }
  </style>
</BaseLayout>
