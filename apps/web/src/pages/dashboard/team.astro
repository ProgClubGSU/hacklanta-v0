---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TabNavigation from '../../components/dashboard/TabNavigation';

// Ensure the user is authenticated on this page
const { userId } = await Astro.locals.auth();
if (!userId) {
  return Astro.redirect('/sign-in');
}
---

<BaseLayout title="Team Matcher | Hacklanta">
  <main class="min-h-screen bg-black px-4 py-16 font-body">
    <div class="mx-auto max-w-6xl">
      {/* Header */}
      <header class="mb-12">
        <h1 class="font-display text-5xl tracking-wide text-white-pure md:text-7xl">
          Team Matcher
        </h1>
        <p class="mt-4 font-mono text-sm uppercase tracking-widest text-gray">
          <span class="text-red">♠</span> Find your crew and build together <span class="text-red">♠</span>
        </p>
      </header>

      {/* Tabbed Navigation */}
      <TabNavigation client:load />
    </div>
  </main>
</BaseLayout>
