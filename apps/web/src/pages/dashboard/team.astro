---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TabNavigation from '../../components/dashboard/TabNavigation';
import { UserMenu } from '../../components/ui/UserMenu';

// Ensure the user is authenticated on this page
const { userId } = await Astro.locals.auth();
if (!userId) {
  return Astro.redirect('/sign-in');
}
---

<BaseLayout title="Team Matcher | Hacklanta">
  <main class="min-h-screen bg-black px-4 py-16 font-body">
    <div class="mx-auto max-w-6xl">
      {/* Top bar */}
      <div class="mb-8 flex items-center justify-between">
        <a href="/" class="text-white/60 transition-colors hover:text-white" aria-label="Home">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
            <polyline points="9 22 9 12 15 12 15 22"></polyline>
          </svg>
        </a>
        <UserMenu client:only="react" />
      </div>

      {/* Header */}
      <header class="mb-12">
        <h1 class="font-display text-5xl tracking-wide text-white-pure md:text-7xl">
          Team Matcher
        </h1>
        <p class="mt-4 font-mono text-sm uppercase tracking-widest text-gray">
          <span class="text-red">♠</span> Find your crew and build together <span class="text-red"
            >♠</span
          >
        </p>
      </header>

      {/* Tabbed Navigation */}
      <TabNavigation client:load />
    </div>
  </main>
</BaseLayout>
