---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TabNavigation from '../../components/dashboard/TabNavigation';
import { createServerSupabaseClient } from '../../lib/supabase-server';

const { userId } = await Astro.locals.auth();
if (!userId) {
  return Astro.redirect('/sign-in');
}

// Check if user is accepted (gated access to team finder)
const supabase = createServerSupabaseClient();
const { data: user } = await supabase
  .from('users')
  .select('is_accepted')
  .eq('clerk_id', userId)
  .single();

if (!user?.is_accepted) {
  return Astro.redirect('/dashboard/pending');
}
---

<BaseLayout title="Team Matcher | Hacklanta">
  <main class="min-h-screen bg-black px-4 py-16 font-body">
    <div class="mx-auto max-w-6xl">
      <TabNavigation client:load />
    </div>
  </main>
</BaseLayout>
