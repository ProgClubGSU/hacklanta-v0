---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { checkDashboardAccess } from '../../lib/dashboard-gate';

const { userId } = await Astro.locals.auth();
if (!userId) {
  return Astro.redirect('/sign-in');
}

// Gate: if user actually has an application or is accepted, redirect them appropriately
const gate = await checkDashboardAccess(userId);

if (gate.status === 'accepted') {
  return Astro.redirect('/dashboard/team');
}
if (gate.status === 'pending') {
  return Astro.redirect('/dashboard/pending');
}
---

<BaseLayout title="No Application Found | Hacklanta">
  <main class="gate-page relative flex min-h-screen flex-col items-center justify-center overflow-hidden bg-[#121212] px-6 py-20">

    <!-- Grid background -->
    <div class="pointer-events-none absolute inset-0 gate-grid opacity-[0.35]" aria-hidden="true"></div>

    <!-- Radial glow -->
    <div class="pointer-events-none absolute inset-0" aria-hidden="true">
      <div class="absolute left-1/2 top-1/2 h-[800px] w-[800px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-[radial-gradient(circle,rgba(196,30,58,0.05)_0%,transparent_70%)]"></div>
    </div>

    <!-- Decorative compass / star -->
    <div class="pointer-events-none absolute left-[6%] bottom-[15%] select-none opacity-[0.06]" aria-hidden="true">
      <svg width="140" height="140" viewBox="0 0 100 100" fill="none" stroke="currentColor" class="text-white">
        <circle cx="50" cy="50" r="35" stroke-width="0.5" />
        <circle cx="50" cy="50" r="25" stroke-width="0.3" />
        <line x1="50" y1="10" x2="50" y2="90" stroke-width="0.5" />
        <line x1="10" y1="50" x2="90" y2="50" stroke-width="0.5" />
        <line x1="22" y1="22" x2="78" y2="78" stroke-width="0.3" />
        <line x1="78" y1="22" x2="22" y2="78" stroke-width="0.3" />
        <path d="M50 15 L53 47 L85 50 L53 53 L50 85 L47 53 L15 50 L47 47 Z" stroke-width="0.5" fill="currentColor" opacity="0.3" />
      </svg>
    </div>

    <!-- Floating suit symbols -->
    <span class="pointer-events-none absolute right-[8%] top-[15%] select-none font-serif text-[10rem] leading-none text-red/[0.03]" aria-hidden="true">♥</span>
    <span class="pointer-events-none absolute left-[10%] bottom-[25%] select-none font-serif text-[7rem] leading-none text-white/[0.02]" aria-hidden="true">♣</span>

    <div class="relative z-10 mx-auto w-full max-w-4xl">

      <!-- Top nav -->
      <nav class="mb-16 flex items-center justify-between">
        <a href="/" class="transition-opacity hover:opacity-70" aria-label="Home">
          <img src="/logo_trimmed.png" alt="Hacklanta" class="h-6 w-auto opacity-80 select-none" draggable="false" />
        </a>
        <a href="/" class="font-mono text-[10px] uppercase tracking-[0.25em] text-white/40 transition-colors hover:text-white/70">
          &larr; Home
        </a>
      </nav>

      <!-- Main typography block -->
      <div class="mb-16 select-none">
        <!-- "No application" — outline italic -->
        <div class="relative mb-2">
          <!-- Glow layer -->
          <h1
            class="gate-outline-glow absolute inset-0 font-serif italic text-[clamp(3rem,10vw,7rem)] leading-[0.9] tracking-tight"
            aria-hidden="true"
          >No application</h1>
          <!-- Sharp layer -->
          <h1
            class="gate-outline relative font-serif italic text-[clamp(3rem,10vw,7rem)] leading-[0.9] tracking-tight"
          >No application</h1>
        </div>

        <!-- "was" — red italic accent -->
        <div class="mb-1 ml-[5%]">
          <span class="font-serif italic text-[clamp(1.5rem,4vw,2.5rem)] text-red-bright">was</span>
        </div>

        <!-- "found" — solid white serif -->
        <div class="ml-[20%] sm:ml-[30%]">
          <h2 class="font-serif text-[clamp(3.5rem,12vw,9rem)] leading-[0.85] tracking-tight text-white">
            found
          </h2>
        </div>
      </div>

      <!-- Divider -->
      <div class="mb-12 h-px w-full bg-gradient-to-r from-transparent via-white/10 to-transparent"></div>

      <!-- Content -->
      <div class="grid gap-12 sm:grid-cols-2">
        <div>
          <p class="mb-6 font-body text-[15px] leading-relaxed text-white/60">
            We couldn't find an application linked to your account. If you haven't applied yet, submit your application to get started.
          </p>
          <p class="font-body text-[15px] leading-relaxed text-white/50">
            If you already submitted a Tally form, make sure you used the same email address you signed up with.
          </p>
        </div>

        <div class="space-y-6">
          <div class="border-l-2 border-red/30 pl-5">
            <h3 class="mb-1 font-mono text-[10px] uppercase tracking-[0.25em] text-red-bright">Apply now</h3>
            <p class="font-body text-sm text-white/50">
              Submit your application to unlock access to the team matcher and dashboard.
            </p>
          </div>
          <div class="border-l-2 border-white/10 pl-5">
            <h3 class="mb-1 font-mono text-[10px] uppercase tracking-[0.25em] text-white/60">Need help?</h3>
            <p class="font-body text-sm text-white/50">
              Reach out at <a href="mailto:official@progsu.com" class="text-red-bright/80 underline decoration-red/30 transition-colors hover:text-red-bright">official@progsu.com</a>
            </p>
          </div>
        </div>
      </div>

      <!-- Terminal accent -->
      <div class="mt-16 rounded border border-white/[0.06] bg-white/[0.02] px-5 py-4 font-mono text-[11px] leading-relaxed text-white/30">
        <span class="text-red-bright/60">$</span> access_status --user=current<br />
        <span class="text-white/40">&gt; STATUS: NO_APPLICATION</span><br />
        <span class="text-white/40">&gt; ACCESS_LEVEL: RESTRICTED</span><br />
        <span class="text-white/40">&gt; MESSAGE: Submit an application to continue...</span>
      </div>

      <!-- CTA -->
      <div class="mt-10 flex items-center gap-6">
        <a
          href="/apply"
          class="group inline-flex items-center gap-3 border border-red/40 bg-red/10 px-8 py-3 font-mono text-[11px] uppercase tracking-[0.2em] text-red-bright transition-all duration-300 hover:border-red/70 hover:bg-red/20 hover:shadow-[0_0_30px_rgba(196,30,58,0.15)]"
        >
          Apply now
          <svg class="h-3.5 w-3.5 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </a>
        <a
          href="/"
          class="font-mono text-[11px] uppercase tracking-[0.2em] text-white/40 transition-colors hover:text-white/70"
        >
          &larr; Back to home
        </a>
      </div>

    </div>
  </main>

  <style>
    .gate-grid {
      background-image:
        linear-gradient(to right, rgba(255,255,255,0.03) 1px, transparent 1px),
        linear-gradient(to bottom, rgba(255,255,255,0.03) 1px, transparent 1px);
      background-size: 60px 60px;
    }

    .gate-outline {
      -webkit-text-stroke: 1.5px rgba(255,255,255,0.7);
      color: transparent;
    }

    .gate-outline-glow {
      -webkit-text-stroke: 8px rgba(255,255,255,0.06);
      color: transparent;
    }
  </style>
</BaseLayout>
