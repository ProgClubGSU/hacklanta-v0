---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TabNavigation from '../../components/dashboard/TabNavigation';
import { checkDashboardAccess } from '../../lib/dashboard-gate';

const { userId } = await Astro.locals.auth();
if (!userId) {
  return Astro.redirect('/sign-in');
}

const gate = await checkDashboardAccess(userId);

if (gate.status === 'no-application') {
  return Astro.redirect('/dashboard/no-application');
}
if (gate.status === 'pending') {
  return Astro.redirect('/dashboard/pending');
}
---

<BaseLayout title="Teams | Hacklanta">
  <main class="min-h-screen bg-[#1a0a0e] px-4 py-8 font-body md:px-8">
    <div class="mx-auto max-w-5xl">
      <TabNavigation client:load page="teams" />
    </div>
  </main>
</BaseLayout>
