---
import LandingLayout from '../layouts/LandingLayout.astro';
---

<LandingLayout>
  <section
    class="flex min-h-screen flex-col items-center justify-center bg-base-black px-4 text-center"
  >
    <p class="mb-4 font-mono text-sm tracking-widest text-text-muted">// presented by progsu</p>

    <h1
      class="font-display text-7xl font-black tracking-tight text-text-primary md:text-9xl"
      style="text-shadow: 0 0 80px rgba(0, 255, 136, 0.3), 0 0 40px rgba(0, 255, 136, 0.1);"
    >
      HACK<span class="text-neon-green">LANTA</span>
    </h1>

    <div class="mt-6 flex items-center gap-3 font-mono text-lg text-text-secondary">
      <span class="text-suit-red">♦</span>
      <span>12-hour hackathon</span>
      <span class="text-suit-red">♥</span>
      <span>atlanta, ga</span>
      <span class="text-gold">♠</span>
    </div>

    <div class="mt-12">
      <a
        href="/apply"
        class="inline-block border-2 border-neon-green bg-neon-green/10 px-8 py-4 font-mono text-lg font-bold text-neon-green transition-all hover:bg-neon-green/20 hover:shadow-[0_0_30px_rgba(0,255,136,0.3)]"
      >
        $ ante_up
      </a>
    </div>

    <p class="mt-8 font-mono text-xs text-text-muted">
      ♠ ♦ ♣ ♥ &mdash; go all in &mdash; ♥ ♣ ♦ ♠
    </p>
  </section>
</LandingLayout>
