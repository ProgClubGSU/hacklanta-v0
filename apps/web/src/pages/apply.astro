---
import LandingLayout from '../layouts/LandingLayout.astro';
import { checkDashboardAccess } from '../lib/dashboard-gate';

const { userId } = await Astro.locals.auth();

// If logged in, check if they've already applied or are accepted
if (userId) {
  const gate = await checkDashboardAccess(userId);

  if (gate.status === 'accepted') {
    return Astro.redirect('/dashboard/team');
  }
  // Pre-cutoff users OR post-cutoff users with a linked application → under review
  if (gate.status === 'pending') {
    return Astro.redirect('/dashboard/pending');
  }
  // gate.status === 'no-application' → let them through to the Tally form
}
---

<LandingLayout title="Apply — Hacklanta">
  <section class="relative min-h-screen bg-black px-4 pb-20 pt-24 md:pt-28">
    <!-- Ambient glow -->
    <div
      class="pointer-events-none absolute left-1/2 top-[10%] h-[800px] w-[800px] -translate-x-1/2 rounded-full"
      style="background: radial-gradient(circle, rgba(196,30,58,0.06) 0%, transparent 55%);"
    ></div>

    <div class="relative z-10 mx-auto max-w-2xl">
      <!-- Tally form embed -->
      <div class="tally-embed">
        <div class="tally-embed-inner">
          <iframe
            data-tally-src={`https://tally.so/embed/q4dzZO?alignLeft=1&hideTitle=1&dynamicHeight=1&formEventsForwarding=1${userId ? `&clerk_id=${userId}` : ''}`}
            loading="lazy"
            width="100%"
            height="1001"
            frameborder="0"
            marginheight="0"
            marginwidth="0"
            title="Hacklanta Application Form"
          ></iframe>
        </div>
      </div>
    </div>
  </section>
</LandingLayout>

<style>
  .tally-embed {
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid rgba(196, 30, 58, 0.1);
    background: #000;
    box-shadow:
      0 0 60px rgba(196, 30, 58, 0.03),
      0 20px 60px rgba(0, 0, 0, 0.5);
  }

  /* Top accent line */
  .tally-embed::before {
    content: '';
    position: absolute;
    inset-inline: 0;
    top: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(196, 30, 58, 0.35), transparent);
    z-index: 2;
  }

  .tally-embed-inner {
    padding: 24px 16px;
    overflow: hidden;
  }

  @media (min-width: 768px) {
    .tally-embed-inner {
      padding: 36px 40px;
    }
  }

  .tally-embed iframe {
    display: block;
    color-scheme: dark;
  }
</style>

<script is:inline>
  // Load Tally embed widget
  const d = document;
  const w = "https://tally.so/widgets/embed.js";
  const v = function () {
    if (typeof Tally !== "undefined") {
      Tally.loadEmbeds();
    } else {
      d.querySelectorAll("iframe[data-tally-src]:not([src])").forEach(
        function (e) {
          e.src = e.dataset.tallySrc;
        }
      );
    }
  };
  if (typeof Tally !== "undefined") {
    v();
  } else if (d.querySelector('script[src="' + w + '"]') == null) {
    const s = d.createElement("script");
    s.src = w;
    s.onload = v;
    s.onerror = v;
    d.body.appendChild(s);
  }

  // Redirect to /status after Tally form submission
  window.addEventListener("message", function (e) {
    try {
      const data = typeof e.data === "string" ? JSON.parse(e.data) : e.data;
      if (data && data.event === "Tally.FormSubmitted") {
        setTimeout(function () {
          window.location.href = "/status";
        }, 1500);
      }
    } catch (_err) {
      // Not a JSON message, ignore
    }
  });
</script>
